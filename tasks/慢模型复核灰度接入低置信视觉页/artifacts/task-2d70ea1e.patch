+
+def test_default_sync_mode_never_triggers_slow_review():
+    audit = build_visual_similarity_slow_review_audit(
+        page_scores=_low_confidence_pages(),
+        key_regions=_low_confidence_regions(),
+        thresholds=_thresholds(),
+        gate_enabled=False,
+        artifact_ready_for_scoring=True,
+    )
+
+    assert audit['enabled'] is False
+    assert audit['selected_page_count'] == 0
+    assert audit['pages'][0]['triggered'] is False
+    assert audit['pages'][0]['decision_reason'] == 'default_sync_disabled'
+    assert audit['pages'][0]['review_status'] == 'disabled'
