@@ -0,0 +1,179 @@
+from __future__ import annotations
+
+from collections.abc import Callable, Mapping, Sequence
+from typing import Any
+
+
+VISUAL_SIMILARITY_SLOW_REVIEW_VERSION = 'pdf_to_word_visual_similarity_slow_review/v1'
+VISUAL_SIMILARITY_SLOW_REVIEW_MODEL = 'qwen3_vl_8b'
+
+
+def build_visual_similarity_slow_review_audit(
+    *,
+    page_scores: Sequence[Mapping[str, Any]],
+    key_regions: Sequence[Mapping[str, Any]],
+    thresholds: Mapping[str, float],
+    gate_enabled: bool,
+    artifact_ready_for_scoring: bool,
+    rollout_enabled: bool = True,
+    reviewer: Callable[[dict[str, Any]], Mapping[str, Any]] | None = None,
+    candidate_model: str = VISUAL_SIMILARITY_SLOW_REVIEW_MODEL,
+    max_review_pages: int = 3,
+    fallback_action: str = 'manual_review',
+) -> dict[str, Any]:
+    region_map = _group_regions_by_page(key_regions)
+    page_entries: list[dict[str, Any]] = []
+    scheduled_count = 0
+    executed_count = 0
+    fallback_count = 0
+
+    for page in page_scores:
+        page_index = int(page.get('page_index') or 0)
+        page_regions = region_map.get(page_index, ())
+        trigger_reasons = _collect_low_confidence_reasons(
+            page=page,
+            regions=page_regions,
+            thresholds=thresholds,
+        )
+        entry = {
+            'page_index': page_index,
+            'triggered': False,
+            'executed': False,
+            'model_profile': None,
+            'trigger_reasons': trigger_reasons,
+            'decision_reason': '',
+            'review_status': 'not_requested',
+            'fallback_action': None,
+            'response': None,
+            'error': None,
+        }
+
+        if not gate_enabled:
+            entry['decision_reason'] = 'default_sync_disabled'
+            entry['review_status'] = 'disabled'
+            page_entries.append(entry)
+            continue
+        if not artifact_ready_for_scoring:
+            entry['decision_reason'] = 'artifact_not_ready'
+            entry['review_status'] = 'disabled'
+            page_entries.append(entry)
+            continue
+        if not rollout_enabled:
+            entry['decision_reason'] = 'rollout_disabled'
+            entry['review_status'] = 'disabled'
+            page_entries.append(entry)
+            continue
+        if _has_hard_fail(page=page, regions=page_regions):
+            entry['decision_reason'] = 'hard_fail_page_or_region'
+            page_entries.append(entry)
+            continue
+        if not trigger_reasons:
+            entry['decision_reason'] = 'page_confident_no_slow_review'
+            page_entries.append(entry)
+            continue
+        if scheduled_count >= max(0, int(max_review_pages)):
+            entry['decision_reason'] = 'review_budget_exhausted'
+            entry['review_status'] = 'not_requested'
+            page_entries.append(entry)
+            continue
+
+        entry['triggered'] = True
+        entry['model_profile'] = candidate_model
+        scheduled_count += 1
+
+        if reviewer is None:
+            entry['decision_reason'] = 'slow_review_worker_not_configured'
+            entry['review_status'] = 'fallback_skipped'
+            entry['fallback_action'] = fallback_action
+            fallback_count += 1
+            page_entries.append(entry)
+            continue
+
+        request = {
+            'page_index': page_index,
+            'model_profile': candidate_model,
+            'trigger_reasons': trigger_reasons,
+            'page_score': dict(page),
+            'key_regions': [dict(region) for region in page_regions],
+        }
+        try:
+            response = reviewer(request)
+        except Exception as exc:  # pragma: no cover - defensive runtime guard
+            entry['decision_reason'] = 'slow_review_worker_failed'
+            entry['review_status'] = 'fallback_skipped'
+            entry['fallback_action'] = fallback_action
+            entry['error'] = str(exc)
+            fallback_count += 1
+            page_entries.append(entry)
+            continue
+
+        entry['decision_reason'] = 'slow_review_completed'
+        entry['review_status'] = 'completed'
+        entry['executed'] = True
+        entry['response'] = dict(response or {})
+        executed_count += 1
+        page_entries.append(entry)
+
+    return {
+        'report_type': VISUAL_SIMILARITY_SLOW_REVIEW_VERSION,
+        'enabled': gate_enabled,
+        'artifact_ready_for_scoring': artifact_ready_for_scoring,
+        'rollout_enabled': rollout_enabled,
+        'candidate_model': candidate_model,
+        'max_review_pages': int(max_review_pages),
+        'selected_page_count': scheduled_count,
+        'executed_page_count': executed_count,
+        'fallback_page_count': fallback_count,
+        'pages': page_entries,
+    }
+
+
+def _collect_low_confidence_reasons(
+    *,
+    page: Mapping[str, Any],
+    regions: Sequence[Mapping[str, Any]],
+    thresholds: Mapping[str, float],
+) -> list[str]:
+    reasons = list(page.get('review_reasons') or [])
+    page_thresholds = page.get('thresholds') if isinstance(page.get('thresholds'), Mapping) else {}
+    review_band = float(thresholds.get('slow_model_review_band') or 0.03)
+    similarity = _optional_float(page.get('page_render_similarity'))
+    similarity_min = float(page_thresholds.get('page_render_similarity_min') or 0.0)
+    if _is_near_threshold(similarity, minimum=similarity_min, review_band=review_band):
+        reasons.append('near_threshold_page_render_similarity')
+
+    for region in regions:
+        reasons.extend(str(item) for item in region.get('review_reasons') or [])
+        region_thresholds = region.get('thresholds') if isinstance(region.get('thresholds'), Mapping) else {}
+        region_similarity = _optional_float(region.get('region_similarity'))
+        region_min = float(region_thresholds.get('region_similarity_min') or 0.0)
+        if _is_near_threshold(region_similarity, minimum=region_min, review_band=review_band):
+            reasons.append(f"near_threshold_key_region_similarity:{region.get('region_id')}")
+
+    return sorted({str(reason).strip() for reason in reasons if str(reason).strip()})
+
+
+def _has_hard_fail(*, page: Mapping[str, Any], regions: Sequence[Mapping[str, Any]]) -> bool:
+    if page.get('passed') is False:
+        return True
+    return any(region.get('passed') is False for region in regions)
+
+
+def _group_regions_by_page(key_regions: Sequence[Mapping[str, Any]]) -> dict[int, list[Mapping[str, Any]]]:
+    grouped: dict[int, list[Mapping[str, Any]]] = {}
+    for region in key_regions:
+        page_index = int(region.get('page_index') or 0)
+        grouped.setdefault(page_index, []).append(region)
+    return grouped
+
+
+def _optional_float(value: object) -> float | None:
+    if value is None or value == '':
+        return None
+    return float(value)
+
+
+def _is_near_threshold(value: float | None, *, minimum: float, review_band: float) -> bool:
+    if value is None:
+        return False
+    return minimum <= value < minimum + review_band
