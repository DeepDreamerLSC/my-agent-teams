+def test_confident_pages_are_skipped():
+    audit = build_visual_similarity_slow_review_audit(
+        page_scores=[
+            {
+                'page_index': 3,
+                'page_role': 'regular',
+                'page_render_similarity': 0.97,
+                'thresholds': {'page_render_similarity_min': 0.88},
+                'review_reasons': [],
+            }
+        ],
+        key_regions=[],
+        thresholds=_thresholds(),
+        gate_enabled=True,
+        artifact_ready_for_scoring=True,
