+def test_quality_gate_triggers_slow_review_for_low_confidence_pages(tmp_path: Path):
+    contract = _build_contract(tmp_path)
+    seen_requests: list[dict[str, object]] = []
+
+    def reviewer(request: dict[str, object]) -> dict[str, object]:
+        seen_requests.append(request)
+        return {'decision': 'manual_compare', 'confidence': 0.77}
+
+    report = build_visual_similarity_gate_report(
+        contract,
+        requested_mode='quality',
+        parser_backend='hybrid_experimental',
+        slow_review_worker=reviewer,
+    )
+
+    first_page = report['slow_model_review']['pages'][0]
+    second_page = report['slow_model_review']['pages'][1]
+
+    assert report['mode_boundary']['resolved_gate_mode'] == QUALITY_HYBRID_ASYNC_MODE
+    assert report['status'] == 'ready'
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['slow_model_policy']['candidate_models'] == [VISUAL_SIMILARITY_SLOW_REVIEW_MODEL]
+    assert first_page['triggered'] is True
+    assert first_page['executed'] is True
+    assert first_page['review_status'] == 'completed'
+    assert first_page['model_profile'] == VISUAL_SIMILARITY_SLOW_REVIEW_MODEL
+    assert first_page['response']['decision'] == 'manual_compare'
+    assert second_page['triggered'] is False
+    assert second_page['decision_reason'] == 'page_confident_no_slow_review'
+    assert seen_requests[0]['page_index'] == 1
+    assert report['human_review_required'] is True
+    assert 'slow_review_completed:p1' in report['human_review_reasons']
+
+
+def test_default_sync_never_triggers_slow_review(tmp_path: Path):
