+def _ensure_fixture_file(path: Path) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    if path.suffix == '.json':
+        path.write_text('{}\n', encoding='utf-8')
+    else:
+        path.write_bytes(b'fixture')
+
+
+def _build_render_pair_artifact(tmp_path: Path) -> dict[str, object]:
+    render_root = tmp_path / 'renders'
+    output_root = render_root / 'docx'
+    source_root = render_root / 'source'
+    converted_pdf = render_root / 'rendered-output.pdf'
+    _ensure_fixture_file(converted_pdf)
+
+    render_pairs: list[dict[str, object]] = []
+    for page_index in (1, 2):
+        source_image = source_root / f'page-{page_index:03d}.png'
+        source_meta = source_root / f'page-{page_index:03d}.json'
+        docx_image = output_root / f'page-{page_index:03d}.png'
+        docx_meta = output_root / f'page-{page_index:03d}.json'
+        for artifact_path in (source_image, source_meta, docx_image, docx_meta):
+            _ensure_fixture_file(artifact_path)
+        render_pairs.append(
+            {
+                'page_index': page_index,
+                'pair_status': 'matched',
+                'alignment_mode': 'page_index',
+                'source_pdf': {
+                    'page_index': page_index,
+                    'image_path': str(source_image),
+                    'render_artifact': str(source_meta),
+                },
+                'output_docx': {
+                    'page_index': page_index,
+                    'image_path': str(docx_image),
+                    'render_artifact': str(docx_meta),
+                },
+            }
+        )
+
+    return {
+        'report_type': 'pdf_to_word_render_pair/v1',
+        'status': 'success',
+        'ok': True,
+        'failure_code': None,
+        'errors': [],
+        'render_pairs': render_pairs,
+        'evidence_paths': {
+            'output_root': str(render_root),
+            'source_pdf_render_dir': str(source_root),
+            'output_docx_render_dir': str(output_root),
+            'docx_converted_pdf_path': str(converted_pdf),
+        },
+    }
+
+
+def _build_contract(tmp_path: Path, *, rollout_enabled: bool = True) -> dict[str, object]:
+    debug_root = tmp_path / 'debug'
+    diff_root = tmp_path / 'diffs'
+    for artifact_path in (
+        debug_root / 'quality_ready.html',
+        debug_root / 'quality_ready.md',
+        diff_root / 'pages' / 'page-001-diff.png',
+        diff_root / 'pages' / 'page-002-diff.png',
+        diff_root / 'regions' / 'math-p1-table-source.png',
+        diff_root / 'regions' / 'math-p1-table-docx.png',
+        diff_root / 'regions' / 'math-p1-table-diff.png',
+    ):
+        _ensure_fixture_file(artifact_path)
+
+    return {
+        'contract_version': VISUAL_SIMILARITY_GATE_VERSION,
+        'implementation_status': 'real_render_pair_artifact_ready',
+        'source_policy': {
+            'route_doc_date': '2026-05-19',
+            'target_total_score_threshold': 95,
+            'visual_similarity_weight': 17,
+            'quality_target_scope': 'quality/hybrid_async only',
+            'default_sync_policy': 'default sync cannot use render comparison or slow models',
+            'sync_boundary': 'default sync cannot be slowed by render comparison or slow visual models',
+        },
+        'thresholds': {
+            'document_overall_similarity_min': 0.95,
+            'critical_page_render_similarity_min': 0.92,
+            'regular_page_render_similarity_min': 0.88,
+            'key_region_similarity_min': 0.90,
+            'bbox_iou_min': 0.85,
+            'layout_density_delta_max': 0.08,
+            'text_coverage_delta_max': 0.10,
+            'image_coverage_delta_max': 0.10,
+            'slow_model_review_band': 0.03,
+        },
+        'slow_model_policy': {
+            'allowed_modes': ['quality', 'hybrid_async'],
+            'disallowed_modes': ['fast', 'balanced', 'default_sync'],
+            'candidate_models': ['qwen3_vl_8b'],
+            'rollout_enabled': rollout_enabled,
+            'max_review_pages': 2,
+            'fallback_action': 'manual_review',
+            'notes': 'Slow review is gray-only evidence for low-confidence pages in quality/hybrid_async.',
+        },
+        'artifact_contract': {
+            'required_artifacts': ['visual_similarity.json', 'render_pair.json', 'slow_model_review.json'],
+            'required_fields': list(ARTIFACT_REQUIRED_FIELDS),
+            'allowed_subject_page_types': list(ALLOWED_SUBJECT_PAGE_TYPES),
+            'allowed_region_types': list(ALLOWED_REGION_TYPES),
+        },
+        'subject_page_type': 'math',
+        'render_pair_artifact': _build_render_pair_artifact(tmp_path),
+        'page_scores': [
+            {
+                'page_index': 1,
+                'subject_page_type': 'math',
+                'page_role': 'critical',
+                'page_render_similarity': 0.93,
+                'layout_density_delta': 0.02,
+                'text_coverage_delta': 0.01,
+                'image_coverage_delta': 0.01,
+                'diff_image_path': str(diff_root / 'pages' / 'page-001-diff.png'),
+            },
+            {
+                'page_index': 2,
+                'subject_page_type': 'math',
+                'page_role': 'regular',
+                'page_render_similarity': 0.98,
+                'layout_density_delta': 0.01,
+                'text_coverage_delta': 0.01,
+                'image_coverage_delta': 0.01,
+                'diff_image_path': str(diff_root / 'pages' / 'page-002-diff.png'),
+            },
+        ],
+        'key_regions': [
+            {
+                'page_index': 1,
+                'subject_page_type': 'math',
+                'region_id': 'math:p1:table-01',
+                'region_type': 'table',
+                'required': True,
+                'bbox': {'x0': 88.0, 'y0': 392.0, 'x1': 512.0, 'y1': 582.0},
+                'region_similarity': 0.905,
+                'bbox_iou': 0.91,
+                'source_crop_path': str(diff_root / 'regions' / 'math-p1-table-source.png'),
+                'docx_crop_path': str(diff_root / 'regions' / 'math-p1-table-docx.png'),
+                'diff_image_path': str(diff_root / 'regions' / 'math-p1-table-diff.png'),
+            }
+        ],
+        'evidence_paths': {
+            'debug_html_path': str(debug_root / 'quality_ready.html'),
+            'debug_markdown_path': str(debug_root / 'quality_ready.md'),
+            'page_diff_dir': str(diff_root / 'pages'),
