+            'page_role': 'critical',
+            'page_render_similarity': 0.93,
+            'thresholds': {'page_render_similarity_min': 0.92},
+            'review_reasons': ['near_threshold_page_render_similarity:p1'],
+        },
+        {
+            'page_index': 2,
+            'page_role': 'regular',
+            'page_render_similarity': 0.89,
+            'thresholds': {'page_render_similarity_min': 0.88},
+            'review_reasons': ['near_threshold_page_render_similarity:p2'],
