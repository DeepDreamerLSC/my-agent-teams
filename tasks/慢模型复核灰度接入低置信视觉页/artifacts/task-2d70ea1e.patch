@@ -0,0 +1,785 @@
+from __future__ import annotations
+
+import json
+from collections.abc import Callable, Mapping, Sequence
+from pathlib import Path
+from typing import Any
+
+from app.services.pdf_to_word.visual_similarity_slow_review import (
+    VISUAL_SIMILARITY_SLOW_REVIEW_MODEL,
+    build_visual_similarity_slow_review_audit,
+)
+
+
+VISUAL_SIMILARITY_GATE_VERSION = 'pdf_to_word_visual_similarity_gate/v1'
+VISUAL_SIMILARITY_REPORT_TYPE = 'pdf_to_word_visual_similarity_evidence'
+VISUAL_SIMILARITY_ARTIFACT_NAME = 'visual_similarity.json'
+VISUAL_SIMILARITY_DIMENSION_KEY = 'visual_similarity'
+VISUAL_SIMILARITY_DIMENSION_WEIGHT = 17
+QUALITY_HYBRID_ASYNC_MODE = 'quality/hybrid_async'
+DEFAULT_SYNC_MODE = 'default_sync'
+QUALITY_GATE_MODES = {'quality', 'hybrid_async', QUALITY_HYBRID_ASYNC_MODE}
+DEFAULT_SYNC_MODES = {'', 'auto', 'apple', 'fast', 'balanced', DEFAULT_SYNC_MODE}
+ALLOWED_SUBJECT_PAGE_TYPES = (
+    'science',
+    'math',
+    'english',
+    'chinese',
+    'negative',
+    'answer_section',
+)
+ALLOWED_REGION_TYPES = (
+    'question_number',
+    'question_backbone',
+    'table',
+    'image',
+    'options',
+    'answer_area',
+    'reading',
+    'formula_graphic',
+)
+ARTIFACT_REQUIRED_FIELDS = (
+    'report_type',
+    'contract_version',
+    'status',
+    'failure_code',
+    'mode_boundary',
+    'score_contract',
+    'thresholds',
+    'render_pairs',
+    'page_scores',
+    'key_regions',
+    'vetoes',
+    'subject_page_type',
+    'human_review_required',
+    'evidence_paths',
+    'slow_model_review',
+)
+DEFAULT_THRESHOLDS: dict[str, float] = {
+    'document_overall_similarity_min': 0.95,
+    'critical_page_render_similarity_min': 0.92,
+    'regular_page_render_similarity_min': 0.88,
+    'key_region_similarity_min': 0.90,
+    'bbox_iou_min': 0.85,
+    'layout_density_delta_max': 0.08,
+    'text_coverage_delta_max': 0.10,
+    'image_coverage_delta_max': 0.10,
+    'slow_model_review_band': 0.03,
+}
+
+
+class VisualSimilarityGateError(ValueError):
+    """Raised when a visual-similarity contract fixture is structurally invalid."""
+
+
+def load_visual_similarity_contract(path: str | Path) -> dict[str, Any]:
+    contract_path = Path(path).expanduser().resolve()
+    return json.loads(contract_path.read_text(encoding='utf-8'))
+
+
+def resolve_visual_gate_mode(requested_mode: str | None, *, parser_backend: str | None = None) -> str:
+    mode = _normalize_mode(requested_mode)
+    backend = str(parser_backend or '').strip().lower()
+    if mode in QUALITY_GATE_MODES:
+        return QUALITY_HYBRID_ASYNC_MODE
+    if backend == 'hybrid_experimental' and mode == 'quality':
+        return QUALITY_HYBRID_ASYNC_MODE
+    if mode in DEFAULT_SYNC_MODES:
+        return DEFAULT_SYNC_MODE
+    return DEFAULT_SYNC_MODE
+
+
+def write_visual_similarity_gate_artifact(report: Mapping[str, Any], output_path: str | Path) -> Path:
+    artifact_path = Path(output_path).expanduser().resolve()
+    artifact_path.parent.mkdir(parents=True, exist_ok=True)
+    artifact_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return artifact_path
+
+
+def build_visual_similarity_gate_report(
+    contract: Mapping[str, Any],
+    *,
+    requested_mode: str | None = None,
+    parser_backend: str | None = None,
+    slow_review_worker: Callable[[dict[str, Any]], Mapping[str, Any]] | None = None,
+) -> dict[str, Any]:
+    _validate_contract(contract)
+    thresholds = _coerce_thresholds(contract.get('thresholds'))
+    gate_mode = resolve_visual_gate_mode(requested_mode, parser_backend=parser_backend)
+    gate_enabled = gate_mode == QUALITY_HYBRID_ASYNC_MODE
+    subject_page_type = _normalize_subject_page_type(contract.get('subject_page_type'), fallback='negative')
+    render_pair_artifact, render_pair_artifact_path, render_pair_load_error = _load_render_pair_artifact(contract)
+    render_pair_validation = _validate_render_pair_artifact(
+        render_pair_artifact,
+        render_pair_artifact_path,
+        load_error=render_pair_load_error,
+    )
+
+    render_pairs = list(render_pair_artifact.get('render_pairs') or []) if isinstance(render_pair_artifact, Mapping) else []
+    page_scores, page_vetoes, page_review_reasons, page_ready_failures = _build_page_scores(
+        contract.get('page_scores') or [],
+        render_pairs,
+        thresholds=thresholds,
+        default_subject_page_type=subject_page_type,
+    )
+    page_subject_by_index = {
+        int(page['page_index']): str(page['subject_page_type'])
+        for page in page_scores
+        if int(page.get('page_index') or 0) > 0
+    }
+    key_regions, region_vetoes, region_review_reasons, region_ready_failures = _build_key_regions(
+        contract.get('key_regions') or [],
+        thresholds=thresholds,
+        page_subject_by_index=page_subject_by_index,
+        default_subject_page_type=subject_page_type,
+    )
+
+    readiness_failures = sorted(
+        set(
+            list(render_pair_validation['readiness_failures'])
+            + page_ready_failures
+            + region_ready_failures
+        )
+    )
+    artifact_ready_for_scoring = not readiness_failures
+
+    vetoes: list[dict[str, Any]] = []
+    if readiness_failures:
+        vetoes.append(
+            _make_veto(
+                code='visual_similarity_artifact_not_ready',
+                scope='document',
+                severity='p0',
+                reason='visual similarity artifact lacks real render-pair evidence or complete scoring payload',
+                blocking=True,
+                details=readiness_failures,
+            )
+        )
+    vetoes.extend(page_vetoes)
+    vetoes.extend(region_vetoes)
+
+    aggregate = _build_aggregate(render_pairs, page_scores, key_regions, vetoes)
+    if artifact_ready_for_scoring and aggregate['overall_page_similarity_mean'] is not None:
+        if aggregate['overall_page_similarity_mean'] < thresholds['document_overall_similarity_min']:
+            vetoes.append(
+                _make_veto(
+                    code='document_overall_similarity_below_threshold',
+                    scope='document',
+                    severity='p1',
+                    reason=(
+                        f"overall page similarity {aggregate['overall_page_similarity_mean']:.4f} below "
+                        f"{thresholds['document_overall_similarity_min']:.4f}"
+                    ),
+                    blocking=True,
+                )
+            )
+            aggregate = _build_aggregate(render_pairs, page_scores, key_regions, vetoes)
+
+    blocking_vetoes = [veto for veto in vetoes if veto.get('blocking')]
+    if not artifact_ready_for_scoring:
+        status = 'artifact_not_ready'
+        failure_code = 'visual_similarity_artifact_not_ready'
+    elif blocking_vetoes:
+        status = 'failed'
+        failure_code = 'visual_similarity_veto_triggered'
+    else:
+        status = 'ready'
+        failure_code = None
+
+    slow_model_policy = _build_slow_model_policy(contract, enabled=gate_enabled)
+    slow_model_review = build_visual_similarity_slow_review_audit(
+        page_scores=page_scores,
+        key_regions=key_regions,
+        thresholds=thresholds,
+        gate_enabled=gate_enabled,
+        artifact_ready_for_scoring=artifact_ready_for_scoring,
+        rollout_enabled=bool(slow_model_policy.get('rollout_enabled', True)),
+        reviewer=slow_review_worker,
+        candidate_model=str(slow_model_policy.get('candidate_models', [VISUAL_SIMILARITY_SLOW_REVIEW_MODEL])[0]),
+        max_review_pages=int(slow_model_policy.get('max_review_pages') or 3),
+        fallback_action=str(slow_model_policy.get('fallback_action') or 'manual_review'),
+    )
+
+    slow_review_reasons = []
+    for page in slow_model_review['pages']:
+        if page.get('triggered'):
+            slow_review_reasons.append(f"slow_review_triggered:p{page.get('page_index')}")
+        if page.get('review_status') == 'fallback_skipped':
+            slow_review_reasons.append(f"slow_review_fallback:p{page.get('page_index')}")
+        elif page.get('review_status') == 'completed':
+            slow_review_reasons.append(f"slow_review_completed:p{page.get('page_index')}")
+
+    human_review_reasons = sorted(
+        set(page_review_reasons)
+        | set(region_review_reasons)
+        | set(slow_review_reasons)
+        | ({'visual_similarity_artifact_not_ready'} if not artifact_ready_for_scoring else set())
+    )
+
+    return {
+        'report_type': VISUAL_SIMILARITY_REPORT_TYPE,
+        'contract_version': str(contract.get('contract_version') or VISUAL_SIMILARITY_GATE_VERSION),
+        'artifact_name': VISUAL_SIMILARITY_ARTIFACT_NAME,
+        'implementation_status': str(
+            contract.get('implementation_status')
+            or ('real_render_pair_artifact_ready' if artifact_ready_for_scoring else 'contract_only_render_pair_missing')
+        ),
+        'status': status,
+        'failure_code': failure_code,
+        'mode_boundary': {
+            'requested_mode': _normalize_mode(requested_mode),
+            'parser_backend': str(parser_backend or '').strip() or None,
+            'resolved_gate_mode': gate_mode,
+            'enabled': gate_enabled,
+            'default_sync_safe': True,
+            'default_sync_invokes_render_or_slow_model': False,
+            'reason': (
+                'visual similarity enters the 95-point route only in quality/hybrid_async'
+                if gate_enabled
+                else 'default synchronous modes must not count visual similarity scoring'
+            ),
+        },
+        'score_contract': _build_score_contract(
+            gate_enabled=gate_enabled,
+            artifact_ready_for_scoring=artifact_ready_for_scoring,
+            blocking_vetoes=blocking_vetoes,
+        ),
+        'thresholds': thresholds,
+        'artifact_contract': _build_artifact_contract(contract),
+        'render_pair_status': render_pair_validation['status'],
+        'render_pair_failure_code': render_pair_validation['failure_code'],
+        'render_pairs': render_pairs,
+        'page_scores': page_scores,
+        'key_regions': key_regions,
+        'vetoes': vetoes,
+        'blocking_failures': [str(veto.get('code') or '') for veto in blocking_vetoes],
+        'subject_page_type': subject_page_type,
+        'human_review_required': bool(human_review_reasons),
+        'human_review_reasons': human_review_reasons,
+        'evidence_paths': _build_evidence_paths(contract, render_pair_artifact, render_pair_artifact_path),
+        'aggregate': aggregate,
+        'artifact_ready_for_scoring': artifact_ready_for_scoring,
+        'gate_passed': artifact_ready_for_scoring and not blocking_vetoes,
+        'slow_model_policy': slow_model_policy,
+        'slow_model_review': slow_model_review,
+        'known_gaps': list(contract.get('known_gaps') or []),
+        'downstream_required_work': list(contract.get('downstream_required_work') or []),
+    }
+
+
+def _validate_contract(contract: Mapping[str, Any]) -> None:
+    required = {
+        'contract_version',
+        'source_policy',
+        'thresholds',
+        'slow_model_policy',
+        'artifact_contract',
+        'page_scores',
+        'key_regions',
+        'evidence_paths',
+    }
+    missing = sorted(required - set(contract))
+    if missing:
+        raise VisualSimilarityGateError(f'missing visual similarity contract fields: {missing}')
+    if str(contract.get('contract_version') or '') != VISUAL_SIMILARITY_GATE_VERSION:
+        raise VisualSimilarityGateError('unsupported visual similarity contract_version')
+
+    source_policy = contract.get('source_policy') if isinstance(contract.get('source_policy'), Mapping) else {}
+    if int(source_policy.get('visual_similarity_weight') or 0) != VISUAL_SIMILARITY_DIMENSION_WEIGHT:
+        raise VisualSimilarityGateError('visual_similarity_weight must remain 17 in the 95-point route')
+    if 'quality/hybrid_async' not in str(source_policy.get('quality_target_scope') or ''):
+        raise VisualSimilarityGateError('quality_target_scope must mention quality/hybrid_async')
+
+    slow_model_policy = contract.get('slow_model_policy')
+    if not isinstance(slow_model_policy, Mapping):
+        raise VisualSimilarityGateError('slow_model_policy must be an object')
+    disallowed = {str(item).strip() for item in slow_model_policy.get('disallowed_modes') or []}
+    if not {'fast', 'balanced', DEFAULT_SYNC_MODE}.issubset(disallowed):
+        raise VisualSimilarityGateError('slow_model_policy must explicitly block default sync modes')
+    active_candidates = [str(item).strip() for item in slow_model_policy.get('candidate_models') or []]
+    if active_candidates != [VISUAL_SIMILARITY_SLOW_REVIEW_MODEL]:
+        raise VisualSimilarityGateError('active slow-model candidate_models must be exactly [qwen3_vl_8b]')
+
+    artifact_contract = contract.get('artifact_contract')
+    if not isinstance(artifact_contract, Mapping):
+        raise VisualSimilarityGateError('artifact_contract must be an object')
+    required_fields = set(artifact_contract.get('required_fields') or [])
+    if not set(ARTIFACT_REQUIRED_FIELDS).issubset(required_fields):
+        raise VisualSimilarityGateError('artifact_contract.required_fields must include canonical visual evidence fields')
+    allowed_subject_types = set(artifact_contract.get('allowed_subject_page_types') or [])
+    if not set(ALLOWED_SUBJECT_PAGE_TYPES).issubset(allowed_subject_types):
+        raise VisualSimilarityGateError('artifact_contract.allowed_subject_page_types must cover all required subject/page classes')
+    allowed_region_types = set(artifact_contract.get('allowed_region_types') or [])
+    if not {'table', 'image', 'options', 'answer_area', 'reading', 'formula_graphic', 'question_backbone'}.issubset(allowed_region_types):
+        raise VisualSimilarityGateError('artifact_contract.allowed_region_types must cover common cross-subject key-region classes')
+
+
+def _load_render_pair_artifact(contract: Mapping[str, Any]) -> tuple[dict[str, Any] | None, str | None, str | None]:
+    inline_payload = contract.get('render_pair_artifact')
+    if isinstance(inline_payload, Mapping):
+        return dict(inline_payload), None, None
+    render_pair_path = str(contract.get('render_pair_artifact_path') or '').strip()
+    if not render_pair_path:
+        return None, None, None
+    path = Path(render_pair_path).expanduser().resolve()
+    if not path.exists():
+        return None, str(path), 'render_pair_artifact_missing'
+    try:
+        return json.loads(path.read_text(encoding='utf-8')), str(path), None
+    except Exception as exc:  # pragma: no cover - defensive runtime guard
+        return None, str(path), f'render_pair_artifact_unreadable:{exc}'
+
+
+def _validate_render_pair_artifact(
+    payload: Mapping[str, Any] | None,
+    artifact_path: str | None,
+    *,
+    load_error: str | None,
+) -> dict[str, Any]:
+    readiness_failures: list[str] = []
+    failure_code: str | None = None
+    status = 'missing'
+    if load_error:
+        readiness_failures.append(load_error)
+        failure_code = load_error.split(':', 1)[0]
+    elif not isinstance(payload, Mapping):
+        readiness_failures.append('render_pair_artifact_missing')
+        failure_code = 'render_pair_artifact_missing'
+    else:
+        status = str(payload.get('status') or '').strip() or 'missing'
+        if artifact_path and not Path(artifact_path).exists():
+            readiness_failures.append('render_pair_artifact_path_missing')
+        if status != 'success' or payload.get('ok') is not True or payload.get('failure_code'):
+            readiness_failures.append(f'render_pair_status_not_success:{status or "unknown"}')
+            failure_code = str(payload.get('failure_code') or status or 'render_pair_failed')
+        render_pairs = list(payload.get('render_pairs') or [])
+        if not render_pairs:
+            readiness_failures.append('render_pair_list_missing')
+            failure_code = failure_code or 'render_pair_list_missing'
+        for pair in render_pairs:
+            if not isinstance(pair, Mapping):
+                readiness_failures.append('render_pair_entry_invalid')
+                failure_code = failure_code or 'render_pair_entry_invalid'
+                continue
+            page_index = int(pair.get('page_index') or 0)
+            pair_status = str(pair.get('pair_status') or '').strip()
+            if pair_status != 'matched':
+                readiness_failures.append(f'render_pair_not_matched:p{page_index}')
+                failure_code = failure_code or 'render_pair_not_matched'
+            for side_key in ('source_pdf', 'output_docx'):
+                side = pair.get(side_key)
+                if not isinstance(side, Mapping):
+                    readiness_failures.append(f'render_pair_side_missing:{side_key}:p{page_index}')
+                    failure_code = failure_code or 'render_pair_side_missing'
+                    continue
+                for field_name in ('image_path', 'render_artifact'):
+                    raw_path = str(side.get(field_name) or '').strip()
+                    if not raw_path:
+                        readiness_failures.append(f'render_pair_field_missing:{side_key}:{field_name}:p{page_index}')
+                        failure_code = failure_code or 'render_pair_field_missing'
+                        continue
+                    if not Path(raw_path).expanduser().exists():
+                        readiness_failures.append(f'render_pair_path_missing:{side_key}:{field_name}:p{page_index}')
+                        failure_code = failure_code or 'render_pair_path_missing'
+    return {
+        'ready': not readiness_failures,
+        'status': status,
+        'failure_code': failure_code,
+        'readiness_failures': readiness_failures,
+    }
+
+
+def _build_page_scores(
+    raw_scores: Sequence[object],
+    render_pairs: Sequence[object],
+    *,
+    thresholds: Mapping[str, float],
+    default_subject_page_type: str,
+) -> tuple[list[dict[str, Any]], list[dict[str, Any]], list[str], list[str]]:
+    raw_by_page = {
+        int(item.get('page_index') or 0): item
+        for item in raw_scores
+        if isinstance(item, Mapping) and int(item.get('page_index') or 0) > 0
+    }
+    reports: list[dict[str, Any]] = []
+    vetoes: list[dict[str, Any]] = []
+    review_reasons: list[str] = []
+    readiness_failures: list[str] = []
+
+    for pair in render_pairs:
+        if not isinstance(pair, Mapping):
+            continue
+        page_index = int(pair.get('page_index') or 0)
+        pair_status = str(pair.get('pair_status') or 'unknown').strip() or 'unknown'
+        raw = raw_by_page.get(page_index)
+        evidence = _build_page_evidence(pair, raw if isinstance(raw, Mapping) else None)
+        if raw is None:
+            readiness_failures.append(f'page_score_missing:p{page_index}')
+            reports.append(
+                {
+                    'page_index': page_index,
+                    'subject_page_type': default_subject_page_type,
+                    'page_role': 'unknown',
+                    'pair_status': pair_status,
+                    'page_render_similarity': None,
+                    'layout_density_delta': None,
+                    'text_coverage_delta': None,
+                    'image_coverage_delta': None,
+                    'thresholds': {'page_render_similarity_min': thresholds['critical_page_render_similarity_min']},
+                    'passed': False,
+                    'review_required': True,
+                    'review_reasons': ['page_score_missing'],
+                    'evidence': evidence,
+                }
+            )
+            review_reasons.append(f'page_score_missing:p{page_index}')
+            continue
+
+        subject_page_type = _normalize_subject_page_type(raw.get('subject_page_type'), fallback=default_subject_page_type)
+        page_role = str(raw.get('page_role') or 'regular').strip().lower() or 'regular'
+        similarity_threshold = (
+            thresholds['critical_page_render_similarity_min']
+            if page_role == 'critical'
+            else thresholds['regular_page_render_similarity_min']
+        )
+        similarity = _optional_float(raw.get('page_render_similarity'))
+        layout_density_delta = _optional_float(raw.get('layout_density_delta'))
+        text_coverage_delta = _optional_float(raw.get('text_coverage_delta'))
+        image_coverage_delta = _optional_float(raw.get('image_coverage_delta'))
+
+        page_review_reasons: list[str] = []
+        page_passed = pair_status == 'matched'
+        if pair_status != 'matched':
+            readiness_failures.append(f'render_pair_not_matched:p{page_index}')
+
+        if None in (similarity, layout_density_delta, text_coverage_delta, image_coverage_delta):
+            readiness_failures.append(f'page_score_metrics_incomplete:p{page_index}')
+            page_passed = False
+
+        if similarity is None:
+            page_review_reasons.append(f'page_render_similarity_missing:p{page_index}')
+        elif similarity < similarity_threshold:
+            vetoes.append(
+                _make_veto(
+                    code='page_render_similarity_below_threshold',
+                    scope='page',
+                    severity='p0' if page_role == 'critical' else 'p1',
+                    reason=f'page render similarity {similarity:.4f} below {similarity_threshold:.4f} on page {page_index}',
+                    blocking=True,
+                    page_index=page_index,
+                )
+            )
+            page_passed = False
+        elif similarity < similarity_threshold + thresholds['slow_model_review_band']:
+            page_review_reasons.append(f'near_threshold_page_render_similarity:p{page_index}')
+
+        if layout_density_delta is not None and layout_density_delta > thresholds['layout_density_delta_max']:
+            vetoes.append(
+                _make_veto(
+                    code='layout_density_delta_above_threshold',
+                    scope='page',
+                    severity='p1',
+                    reason=f'layout density delta {layout_density_delta:.4f} above {thresholds["layout_density_delta_max"]:.4f} on page {page_index}',
+                    blocking=True,
+                    page_index=page_index,
+                )
+            )
+            page_passed = False
+        if text_coverage_delta is not None and text_coverage_delta > thresholds['text_coverage_delta_max']:
+            vetoes.append(
+                _make_veto(
+                    code='text_coverage_delta_above_threshold',
+                    scope='page',
+                    severity='p1',
+                    reason=f'text coverage delta {text_coverage_delta:.4f} above {thresholds["text_coverage_delta_max"]:.4f} on page {page_index}',
+                    blocking=True,
+                    page_index=page_index,
+                )
+            )
+            page_passed = False
+        if image_coverage_delta is not None and image_coverage_delta > thresholds['image_coverage_delta_max']:
+            vetoes.append(
+                _make_veto(
+                    code='image_coverage_delta_above_threshold',
+                    scope='page',
+                    severity='p1',
+                    reason=f'image coverage delta {image_coverage_delta:.4f} above {thresholds["image_coverage_delta_max"]:.4f} on page {page_index}',
+                    blocking=True,
+                    page_index=page_index,
+                )
+            )
+            page_passed = False
+
+        reports.append(
+            {
+                'page_index': page_index,
+                'subject_page_type': subject_page_type,
+                'page_role': page_role,
+                'pair_status': pair_status,
+                'page_render_similarity': similarity,
+                'layout_density_delta': layout_density_delta,
+                'text_coverage_delta': text_coverage_delta,
+                'image_coverage_delta': image_coverage_delta,
+                'thresholds': {
+                    'page_render_similarity_min': similarity_threshold,
+                    'layout_density_delta_max': thresholds['layout_density_delta_max'],
+                    'text_coverage_delta_max': thresholds['text_coverage_delta_max'],
+                    'image_coverage_delta_max': thresholds['image_coverage_delta_max'],
+                },
+                'passed': page_passed,
+                'review_required': bool(page_review_reasons),
+                'review_reasons': page_review_reasons,
+                'evidence': evidence,
+            }
+        )
+        review_reasons.extend(page_review_reasons)
+    return reports, vetoes, review_reasons, readiness_failures
+
+
+def _build_key_regions(
+    raw_regions: Sequence[object],
+    *,
+    thresholds: Mapping[str, float],
+    page_subject_by_index: Mapping[int, str],
+    default_subject_page_type: str,
+) -> tuple[list[dict[str, Any]], list[dict[str, Any]], list[str], list[str]]:
+    reports: list[dict[str, Any]] = []
+    vetoes: list[dict[str, Any]] = []
+    review_reasons: list[str] = []
+    readiness_failures: list[str] = []
+
+    for index, region in enumerate(raw_regions, start=1):
+        if not isinstance(region, Mapping):
+            continue
+        page_index = int(region.get('page_index') or 0)
+        region_id = str(region.get('region_id') or f'p{page_index}:r{index}').strip()
+        similarity = _optional_float(region.get('region_similarity'))
+        bbox_iou = _optional_float(region.get('bbox_iou'))
+        subject_page_type = _normalize_subject_page_type(
+            region.get('subject_page_type'),
+            fallback=page_subject_by_index.get(page_index, default_subject_page_type),
+        )
+        region_review_reasons: list[str] = []
+        region_passed = True
+        if page_index not in page_subject_by_index:
+            readiness_failures.append(f'key_region_without_page_score:{region_id}')
+            region_passed = False
+        if similarity is None or bbox_iou is None:
+            readiness_failures.append(f'key_region_metrics_incomplete:{region_id}')
+            region_passed = False
+        elif similarity < thresholds['key_region_similarity_min']:
+            vetoes.append(
+                _make_veto(
+                    code='key_region_similarity_below_threshold',
+                    scope='region',
+                    severity='p0',
+                    reason=f'key region similarity {similarity:.4f} below {thresholds["key_region_similarity_min"]:.4f} for {region_id}',
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=region_id,
+                )
+            )
+            region_passed = False
+        elif similarity < thresholds['key_region_similarity_min'] + thresholds['slow_model_review_band']:
+            region_review_reasons.append(f'near_threshold_region_similarity:{region_id}')
+
+        if bbox_iou is not None and bbox_iou < thresholds['bbox_iou_min']:
+            vetoes.append(
+                _make_veto(
+                    code='key_region_bbox_iou_below_threshold',
+                    scope='region',
+                    severity='p0',
+                    reason=f'bbox IoU {bbox_iou:.4f} below {thresholds["bbox_iou_min"]:.4f} for {region_id}',
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=region_id,
+                )
+            )
+            region_passed = False
+
+        reports.append(
+            {
+                'page_index': page_index,
+                'subject_page_type': subject_page_type,
+                'region_id': region_id,
+                'region_type': str(region.get('region_type') or 'unknown').strip(),
+                'required': bool(region.get('required', True)),
+                'bbox': dict(region.get('bbox') or {}),
+                'region_similarity': similarity,
+                'bbox_iou': bbox_iou,
+                'thresholds': {
+                    'region_similarity_min': thresholds['key_region_similarity_min'],
+                    'bbox_iou_min': thresholds['bbox_iou_min'],
+                },
+                'passed': region_passed,
+                'review_required': bool(region_review_reasons),
+                'review_reasons': region_review_reasons,
+                'evidence': {
+                    'source_crop_path': str(region.get('source_crop_path') or ''),
+                    'docx_crop_path': str(region.get('docx_crop_path') or ''),
+                    'diff_image_path': str(region.get('diff_image_path') or ''),
+                },
+            }
+        )
+        review_reasons.extend(region_review_reasons)
+    return reports, vetoes, review_reasons, readiness_failures
+
+
+def _build_page_evidence(pair: Mapping[str, Any], raw: Mapping[str, Any] | None) -> dict[str, str]:
+    source_pdf = pair.get('source_pdf') if isinstance(pair.get('source_pdf'), Mapping) else {}
+    output_docx = pair.get('output_docx') if isinstance(pair.get('output_docx'), Mapping) else {}
+    return {
+        'source_image_path': str(source_pdf.get('image_path') or ''),
+        'docx_image_path': str(output_docx.get('image_path') or ''),
+        'source_render_artifact': str(source_pdf.get('render_artifact') or ''),
+        'docx_render_artifact': str(output_docx.get('render_artifact') or ''),
+        'diff_image_path': str((raw or {}).get('diff_image_path') or ''),
+    }
+
+
+def _build_aggregate(
+    render_pairs: Sequence[object],
+    page_scores: Sequence[Mapping[str, Any]],
+    key_regions: Sequence[Mapping[str, Any]],
+    vetoes: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    similarity_values = [
+        float(page['page_render_similarity'])
+        for page in page_scores
+        if page.get('page_render_similarity') is not None
+    ]
+    return {
+        'render_pair_count': len(render_pairs),
+        'matched_render_pair_count': sum(
+            1 for pair in render_pairs if isinstance(pair, Mapping) and str(pair.get('pair_status') or '') == 'matched'
+        ),
+        'page_score_count': len(page_scores),
+        'key_region_count': len(key_regions),
+        'critical_page_count': sum(1 for page in page_scores if page.get('page_role') == 'critical'),
+        'human_review_page_count': sum(1 for page in page_scores if page.get('review_required')),
+        'human_review_region_count': sum(1 for region in key_regions if region.get('review_required')),
+        'overall_page_similarity_mean': _mean(similarity_values),
+        'veto_count': len(vetoes),
+        'blocking_veto_count': sum(1 for veto in vetoes if veto.get('blocking')),
+    }
+
+
+def _build_score_contract(
+    *,
+    gate_enabled: bool,
+    artifact_ready_for_scoring: bool,
+    blocking_vetoes: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    blocked = bool(blocking_vetoes)
+    if not gate_enabled:
+        skipped_score_reason = 'default_sync_excludes_visual_similarity_dimension'
+    elif not artifact_ready_for_scoring:
+        skipped_score_reason = 'visual_similarity_artifact_not_ready'
+    elif blocked:
+        skipped_score_reason = 'visual_similarity_veto_triggered'
+    else:
+        skipped_score_reason = None
+    return {
+        'dimension_key': VISUAL_SIMILARITY_DIMENSION_KEY,
+        'dimension_weight': VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+        'target_total_score_threshold': 95,
+        'enters_95_total_score': gate_enabled and artifact_ready_for_scoring,
+        'score_awarded_when_passed': VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+        'score_awarded': VISUAL_SIMILARITY_DIMENSION_WEIGHT if gate_enabled and artifact_ready_for_scoring and not blocked else 0,
+        'blocking_when_enabled': True,
+        'skipped_score_reason': skipped_score_reason,
+    }
+
+
+def _build_slow_model_policy(contract: Mapping[str, Any], *, enabled: bool) -> dict[str, Any]:
+    policy = contract.get('slow_model_policy') if isinstance(contract.get('slow_model_policy'), Mapping) else {}
+    return {
+        'enabled': enabled,
+        'rollout_enabled': bool(policy.get('rollout_enabled', True)),
+        'allowed_modes': list(policy.get('allowed_modes') or ['quality', 'hybrid_async']),
+        'disallowed_modes': list(policy.get('disallowed_modes') or ['fast', 'balanced', DEFAULT_SYNC_MODE]),
+        'candidate_models': list(policy.get('candidate_models') or [VISUAL_SIMILARITY_SLOW_REVIEW_MODEL]),
+        'max_review_pages': int(policy.get('max_review_pages') or 3),
+        'fallback_action': str(policy.get('fallback_action') or 'manual_review'),
+        'notes': str(policy.get('notes') or '').strip(),
+    }
+
+
+def _build_artifact_contract(contract: Mapping[str, Any]) -> dict[str, Any]:
+    artifact_contract = contract.get('artifact_contract')
+    payload = dict(artifact_contract) if isinstance(artifact_contract, Mapping) else {}
+    payload['required_fields'] = list(payload.get('required_fields') or ARTIFACT_REQUIRED_FIELDS)
+    payload['required_artifacts'] = list(
+        payload.get('required_artifacts') or ['visual_similarity.json', 'render_pair.json', 'slow_model_review.json']
+    )
+    return payload
+
+
+def _build_evidence_paths(
+    contract: Mapping[str, Any],
+    render_pair_artifact: Mapping[str, Any] | None,
+    render_pair_artifact_path: str | None,
+) -> dict[str, Any]:
+    contract_paths = contract.get('evidence_paths') if isinstance(contract.get('evidence_paths'), Mapping) else {}
+    render_pair_paths = render_pair_artifact.get('evidence_paths') if isinstance(render_pair_artifact, Mapping) and isinstance(render_pair_artifact.get('evidence_paths'), Mapping) else {}
+    return {
+        'render_pair_artifact_path': render_pair_artifact_path,
+        'render_pair_output_root': str(render_pair_paths.get('output_root') or ''),
+        'source_pdf_render_dir': str(render_pair_paths.get('source_pdf_render_dir') or ''),
+        'output_docx_render_dir': str(render_pair_paths.get('output_docx_render_dir') or ''),
+        'docx_converted_pdf_path': str(render_pair_paths.get('docx_converted_pdf_path') or ''),
+        **{str(key): value for key, value in contract_paths.items()},
+    }
+
+
+def _make_veto(
+    *,
+    code: str,
+    scope: str,
+    severity: str,
+    reason: str,
+    blocking: bool,
+    page_index: int | None = None,
+    region_id: str | None = None,
+    details: Sequence[str] | None = None,
+) -> dict[str, Any]:
+    return {
+        'code': code,
+        'scope': scope,
+        'severity': severity,
+        'blocking': blocking,
+        'page_index': page_index,
+        'region_id': region_id,
+        'reason': reason,
+        'details': list(details or []),
+    }
+
+
+def _normalize_subject_page_type(value: object, *, fallback: str) -> str:
+    normalized = str(value or '').strip()
+    return normalized if normalized in ALLOWED_SUBJECT_PAGE_TYPES else fallback
+
+
+def _normalize_mode(mode: str | None) -> str:
+    return str(mode or '').strip().lower()
+
+
+def _coerce_thresholds(payload: object) -> dict[str, float]:
+    thresholds = dict(DEFAULT_THRESHOLDS)
+    if isinstance(payload, Mapping):
+        for key in DEFAULT_THRESHOLDS:
+            if key in payload:
+                thresholds[key] = float(payload[key])
+    return thresholds
+
+
+def _optional_float(value: object) -> float | None:
+    if value is None or value == '':
+        return None
+    return float(value)
+
+
+def _mean(values: Sequence[float]) -> float | None:
+    if not values:
+        return None
+    return round(sum(values) / len(values), 4)
