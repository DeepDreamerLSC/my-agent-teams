+
+
+def test_english_visual_gate_marks_empty_top_level_pages_as_not_ready():
+    payload = copy.deepcopy(_load_fixture('english_reading_happy.json'))
+    payload['pages'] = []
+
+    summary = evaluate_english_visual_gate(payload)
+
+    assert summary['status'] == 'not_ready'
+    assert summary['human_review_required'] is True
+    assert summary['blockers']
+    assert summary['blockers'][0]['code'] == 'english_pages_empty'
+    assert summary['pages'] == []
+    assert not (
+        summary['status'] == 'ready'
+        and summary['human_review_required'] is False
+        and summary['blockers'] == []
+    )
