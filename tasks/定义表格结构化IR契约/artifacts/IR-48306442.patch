diff --git a/backend/tests/test_pdf_to_word_table_ir_contract.py b/backend/tests/test_pdf_to_word_table_ir_contract.py
new file mode 100644
index 0000000..9553711
--- /dev/null
+++ b/backend/tests/test_pdf_to_word_table_ir_contract.py
@@ -0,0 +1,148 @@
+from __future__ import annotations
+
+import copy
+import json
+from pathlib import Path
+
+import pytest
+
+from app.services.pdf_to_word.table_ir import (
+    NORMALIZED_TABLE_IR_VERSION,
+    REQUIRED_CELL_FIELDS,
+    REQUIRED_RAW_FIELDS,
+    REQUIRED_TABLE_IR_FIELDS,
+    NormalizedTableIR,
+    WARN_IMAGE_ONLY_FALLBACK,
+    WARN_TABLE_CELL_OVERLAP,
+    WARN_TABLE_DIMENSION_MISMATCH,
+    WARN_TABLE_SPAN_OUT_OF_BOUNDS,
+    WARN_TABLE_STRUCTURE_MISSING,
+    load_normalized_table_ir,
+    validate_normalized_table_ir,
+)
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "table_ir"
+
+
+def _load_payload(name: str) -> dict:
+    return json.loads((FIXTURE_DIR / name).read_text(encoding="utf-8"))
+
+
+def test_structured_fixture_freezes_required_fields_and_passes_contract():
+    payload = _load_payload("structured_table.json")
+
+    assert set(payload) == REQUIRED_TABLE_IR_FIELDS
+    assert payload["version"] == NORMALIZED_TABLE_IR_VERSION
+    assert set(payload["raw"]) == REQUIRED_RAW_FIELDS
+    for cell in payload["cells"]:
+        assert REQUIRED_CELL_FIELDS <= set(cell)
+        assert cell["runs"], "structured cell must preserve text runs"
+        for run in cell["runs"]:
+            assert set(run) == {"text", "style"}
+            assert {"bold", "italic", "underline", "font_name", "font_size", "color"} <= set(run["style"])
+
+    table = NormalizedTableIR.from_dict(payload)
+    report = validate_normalized_table_ir(table)
+
+    assert table.table_id == "table:p1:candidate-0007"
+    assert table.source_candidate_id == "mineru_full:p1:b7"
+    assert table.assigned_question_id == "q-2026-math-01"
+    assert table.assigned_region_id == "region:p1:q1"
+    assert table.inferred_dimensions() == (3, 3)
+    assert (report.inferred_row_count, report.inferred_column_count) == (table.row_count, table.column_count)
+    assert report.status == "pass"
+    assert report.passable is True
+    assert report.errors == ()
+    assert report.warnings == ()
+
+
+def test_span_semantics_use_zero_based_grid_and_cover_declared_slots():
+    table = load_normalized_table_ir(FIXTURE_DIR / "structured_table.json")
+
+    header = table.cells[0]
+    assert header.row_index == 0
+    assert header.column_index == 0
+    assert header.row_span == 1
+    assert header.column_span == 3
+    assert header.covered_slots() == ((0, 0), (0, 1), (0, 2))
+
+    covered_slots = {slot for cell in table.cells for slot in cell.covered_slots()}
+    assert covered_slots == {(row, column) for row in range(3) for column in range(3)}
+
+
+def test_image_only_fixture_is_review_only_and_never_counts_as_table_success():
+    table = load_normalized_table_ir(FIXTURE_DIR / "image_only_missing_structure.json")
+    report = validate_normalized_table_ir(table)
+
+    assert table.cells == ()
+    assert table.raw.image_path == "crops/page-2/table-like-image-0019.png"
+    assert table.raw.html is None
+    assert table.raw.markdown is None
+    assert report.has_structured_cells is False
+    assert report.status == "review"
+    assert report.passable is False
+    assert report.errors == ()
+    assert WARN_TABLE_STRUCTURE_MISSING in report.warnings
+    assert WARN_IMAGE_ONLY_FALLBACK in report.warnings
+
+
+def test_raw_html_or_markdown_alone_still_does_not_satisfy_structure_contract():
+    payload = _load_payload("image_only_missing_structure.json")
+    payload["raw"]["html"] = "<table><tr><td>untrusted raw only</td></tr></table>"
+    payload["raw"]["markdown"] = "| raw only |"
+    payload["warnings"] = []
+
+    table = NormalizedTableIR.from_dict(payload)
+    report = validate_normalized_table_ir(table)
+
+    assert report.status == "review"
+    assert report.passable is False
+    assert WARN_TABLE_STRUCTURE_MISSING in report.warnings
+    assert WARN_IMAGE_ONLY_FALLBACK not in report.warnings
+
+
+def test_validation_reports_span_overlap_and_out_of_bounds_as_contract_failure():
+    payload = _load_payload("structured_table.json")
+    payload["cells"] = copy.deepcopy(payload["cells"])
+    payload["cells"].append(
+        {
+            "row_index": 0,
+            "column_index": 2,
+            "row_span": 1,
+            "column_span": 2,
+            "text": "越界且重叠",
+            "runs": [
+                {
+                    "text": "越界且重叠",
+                    "style": {
+                        "bold": False,
+                        "italic": False,
+                        "underline": False,
+                        "font_name": "SimSun",
+                        "font_size": 10.5,
+                        "color": "000000",
+                    },
+                }
+            ],
+            "bbox": {"page": 1, "x0": 450.0, "y0": 220.0, "x1": 520.0, "y1": 246.0},
+            "confidence": 0.5,
+            "warnings": [],
+        }
+    )
+
+    table = NormalizedTableIR.from_dict(payload)
+    report = validate_normalized_table_ir(table)
+
+    assert report.status == "fail"
+    assert report.passable is False
+    assert any(WARN_TABLE_SPAN_OUT_OF_BOUNDS in error for error in report.errors)
+    assert any(WARN_TABLE_CELL_OVERLAP in error for error in report.errors)
+    assert WARN_TABLE_DIMENSION_MISMATCH in report.warnings
+
+
+def test_missing_required_contract_fields_fail_fast():
+    payload = _load_payload("structured_table.json")
+    payload.pop("source_candidate_id")
+
+    with pytest.raises(ValueError, match="source_candidate_id"):
+        NormalizedTableIR.from_dict(payload)

