+        f"- Engineering gate: `{engineering_gate.get('status')}` / gate_passed=`{str(engineering_gate.get('gate_passed')).lower()}`",
+        f"- Human visual gate: `{human_visual_status_display}`",
+        '',
+        '## Boundary',
+        '',
+        '- Engineering PASS does **not** upgrade to human visual 95 PASS automatically.',
+        '- Missing canonical artifacts, missing Chinese positive sample, or manifest mismatch must produce explicit NO-GO.',
+        '',
+        '## Blocking Failures',
+        '',
+    ]
+    for item in summary.get('blocking_failures') or []:
+        lines.append(f"- `{item.get('code')}`: {item.get('evidence')}")
+        for detail in item.get('details') or []:
+            lines.append(f"  - {detail}")
+    if not (summary.get('blocking_failures') or []):
+        lines.append('- none')
+    lines.extend(['', '## Samples', '', '| Sample | Subject | Role | Engineering | Human Visual | Manifest Gate | render_pair | visual_similarity | fidelity_veto | human_review |', '| --- | --- | --- | --- | --- | --- | --- | --- | --- | --- |'])
