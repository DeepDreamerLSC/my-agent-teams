+def _normalize_acceptance_manifest_index(samples_payload: Any) -> dict[str, dict[str, Any]]:
+    if not isinstance(samples_payload, list):
+        return {}
+    result: dict[str, dict[str, Any]] = {}
+    for item in samples_payload:
+        if not isinstance(item, dict):
+            continue
+        sample_key = str(item.get('sample_key') or '').strip()
+        if not sample_key:
+            continue
+        result[sample_key] = dict(item)
+    return result
+
