+def _build_acceptance_subject_coverage(sample_rows: list[dict[str, Any]]) -> list[dict[str, Any]]:
+    subject_map: dict[str, dict[str, Any]] = {}
+    for row in sample_rows:
+        subject = str(row.get('subject') or '').strip() or 'unknown'
+        item = subject_map.setdefault(subject, {
+            'subject': subject,
+            'sample_count': 0,
+            'positive_candidate_count': 0,
+            'negative_guard_count': 0,
+            'human_visual_pass_count': 0,
+            'human_visual_no_go_count': 0,
+            'artifact_not_ready_count': 0,
+            'sample_keys': [],
+        })
+        item['sample_count'] += 1
+        item['sample_keys'].append(row['sample_key'])
+        if row['evaluation_role'] == 'positive_candidate' and row['eligible_for_human_visual_95']:
+            item['positive_candidate_count'] += 1
+        if row['evaluation_role'] == 'negative_guard':
+            item['negative_guard_count'] += 1
+        if row['current_human_visual_status'] == 'human_visual_pass':
+            item['human_visual_pass_count'] += 1
+        if row['current_human_visual_status'] == 'human_visual_no_go':
+            item['human_visual_no_go_count'] += 1
+        if row['current_human_visual_status'] == 'canonical_artifact_chain_not_ready':
+            item['artifact_not_ready_count'] += 1
+    return [subject_map[key] for key in sorted(subject_map)]
