+        '',
+        f"- **工程门禁**：`{(report.get('engineering_gate') or {}).get('status')}`",
+        f"- **全学科人工视觉95**：`{human_visual_status_display}`",
+        '- **重点口径**：工程门禁 PASS 与 human visual 95 PASS 强隔离；缺真实视觉证据或任一样例 NO-GO 时，FinalAcceptance 也必须 NO-GO。',
+        '',
+        '## 2. 当前样例与门禁状态',
+        '',
+        '| Sample | Subject | Role | Human Visual Status | Gate Status | Blockers |',
+        '| --- | --- | --- | --- | --- | --- |',
+    ]
+    for row in report.get('subject_coverage') or []:
