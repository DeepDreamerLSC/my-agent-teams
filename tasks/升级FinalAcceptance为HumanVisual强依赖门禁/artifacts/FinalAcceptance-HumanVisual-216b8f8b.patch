+def _compare_acceptance_manifest_samples(
+    sample_key: str,
+    lhs_name: str,
+    lhs_sample: dict[str, Any],
+    rhs_name: str,
+    rhs_sample: dict[str, Any],
+    *,
+    include_average_flag: bool,
+) -> list[dict[str, Any]]:
+    lhs_snapshot = _acceptance_manifest_field_snapshot(lhs_sample, include_average_flag=include_average_flag)
+    rhs_snapshot = _acceptance_manifest_field_snapshot(rhs_sample, include_average_flag=include_average_flag)
+    mismatches: list[dict[str, Any]] = []
+    for field_name in sorted(set(lhs_snapshot) | set(rhs_snapshot)):
+        if lhs_snapshot.get(field_name) == rhs_snapshot.get(field_name):
+            continue
+        mismatches.append({
+            'sample_key': sample_key,
+            'lhs_manifest': lhs_name,
+            'rhs_manifest': rhs_name,
+            'field': field_name,
+            'lhs_value': lhs_snapshot.get(field_name),
+            'rhs_value': rhs_snapshot.get(field_name),
+        })
+    return mismatches
