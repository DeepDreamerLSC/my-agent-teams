+def _selected_pages_from_acceptance_manifest(sample: dict[str, Any]) -> list[int]:
+    raw_pages = sample.get('selected_pages_or_crops')
+    if raw_pages is None and isinstance(sample.get('fallback_policy'), dict):
+        raw_pages = sample['fallback_policy'].get('selected_pages_or_crops')
+    if raw_pages is None and isinstance(sample.get('current_facts'), dict):
+        raw_pages = sample['current_facts'].get('selected_pages_or_crops')
+    result: list[int] = []
+    for value in raw_pages or []:
+        try:
+            result.append(int(value))
+        except (TypeError, ValueError):
+            continue
+    return result
+
