+        artifact_presence = row.get('artifact_presence') or {}
+        lines.append(
+            f"| `{row.get('sample_key')}` | `{row.get('subject')}` | `{row.get('evaluation_role')}` | `{row.get('engineering_gate_status')}` | `{row.get('current_human_visual_status')}` | `{row.get('manifest_gate_status')}` | `{artifact_presence.get('render_pair_status')}` | `{artifact_presence.get('visual_similarity_status')}` | `{artifact_presence.get('fidelity_veto_status')}` | `{artifact_presence.get('human_review_decision')}` |"
