+        lines.append(
+            f"| `{row.get('sample_key')}` | `{row.get('subject')}` | `{row.get('evaluation_role')}` | `{row.get('current_human_visual_status')}` | `{row.get('manifest_gate_status')}` | {blockers} |"
+        )
+    lines.extend(['', '## 3. Blocking Failures', ''])
+    for item in report.get('blocking_failures') or []:
+        lines.append(f"- `{item.get('code')}`：{item.get('evidence')}")
+        for detail in item.get('details') or []:
+            lines.append(f"  - {detail}")
+    if not (report.get('blocking_failures') or []):
