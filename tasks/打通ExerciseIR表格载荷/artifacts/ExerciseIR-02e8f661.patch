+                cells.append(str(cell.get('text') or cell.get('content') or '').strip())
+            else:
+                cells.append(str(cell or '').strip())
+        normalized_rows.append(' '.join(cell for cell in cells if cell))
+    return '\n'.join(row for row in normalized_rows if row)
