+def _flatten_table_rows_text(value: object) -> str:
+    if not isinstance(value, list):
+        return ''
+    normalized_rows: list[str] = []
+    for row in value:
+        if not isinstance(row, list):
+            return ''
+        cells: list[str] = []
+        for cell in row:
