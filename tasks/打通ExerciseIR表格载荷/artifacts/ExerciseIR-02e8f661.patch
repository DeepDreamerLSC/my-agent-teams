     return payload
 
 
+def _coerce_normalized_table_ir(value: Any) -> tuple[NormalizedTableIR | None, Any | None, list[str]]:
+    if not isinstance(value, dict):
+        return None, None, []
+    try:
+        table_ir = NormalizedTableIR.from_dict(value)
+    except Exception:
+        return None, None, ["table_ir_invalid"]
+    return table_ir, validate_normalized_table_ir(table_ir), []
+
+
+def _table_rows_from_ir(table_ir: NormalizedTableIR) -> list[list[str]] | None:
+    if table_ir.row_count <= 0 or table_ir.column_count <= 0:
+        return None
+    rows = [["" for _ in range(table_ir.column_count)] for _ in range(table_ir.row_count)]
+    for cell in table_ir.cells:
+        if 0 <= cell.row_index < table_ir.row_count and 0 <= cell.column_index < table_ir.column_count:
+            rows[cell.row_index][cell.column_index] = cell.text
+    return rows
+
+
+def _table_reason_from_report(report: Any) -> str:
+    if report.status == "pass":
+        return "ok"
+    if WARN_TABLE_STRUCTURE_MISSING in report.warnings:
+        return WARN_TABLE_STRUCTURE_MISSING
+    if report.errors or WARN_TABLE_DIMENSION_MISMATCH in report.warnings or WARN_TABLE_GRID_INCOMPLETE in report.warnings:
+        return "table_grid_inconsistent"
+    return "table_review_required"
+
+
+def _normalize_warning_values(value: Any) -> list[str]:
+    if not isinstance(value, list):
+        return []
+    return [str(item) for item in value if str(item)]
+
+
+def _has_table_structure(payload: dict[str, Any]) -> bool:
+    return bool(payload.get("table_ir") or payload.get("table_html") or payload.get("table_rows"))
+
+
+def _coerce_optional_float(value: Any) -> float | None:
+    try:
+        if value in (None, ""):
+            return None
+        return float(value)
+    except Exception:
+        return None
+
+
 def _bbox_to_dict(bbox: PageBox | None) -> dict[str, Any] | None:
     if bbox is None:
         return None
