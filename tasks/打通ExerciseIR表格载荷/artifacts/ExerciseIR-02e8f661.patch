+def _flatten_table_ir_text(value: object) -> str:
+    if not isinstance(value, dict):
+        return ''
+    cells = value.get('cells')
+    row_count = int(value.get('row_count') or 0)
+    column_count = int(value.get('column_count') or 0)
+    if not isinstance(cells, list) or row_count <= 0 or column_count <= 0:
+        return ''
+    grid = [["" for _ in range(column_count)] for _ in range(row_count)]
+    for cell in cells:
+        if not isinstance(cell, dict):
+            continue
+        try:
+            row_index = int(cell.get('row_index') or 0)
+            column_index = int(cell.get('column_index') or 0)
+        except Exception:
+            continue
+        if 0 <= row_index < row_count and 0 <= column_index < column_count:
+            grid[row_index][column_index] = str(cell.get('text') or '').strip()
+    return '\n'.join(' '.join(item for item in row if item) for row in grid if any(item for item in row))
+
