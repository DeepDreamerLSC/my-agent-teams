+def _coerce_fidelity_score(value: Any) -> float | None:
+    try:
+        numeric = float(value)
+    except (TypeError, ValueError):
+        return None
+    if numeric < 0:
+        numeric = 0.0
+    return round(numeric, 4)
+
+
+def _coerce_fidelity_notes(value: Any) -> list[str]:
+    if isinstance(value, list):
+        return [str(item) for item in value if str(item).strip()]
+    if isinstance(value, str) and value.strip():
+        return [value.strip()]
+    return []
+
+
+def _resolve_fidelity_dimension_threshold(*, weight: float | None, threshold: float) -> float:
+    normalized_threshold = max(0.0, float(threshold))
+    if weight is None or float(weight) <= 0:
+        return round(normalized_threshold, 4)
+    return round(float(weight) * normalized_threshold / 100.0, 4)
+
+
+def _normalize_fidelity_weights_payload(payload: dict[str, Any]) -> dict[str, float]:
+    weights: dict[str, float] = {}
+    for raw_name, raw_value in payload.items():
+        name = str(raw_name).strip()
+        if not name:
+            continue
+        normalized_name = 'tables' if name in FIDELITY_TABLE_DIMENSION_ALIASES else name
+        try:
+            weights[normalized_name] = round(float(raw_value), 4)
+        except (TypeError, ValueError):
+            continue
+    return weights
+
+
+def _normalize_fidelity_dimensions_payload(payload: dict[str, Any]) -> dict[str, dict[str, Any]]:
+    dimensions: dict[str, dict[str, Any]] = {}
+    for raw_name, raw_value in payload.items():
+        name = str(raw_name).strip()
+        if not name or not isinstance(raw_value, dict):
+            continue
+        normalized_name = 'tables' if name in FIDELITY_TABLE_DIMENSION_ALIASES else name
+        merged_payload = dict(dimensions.get(normalized_name) or {})
+        merged_payload.update(raw_value)
+        dimensions[normalized_name] = merged_payload
+    return dimensions
+
+
+def _normalize_fidelity_tables(payload: dict[str, Any], *, threshold: float, weight: float | None) -> tuple[dict[str, Any], list[str]]:
+    score = _coerce_fidelity_score(payload.get('score'))
+    implemented = _coerce_bool(payload.get('implemented', score is not None))
+    notes = _coerce_fidelity_notes(payload.get('notes') or payload.get('warnings'))
+    detected_table_sample_count = int(payload.get('detected_table_sample_count') or 0)
+    sample_with_table_xml_count = int(payload.get('sample_with_table_xml_count') or 0)
+    image_fallback_table_count = int(payload.get('image_fallback_table_count') or payload.get('table_fallback_count') or 0)
+    raw_has_table_xml = payload.get('has_table_xml') if 'has_table_xml' in payload else payload.get('table_xml_present')
+    has_table_xml = _coerce_bool(raw_has_table_xml)
+    if not has_table_xml and sample_with_table_xml_count > 0:
+        has_table_xml = True
+    if score is None and implemented:
+        score = 0.0
+    dimension_threshold = _resolve_fidelity_dimension_threshold(weight=weight, threshold=threshold)
+    hard_gate_passed = (
+        implemented
+        and (
+            detected_table_sample_count <= 0
+            or (
+                has_table_xml
+                and sample_with_table_xml_count >= detected_table_sample_count
+                and image_fallback_table_count == 0
+            )
+        )
+    )
+    if not implemented:
+        status = 'missing'
+    elif not hard_gate_passed:
+        status = 'fail'
+    elif score is not None and score >= dimension_threshold:
+        status = 'pass'
+    else:
+        status = 'review'
+    blockers: list[str] = []
+    if not implemented:
+        blockers.append('dimension_missing:tables')
+    elif detected_table_sample_count > 0 and sample_with_table_xml_count < detected_table_sample_count:
+        blockers.append('table_gate_failed:detected_without_word_table_xml')
+    if image_fallback_table_count > 0:
+        blockers.append('table_gate_failed:image_fallback_present')
+    return (
+        {
+            'implemented': implemented,
+            'status': status,
+            'score': score,
+            'has_table_xml': has_table_xml,
+            'detected_table_sample_count': detected_table_sample_count,
+            'sample_with_table_xml_count': sample_with_table_xml_count,
+            'image_fallback_table_count': image_fallback_table_count,
+            'hard_gate_passed': hard_gate_passed,
+            'notes': notes,
+        },
+        blockers,
+    )
+
+
+def _resolve_input_relative_path(base_path: Path, value: Any) -> Path | None:
+    text = _coerce_str_path(value)
+    if not text:
+        return None
+    path = Path(text).expanduser()
+    if not path.is_absolute():
+        path = base_path.parent / path
+    return path.resolve()
+
