+def build_visual_similarity_gate_report(
+    contract: Mapping[str, Any],
+    *,
+    requested_mode: str | None = None,
+    parser_backend: str | None = None,
+) -> dict[str, Any]:
+    """Build the final visual-similarity gate contract report.
+
+    This function intentionally consumes precomputed/fixture facts only. It does
+    not render PDF/DOCX pages, call VLMs, or mutate the default synchronous PDF
+    to Word path. Downstream implementation can replace the fixture inputs with
+    real render-pair metrics while preserving this artifact shape.
+    """
+
+    _validate_contract(contract)
+    thresholds = _coerce_thresholds(contract.get('thresholds'))
+    gate_mode = resolve_visual_gate_mode(requested_mode, parser_backend=parser_backend)
+    gate_enabled = gate_mode == QUALITY_HYBRID_ASYNC_MODE
+    implementation_status = str(
+        contract.get('implementation_status') or 'contract_only_no_renderer_or_slow_model_invoked'
+    ).strip() or 'contract_only_no_renderer_or_slow_model_invoked'
+    samples = _build_sample_reports(contract.get('samples') or [], thresholds=thresholds, enabled=gate_enabled)
+    aggregate = _build_aggregate(samples)
+    slow_model_policy = _build_slow_model_policy(contract, enabled=gate_enabled)
+    blocking_failures = _collect_blocking_failures(samples, enabled=gate_enabled)
+    score_contract = _build_score_contract(samples, enabled=gate_enabled)
+
+    return {
+        'report_type': VISUAL_SIMILARITY_REPORT_TYPE,
+        'contract_version': str(contract.get('contract_version') or VISUAL_SIMILARITY_GATE_VERSION),
+        'implementation_status': implementation_status,
+        'mode_boundary': {
+            'requested_mode': _normalize_mode(requested_mode),
+            'parser_backend': str(parser_backend or '').strip() or None,
+            'resolved_gate_mode': gate_mode,
+            'enabled': gate_enabled,
+            'default_sync_safe': True,
+            'default_sync_invokes_render_or_slow_model': False,
+            'default_sync_policy': _source_policy(contract).get(
+                'default_sync_policy',
+                'apple default + hybrid_experimental quality gray + formula audit-only / merge-disabled',
+            ),
+            'reason': (
+                'visual similarity participates in final scoring only in quality/hybrid_async'
+                if gate_enabled
+                else 'default synchronous modes skip render diff and slow-model review'
+            ),
+        },
+        'score_contract': score_contract,
+        'thresholds': thresholds,
+        'artifact_contract': _build_artifact_contract(contract),
+        'slow_model_policy': slow_model_policy,
+        'aggregate': aggregate,
+        'gate_passed': not blocking_failures,
+        'blocking_failures': blocking_failures,
+        'samples': samples,
+        'known_gaps': list(contract.get('known_gaps') or []),
+        'downstream_required_work': list(contract.get('downstream_required_work') or []),
+    }
+
+
+def resolve_visual_gate_mode(requested_mode: str | None, *, parser_backend: str | None = None) -> str:
+    mode = _normalize_mode(requested_mode)
+    backend = str(parser_backend or '').strip().lower()
+    if mode in QUALITY_GATE_MODES:
+        return QUALITY_HYBRID_ASYNC_MODE
+    if backend == 'hybrid_experimental' and mode == 'quality':
+        return QUALITY_HYBRID_ASYNC_MODE
+    if mode in DEFAULT_SYNC_MODES:
+        return DEFAULT_SYNC_MODE
+    return DEFAULT_SYNC_MODE
+
+
+def write_visual_similarity_gate_artifact(report: Mapping[str, Any], output_path: str | Path) -> Path:
+    path = Path(output_path).expanduser().resolve()
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return path
+
+
+def _validate_contract(contract: Mapping[str, Any]) -> None:
+    required = {
+        'contract_version',
+        'source_policy',
+        'thresholds',
+        'slow_model_policy',
+        'artifact_contract',
+        'samples',
+    }
+    missing = sorted(required - set(contract))
+    if missing:
+        raise VisualSimilarityGateError(f'missing visual similarity contract fields: {missing}')
+    if str(contract.get('contract_version') or '') != VISUAL_SIMILARITY_GATE_VERSION:
+        raise VisualSimilarityGateError('unsupported visual similarity contract_version')
+    source_policy = _source_policy(contract)
+    if int(source_policy.get('visual_similarity_weight') or 0) != VISUAL_SIMILARITY_DIMENSION_WEIGHT:
+        raise VisualSimilarityGateError('visual_similarity_weight must remain 17 in the 95-point route')
+    if 'quality/hybrid_async' not in str(source_policy.get('quality_target_scope') or ''):
+        raise VisualSimilarityGateError('quality_target_scope must mention quality/hybrid_async')
+    slow_model_policy = contract.get('slow_model_policy')
+    if not isinstance(slow_model_policy, Mapping):
+        raise VisualSimilarityGateError('slow_model_policy must be an object')
+    disallowed = {str(item).strip() for item in slow_model_policy.get('disallowed_modes') or []}
+    if not {'fast', 'balanced', DEFAULT_SYNC_MODE}.issubset(disallowed):
+        raise VisualSimilarityGateError('slow_model_policy must explicitly block default sync modes')
+    active_candidates = [str(item).strip() for item in slow_model_policy.get('candidate_models') or []]
+    if active_candidates != ['qwen3_vl_8b']:
+        raise VisualSimilarityGateError('active slow-model candidate_models must be exactly [qwen3_vl_8b]')
+    artifact_contract = contract.get('artifact_contract')
+    if not isinstance(artifact_contract, Mapping):
+        raise VisualSimilarityGateError('artifact_contract must be an object')
+    required_artifacts = {str(item).strip() for item in artifact_contract.get('required_artifacts') or []}
+    if 'visual_similarity.json' not in required_artifacts:
+        raise VisualSimilarityGateError('required artifact must include canonical visual_similarity.json')
+    if 'visual_similarity_report.json' in required_artifacts:
+        raise VisualSimilarityGateError('visual_similarity_report.json may only be optional/debug, not required')
+
+
+def _source_policy(contract: Mapping[str, Any]) -> Mapping[str, Any]:
+    policy = contract.get('source_policy')
+    return policy if isinstance(policy, Mapping) else {}
+
+
+def _coerce_thresholds(payload: object) -> dict[str, float]:
+    thresholds = dict(DEFAULT_THRESHOLDS)
+    if isinstance(payload, Mapping):
+        for key in DEFAULT_THRESHOLDS:
+            if key in payload:
+                thresholds[key] = float(payload[key])
+    return thresholds
+
+
+def _build_sample_reports(
+    samples: Sequence[object],
+    *,
+    thresholds: Mapping[str, float],
+    enabled: bool,
+) -> list[dict[str, Any]]:
+    reports: list[dict[str, Any]] = []
+    for sample in samples:
+        if not isinstance(sample, Mapping):
+            continue
+        pages = _build_page_reports(sample.get('pages') or [], thresholds=thresholds, enabled=enabled)
+        key_region_count = sum(len(page['key_regions']) for page in pages)
+        render_pair_missing = sum(1 for page in pages if not page['render_pair_available'])
+        blocking_failures = [failure for page in pages for failure in page['blocking_failures']]
+        slow_model_trigger_count = sum(
+            len(page['slow_model_triggers'])
+            + sum(len(region['slow_model_triggers']) for region in page['key_regions'])
+            for page in pages
+        )
+        reports.append(
+            {
+                'sample_key': str(sample.get('sample_key') or '').strip(),
+                'sample_name': str(sample.get('sample_name') or '').strip(),
+                'sample_role': str(sample.get('sample_role') or '').strip(),
+                'page_type': str(sample.get('page_type') or '').strip(),
+                'source_profile': dict(sample.get('source_profile') or {}),
+                'selected_pages': list(sample.get('selected_pages') or []),
+                'pages': pages,
+                'page_count': len(pages),
+                'key_region_count': key_region_count,
+                'render_pair_missing_count': render_pair_missing,
+                'slow_model_candidate_region_count': slow_model_trigger_count,
+                'blocking_failures': blocking_failures if enabled else [],
+                'ok': not blocking_failures if enabled else True,
+                'scoring_status': 'scored' if enabled else 'skipped_default_sync',
+            }
+        )
+    return reports
+
+
+def _build_page_reports(
+    pages: Sequence[object],
+    *,
+    thresholds: Mapping[str, float],
+    enabled: bool,
+) -> list[dict[str, Any]]:
+    reports: list[dict[str, Any]] = []
+    for page in pages:
+        if not isinstance(page, Mapping):
+            continue
+        page_index = int(page.get('page_index') or 0)
+        render_pair_available = str(page.get('render_pair_status') or '').strip() == 'available'
+        similarity = _optional_float(page.get('page_render_similarity'))
+        density_delta = _optional_float(page.get('layout_density_delta'))
+        order_delta = _optional_float(page.get('paragraph_order_delta'))
+        key_regions = _build_region_reports(
+            page.get('key_regions') or [],
+            page_index=page_index,
+            thresholds=thresholds,
+            enabled=enabled,
+        )
+        blocking_failures: list[str] = []
+        if enabled and not render_pair_available:
+            blocking_failures.append(f'visual_similarity_missing_render_pair:p{page_index}')
+        if enabled and similarity is not None and similarity < thresholds['page_render_similarity_min']:
+            blocking_failures.append(f'page_render_similarity_below_threshold:p{page_index}')
+        if enabled and density_delta is not None and density_delta > thresholds['layout_density_delta_max']:
+            blocking_failures.append(f'layout_density_delta_above_threshold:p{page_index}')
+        if enabled and order_delta is not None and order_delta > thresholds['paragraph_order_delta_max']:
+            blocking_failures.append(f'paragraph_order_delta_above_threshold:p{page_index}')
+        blocking_failures.extend(
+            failure for region in key_regions for failure in region['blocking_failures']
+        )
+        slow_model_triggers = _page_slow_model_triggers(
+            similarity=similarity,
+            density_delta=density_delta,
+            thresholds=thresholds,
+            enabled=enabled,
+        )
+        reports.append(
+            {
+                'page_index': page_index,
+                'render_pair_available': render_pair_available,
+                'source_render_path': str(page.get('source_render_path') or ''),
+                'docx_render_path': str(page.get('docx_render_path') or ''),
+                'page_render_similarity': similarity,
+                'layout_density_delta': density_delta,
+                'paragraph_order_delta': order_delta,
+                'key_regions': key_regions,
+                'slow_model_triggers': slow_model_triggers,
+                'blocking_failures': blocking_failures,
+                'ok': not blocking_failures if enabled else True,
+            }
+        )
+    return reports
+
+
+def _build_region_reports(
+    regions: Sequence[object],
+    *,
+    page_index: int,
+    thresholds: Mapping[str, float],
+    enabled: bool,
+) -> list[dict[str, Any]]:
+    reports: list[dict[str, Any]] = []
+    for index, region in enumerate(regions, start=1):
+        if not isinstance(region, Mapping):
+            continue
+        region_id = str(region.get('region_id') or f'p{page_index}:r{index}').strip()
+        similarity = _optional_float(region.get('region_similarity'))
+        bbox_iou = _optional_float(region.get('bbox_iou'))
+        blocking_failures: list[str] = []
+        if enabled and similarity is not None and similarity < thresholds['key_region_similarity_min']:
+            blocking_failures.append(f'key_region_similarity_below_threshold:{region_id}')
+        if enabled and bbox_iou is not None and bbox_iou < thresholds['bbox_iou_min']:
+            blocking_failures.append(f'bbox_iou_below_threshold:{region_id}')
+        reports.append(
+            {
+                'region_id': region_id,
+                'region_type': str(region.get('region_type') or 'unknown').strip(),
+                'required': bool(region.get('required', True)),
+                'bbox': dict(region.get('bbox') or {}),
+                'region_similarity': similarity,
+                'bbox_iou': bbox_iou,
+                'slow_model_triggers': _region_slow_model_triggers(
+                    similarity=similarity,
+                    bbox_iou=bbox_iou,
+                    thresholds=thresholds,
+                    enabled=enabled,
+                ),
+                'blocking_failures': blocking_failures,
+                'ok': not blocking_failures if enabled else True,
+            }
+        )
+    return reports
+
+
+def _page_slow_model_triggers(
+    *,
+    similarity: float | None,
+    density_delta: float | None,
+    thresholds: Mapping[str, float],
+    enabled: bool,
+) -> list[str]:
+    if not enabled:
+        return []
+    triggers: list[str] = []
+    review_band = thresholds['slow_model_review_band']
+    if similarity is not None and similarity < thresholds['page_render_similarity_min'] + review_band:
+        triggers.append('near_threshold_page_render_similarity')
+    if density_delta is not None and density_delta > thresholds['layout_density_delta_max']:
+        triggers.append('layout_density_delta_outlier')
+    return triggers
+
+
+def _region_slow_model_triggers(
+    *,
+    similarity: float | None,
+    bbox_iou: float | None,
+    thresholds: Mapping[str, float],
+    enabled: bool,
+) -> list[str]:
+    if not enabled:
+        return []
+    triggers: list[str] = []
+    if similarity is not None and similarity < thresholds['key_region_similarity_min']:
+        triggers.append('key_region_below_threshold')
+    if bbox_iou is not None and bbox_iou < thresholds['bbox_iou_min']:
+        triggers.append('bbox_iou_regression')
+    return triggers
+
+
+def _build_aggregate(samples: Sequence[Mapping[str, Any]]) -> dict[str, int]:
+    page_count = sum(int(sample.get('page_count') or 0) for sample in samples)
+    region_count = sum(int(sample.get('key_region_count') or 0) for sample in samples)
+    return {
+        'sample_count': len(samples),
+        'page_count': page_count,
+        'key_region_count': region_count,
+        'render_pair_ready_page_count': sum(
+            1 for sample in samples for page in sample.get('pages', []) if page.get('render_pair_available')
+        ),
+        'missing_render_pair_page_count': sum(
+            int(sample.get('render_pair_missing_count') or 0) for sample in samples
+        ),
+        'slow_model_candidate_region_count': sum(
+            int(sample.get('slow_model_candidate_region_count') or 0) for sample in samples
+        ),
+        'sample_pass_count': sum(1 for sample in samples if sample.get('ok')),
+    }
+
+
+def _build_score_contract(samples: Sequence[Mapping[str, Any]], *, enabled: bool) -> dict[str, Any]:
+    failed_samples = sum(1 for sample in samples if not sample.get('ok'))
+    score_awarded = VISUAL_SIMILARITY_DIMENSION_WEIGHT if enabled and failed_samples == 0 else 0
+    return {
+        'dimension_key': VISUAL_SIMILARITY_DIMENSION_KEY,
+        'dimension_weight': VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+        'target_total_score_threshold': 95,
+        'enters_95_total_score': enabled,
+        'score_awarded_when_passed': VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+        'score_awarded': score_awarded,
+        'blocking_when_enabled': True,
+        'skipped_score_reason': None if enabled else 'default_sync_excludes_visual_similarity_dimension',
+    }
+
+
+def _build_slow_model_policy(contract: Mapping[str, Any], *, enabled: bool) -> dict[str, Any]:
+    policy = contract.get('slow_model_policy') if isinstance(contract.get('slow_model_policy'), Mapping) else {}
+    candidate_models = list(policy.get('candidate_models') or [])
+    return {
+        'enabled': enabled,
+        'allowed_modes': list(policy.get('allowed_modes') or ['quality', 'hybrid_async']),
+        'disallowed_modes': list(policy.get('disallowed_modes') or ['fast', 'balanced', DEFAULT_SYNC_MODE]),
+        'candidate_models': candidate_models,
+        'future_review_candidates': list(policy.get('future_review_candidates') or []),
+        'blocked_candidates': list(policy.get('blocked_candidates') or []),
+        'comparison_only_models': list(policy.get('comparison_only_models') or []),
+        'trigger_policy': str(policy.get('trigger_policy') or 'selective_only').strip(),
+        'triggers': list(policy.get('triggers') or SLOW_MODEL_TRIGGER_KEYS),
+        'max_review_regions_per_sample': int(policy.get('max_review_regions_per_sample') or 3),
+        'must_not_block_default_sync': True,
+        'notes': str(policy.get('notes') or '').strip(),
+    }
+
+
+def _build_artifact_contract(contract: Mapping[str, Any]) -> dict[str, Any]:
+    artifact_contract = contract.get('artifact_contract')
+    payload = dict(artifact_contract) if isinstance(artifact_contract, Mapping) else {}
+    required = list(payload.get('required_artifacts') or ARTIFACT_REQUIRED_KEYS)
+    payload['required_artifacts'] = required
+    payload['required_fields'] = list(
+        payload.get('required_fields')
+        or [
+            'contract_version',
+            'mode_boundary',
+            'score_contract',
+            'thresholds',
+            'aggregate',
+            'samples',
+            'blocking_failures',
+            'slow_model_policy',
+        ]
+    )
+    return payload
+
+
+def _collect_blocking_failures(samples: Sequence[Mapping[str, Any]], *, enabled: bool) -> list[str]:
+    if not enabled:
+        return []
+    failures: list[str] = []
+    for sample in samples:
+        sample_key = str(sample.get('sample_key') or 'unknown')
+        for failure in sample.get('blocking_failures') or []:
+            failures.append(f'{sample_key}:{failure}')
+    return failures
+
+
+def _normalize_mode(mode: str | None) -> str:
+    return str(mode or '').strip().lower()
+
+
+def _optional_float(value: object) -> float | None:
+    if value is None or value == '':
+        return None
+    return float(value)
