+def _normalize_visual_similarity_from_artifact(
+    artifact_path: Path,
+    *,
+    threshold: float,
+    weight: float | None,
+    existing_notes: list[str] | None = None,
+) -> tuple[dict[str, Any], list[str]]:
+    blockers: list[str] = []
+    notes = list(existing_notes or [])
+    if not artifact_path.exists():
+        blockers.append('visual_similarity_artifact_missing')
+        return (
+            {
+                'implemented': False,
+                'status': 'missing',
+                'score': None,
+                'weight': round(float(weight or 0.0), 4),
+                'weighted_score': 0.0,
+                'notes': notes,
+                'artifact_path': str(artifact_path),
+            },
+            blockers,
+        )
+
+    artifact = _read_json(artifact_path)
+    if str(artifact.get('report_type') or '').strip() != VISUAL_SIMILARITY_REPORT_TYPE:
+        blockers.append('visual_similarity_artifact_invalid')
+        return (
+            {
+                'implemented': False,
+                'status': 'missing',
+                'score': None,
+                'weight': round(float(weight or 0.0), 4),
+                'weighted_score': 0.0,
+                'notes': notes + [f'invalid report_type: {artifact.get("report_type")}'],
+                'artifact_path': str(artifact_path),
+            },
+            blockers,
+        )
+
+    implementation_status = str(artifact.get('implementation_status') or '').strip() or VISUAL_SIMILARITY_CONTRACT_ONLY_STATUS
+    gate_passed = _coerce_bool(artifact.get('gate_passed'))
+    score_contract = artifact.get('score_contract') if isinstance(artifact.get('score_contract'), dict) else {}
+    score = _coerce_fidelity_score(score_contract.get('score_awarded'))
+    if score is None and gate_passed:
+        score = round(float(weight or VISUAL_SIMILARITY_DIMENSION_WEIGHT), 4)
+    elif score is None:
+        score = 0.0
+    dimension_threshold = _resolve_fidelity_dimension_threshold(weight=weight, threshold=threshold)
+    artifact_failures = [str(item) for item in (artifact.get('blocking_failures') or []) if str(item).strip()]
+    readiness_notes = notes + [
+        f'artifact_path={artifact_path}',
+        f'implementation_status={implementation_status}',
+    ]
+
+    if implementation_status == VISUAL_SIMILARITY_CONTRACT_ONLY_STATUS:
+        blockers.append(f'visual_similarity_artifact_not_ready:{implementation_status}')
+        return (
+            {
+                'implemented': False,
+                'status': 'missing',
+                'score': None,
+                'weight': round(float(weight or 0.0), 4),
+                'weighted_score': 0.0,
+                'notes': readiness_notes,
+                'artifact_path': str(artifact_path),
+                'gate_passed': gate_passed,
+                'implementation_status': implementation_status,
+            },
+            blockers,
+        )
+
+    status = 'pass' if gate_passed and score >= dimension_threshold else 'review'
+    if not gate_passed:
+        status = 'fail'
+        blockers.extend(f'visual_similarity_gate_failed:{failure}' for failure in artifact_failures)
+
+    return (
+        {
+            'implemented': True,
+            'status': status,
+            'score': score,
+            'weight': round(float(weight or 0.0), 4),
+            'weighted_score': round(float(score or 0.0), 4),
+            'notes': readiness_notes,
+            'artifact_path': str(artifact_path),
+            'gate_passed': gate_passed,
+            'implementation_status': implementation_status,
+            'artifact_blocking_failures': artifact_failures,
+        },
+        blockers,
+    )
+
