+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.model_eval_runner import (
+    build_arg_parser,
+    build_fidelity_final_report_summary,
+    build_visual_similarity_artifact_summary,
+    write_fidelity_final_report_artifacts,
+    write_visual_similarity_artifacts,
+)
+
+FIDELITY_FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "fidelity"
+VISUAL_SIMILARITY_FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "visual_similarity"
+
+
+def _load_json(path: Path) -> dict:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def test_model_eval_runner_cli_parses_fidelity_final_report_mode():
+    parser = build_arg_parser()
+
+    args = parser.parse_args(
+        [
+            "--output-dir",
+            "/tmp/fidelity-out",
+            "--fidelity-final-report",
+            "--fidelity-report-input",
+            str(FIDELITY_FIXTURE_DIR / "pass_input.json"),
+        ]
+    )
+
+    assert args.fidelity_final_report is True
+    assert args.fidelity_report_input.endswith("pass_input.json")
+
+
+def test_fidelity_final_report_pass_summary_and_artifacts(tmp_path: Path):
+    summary = build_fidelity_final_report_summary(input_path=FIDELITY_FIXTURE_DIR / "pass_input.json")
+
+    assert summary["pass"] is True
+    assert summary["threshold"] == 95.0
+    assert summary["overall_score"] == 97.2
+    assert summary["blocking_failures"] == []
+    assert summary["weights"]["tables"] == 18.0
+    assert "editable_word_tables" not in summary["dimensions"]
+    assert summary["dimensions"]["tables"]["weight"] == 18.0
+    assert summary["dimensions"]["tables"]["weighted_score"] == 18.0
+    assert summary["tables"]["has_table_xml"] is True
+    assert summary["tables"]["hard_gate_passed"] is True
+
+    output_dir = tmp_path / "fidelity-report"
+    write_fidelity_final_report_artifacts(summary, output_dir)
+
+    metrics_payload = json.loads((output_dir / "fidelity_metrics.json").read_text(encoding="utf-8"))
+    markdown = (output_dir / "fidelity_report.md").read_text(encoding="utf-8")
+    assert metrics_payload["threshold"] == 95.0
+    assert metrics_payload["overall_score"] == 97.2
+    assert metrics_payload["tables"]["sample_with_table_xml_count"] == 2
+    assert "PDF→Word 95% Fidelity Final Report" in markdown
+    assert "Overall score: `97.2`" in markdown
+    assert "has_table_xml: `True`" in markdown
+
+
+def test_fidelity_final_report_table_blocker_fails_hard_gate():
+    summary = build_fidelity_final_report_summary(input_path=FIDELITY_FIXTURE_DIR / "table_blocker_input.json")
+
+    assert summary["pass"] is False
+    assert summary["overall_score"] == 96.6
+    assert summary["weights"]["tables"] == 18.0
+    assert "editable_table" not in summary["dimensions"]
+    assert summary["tables"]["has_table_xml"] is False
+    assert summary["tables"]["image_fallback_table_count"] == 2
+    assert summary["tables"]["status"] == "fail"
+    assert "table_gate_failed:detected_without_word_table_xml" in summary["blocking_failures"]
+    assert "table_gate_failed:image_fallback_present" in summary["blocking_failures"]
+
+
+def test_fidelity_final_report_missing_dimension_is_explicit_gap_not_false_pass():
+    summary = build_fidelity_final_report_summary(input_path=FIDELITY_FIXTURE_DIR / "missing_dimension_input.json")
+
+    assert summary["pass"] is False
+    assert summary["overall_score"] == 80.8
+    assert summary["missing_dimensions"] == ["visual_similarity"]
+    assert summary["dimensions"]["visual_similarity"]["status"] == "missing"
+    assert summary["dimensions"]["visual_similarity"]["weight"] == 17.0
+    assert "dimension_missing:visual_similarity" in summary["blocking_failures"]
+
+
+def test_fidelity_report_consumes_canonical_visual_similarity_artifact(tmp_path: Path):
+    visual_summary = build_visual_similarity_artifact_summary(
+        input_path=VISUAL_SIMILARITY_FIXTURE_DIR / "quality_ready_contract.json",
+        requested_mode="quality",
+        parser_backend="hybrid_experimental",
+    )
+    visual_output_dir = tmp_path / "visual-artifact"
+    write_visual_similarity_artifacts(visual_summary, visual_output_dir)
+
+    payload = _load_json(FIDELITY_FIXTURE_DIR / "missing_dimension_input.json")
+    payload["visual_similarity_artifact_path"] = str((visual_output_dir / "visual_similarity.json").resolve())
+    input_path = tmp_path / "fidelity-input-with-visual.json"
+    input_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+    summary = build_fidelity_final_report_summary(input_path=input_path)
+
+    assert summary["pass"] is True
+    assert summary["overall_score"] == 97.8
+    assert summary["missing_dimensions"] == []
+    assert summary["dimensions"]["visual_similarity"]["status"] == "pass"
+    assert summary["dimensions"]["visual_similarity"]["score"] == 17.0
+    assert summary["dimensions"]["visual_similarity"]["implementation_status"] == "quality_hybrid_async_artifact_ready"
+    assert "dimension_missing:visual_similarity" not in summary["blocking_failures"]
+    assert "visual_similarity_artifact_missing" not in summary["blocking_failures"]
+
+
+def test_contract_only_visual_similarity_artifact_does_not_false_pass(tmp_path: Path):
+    visual_summary = build_visual_similarity_artifact_summary(
+        input_path=VISUAL_SIMILARITY_FIXTURE_DIR / "visual_similarity_contract.json",
+        requested_mode="quality",
+        parser_backend="hybrid_experimental",
+    )
+    visual_output_dir = tmp_path / "visual-contract-only"
+    write_visual_similarity_artifacts(visual_summary, visual_output_dir)
+
+    payload = _load_json(FIDELITY_FIXTURE_DIR / "missing_dimension_input.json")
+    payload["visual_similarity_artifact_path"] = str((visual_output_dir / "visual_similarity.json").resolve())
+    input_path = tmp_path / "fidelity-input-contract-only.json"
+    input_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+    summary = build_fidelity_final_report_summary(input_path=input_path)
+
+    assert summary["pass"] is False
+    assert summary["overall_score"] == 80.8
+    assert summary["missing_dimensions"] == ["visual_similarity"]
+    assert summary["dimensions"]["visual_similarity"]["status"] == "missing"
+    assert (
+        "visual_similarity_artifact_not_ready:contract_only_no_renderer_or_slow_model_invoked"
+        in summary["blocking_failures"]
+    )
