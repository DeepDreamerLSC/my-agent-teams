@@ -0,0 +1,141 @@
+from __future__ import annotations
+
+import copy
+from pathlib import Path
+
+from app.services.pdf_to_word.visual_similarity_gate import (
+    ARTIFACT_REQUIRED_KEYS,
+    QUALITY_HYBRID_ASYNC_MODE,
+    VISUAL_SIMILARITY_DIMENSION_KEY,
+    VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+    VISUAL_SIMILARITY_GATE_VERSION,
+    VisualSimilarityGateError,
+    build_visual_similarity_gate_report,
+    load_visual_similarity_contract,
+    resolve_visual_gate_mode,
+)
+
+FIXTURE_DIR = Path(__file__).parent / 'fixtures' / 'pdf_to_word' / 'visual_similarity'
+CONTRACT_PATH = FIXTURE_DIR / 'visual_similarity_contract.json'
+
+
+def _load_contract() -> dict:
+    return load_visual_similarity_contract(CONTRACT_PATH)
+
+
+def test_fixture_freezes_contract_shape_and_95_score_weight():
+    contract = _load_contract()
+
+    assert contract['contract_version'] == VISUAL_SIMILARITY_GATE_VERSION
+    assert contract['source_policy']['target_total_score_threshold'] == 95
+    assert contract['source_policy']['visual_similarity_weight'] == VISUAL_SIMILARITY_DIMENSION_WEIGHT
+    assert contract['source_policy']['quality_target_scope'] == 'quality/hybrid_async only'
+    assert contract['thresholds'] == {
+        'page_render_similarity_min': 0.92,
+        'key_region_similarity_min': 0.88,
+        'bbox_iou_min': 0.85,
+        'layout_density_delta_max': 0.08,
+        'paragraph_order_delta_max': 0.05,
+        'slow_model_review_band': 0.03,
+    }
+    assert set(ARTIFACT_REQUIRED_KEYS) <= set(contract['artifact_contract']['required_artifacts'])
+    assert contract['artifact_contract']['required_artifacts'][0] == 'visual_similarity.json'
+    assert 'visual_similarity_report.json' not in contract['artifact_contract']['required_artifacts']
+    assert contract['slow_model_policy']['candidate_models'] == ['qwen3_vl_8b']
+    assert 'glm_46v_flash' in contract['slow_model_policy']['comparison_only_models']
+    assert contract['slow_model_policy']['blocked_candidates'][0]['model'] == 'glm_46v_flash'
+
+
+def test_default_sync_skips_visual_gate_and_never_enables_slow_models():
+    report = build_visual_similarity_gate_report(_load_contract(), requested_mode='balanced', parser_backend='apple')
+
+    assert report['mode_boundary']['resolved_gate_mode'] == 'default_sync'
+    assert report['mode_boundary']['enabled'] is False
+    assert report['mode_boundary']['default_sync_safe'] is True
+    assert report['mode_boundary']['default_sync_invokes_render_or_slow_model'] is False
+    assert report['score_contract']['dimension_key'] == VISUAL_SIMILARITY_DIMENSION_KEY
+    assert report['score_contract']['enters_95_total_score'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['score_contract']['skipped_score_reason'] == 'default_sync_excludes_visual_similarity_dimension'
+    assert report['slow_model_policy']['enabled'] is False
+    assert {'fast', 'balanced', 'default_sync'} <= set(report['slow_model_policy']['disallowed_modes'])
+    assert report['blocking_failures'] == []
+    assert report['gate_passed'] is True
+
+
+def test_quality_hybrid_async_enables_visual_score_without_changing_default_policy():
+    report = build_visual_similarity_gate_report(
+        _load_contract(),
+        requested_mode='quality',
+        parser_backend='hybrid_experimental',
+    )
+
+    assert report['mode_boundary']['resolved_gate_mode'] == QUALITY_HYBRID_ASYNC_MODE
+    assert report['mode_boundary']['enabled'] is True
+    assert report['mode_boundary']['default_sync_safe'] is True
+    assert report['mode_boundary']['default_sync_invokes_render_or_slow_model'] is False
+    assert 'apple default + hybrid_experimental quality gray' in report['mode_boundary']['default_sync_policy']
+    assert report['score_contract']['enters_95_total_score'] is True
+    assert report['artifact_contract']['required_artifacts'][0] == 'visual_similarity.json'
+    assert 'visual_similarity_report.json' in report['artifact_contract']['optional_artifacts']
+    assert report['slow_model_policy']['candidate_models'] == ['qwen3_vl_8b']
+    assert 'glm_46v_flash' in report['slow_model_policy']['comparison_only_models']
+    assert report['score_contract']['dimension_weight'] == 17
+    assert report['score_contract']['score_awarded'] == 17
+    assert report['aggregate']['sample_count'] == 2
+    assert report['aggregate']['page_count'] == 2
+    assert report['aggregate']['key_region_count'] == 3
+    assert report['gate_passed'] is True
+    assert report['blocking_failures'] == []
+
+
+def test_quality_mode_below_threshold_has_structured_blocking_failure_and_zero_score():
+    contract = _load_contract()
+    failing = copy.deepcopy(contract)
+    failing['samples'][0]['pages'][0]['key_regions'][0]['region_similarity'] = 0.74
+
+    report = build_visual_similarity_gate_report(failing, requested_mode='hybrid_async')
+
+    assert report['gate_passed'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['aggregate']['slow_model_candidate_region_count'] >= 1
+    assert any(
+        failure == 'math_grade_8:key_region_similarity_below_threshold:math_grade_8:p1:table-01'
+        for failure in report['blocking_failures']
+    )
+    region = report['samples'][0]['pages'][0]['key_regions'][0]
+    assert region['slow_model_triggers'] == ['key_region_below_threshold']
+
+
+def test_missing_render_pair_blocks_only_when_visual_gate_is_enabled():
+    contract = _load_contract()
+    missing = copy.deepcopy(contract)
+    missing['samples'][1]['pages'][0]['render_pair_status'] = 'planned'
+
+    sync_report = build_visual_similarity_gate_report(missing, requested_mode='fast')
+    quality_report = build_visual_similarity_gate_report(missing, requested_mode='quality')
+
+    assert sync_report['gate_passed'] is True
+    assert sync_report['blocking_failures'] == []
+    assert quality_report['gate_passed'] is False
+    assert 'multi_column_extension_stub:visual_similarity_missing_render_pair:p2' in quality_report['blocking_failures']
+
+
+def test_contract_rejects_missing_quality_boundary_fields():
+    contract = _load_contract()
+    broken = copy.deepcopy(contract)
+    broken['source_policy']['quality_target_scope'] = 'default sync'
+
+    try:
+        build_visual_similarity_gate_report(broken, requested_mode='quality')
+    except VisualSimilarityGateError as exc:
+        assert 'quality/hybrid_async' in str(exc)
+    else:  # pragma: no cover - assertion clarity for plain import runners
+        raise AssertionError('expected VisualSimilarityGateError')
+
