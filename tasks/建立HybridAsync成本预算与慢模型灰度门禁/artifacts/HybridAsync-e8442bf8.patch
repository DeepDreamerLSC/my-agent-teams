index 0000000..ebb724a
--- /dev/null
+++ b/backend/app/services/pdf_to_word/visual_gate_budget.py
@@ -0,0 +1,399 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any, Mapping, Sequence
+
+
+VISUAL_GATE_BUDGET_VERSION = 'pdf_to_word_visual_gate_budget/v1'
+DEFAULT_REQUIRED_SUBJECTS = ('science', 'math', 'english', 'chinese')
+DEFAULT_THRESHOLDS: dict[str, Any] = {
+    'required_subjects': list(DEFAULT_REQUIRED_SUBJECTS),
+    'paddle_selected_ratio_max': 0.60,
+    'paddle_selected_ratio_per_sample_max': 0.80,
+    'paddle_cache_hit_rate_min': 0.95,
+    'paddle_latency_seconds_max': 15.0,
+    'slow_model_candidate_pages_max': 3,
+    'slow_model_scheduled_pages_max': 2,
+    'slow_model_timeout_seconds_max': 20.0,
+    'slow_model_cost_units_max': 18,
+}
+DEFAULT_RELEASE_POLICY_TOKENS = (
+    'apple default',
+    'quality gray',
+    'formula audit-only',
+)
+SLOW_MODEL_PROFILE_NAMES = ('qwen3_vl_8b', 'qwen3-vl-8b')
+
+
+def load_visual_gate_budget_payload(path: str | Path) -> dict[str, Any]:
+    payload_path = Path(path).expanduser().resolve()
+    return json.loads(payload_path.read_text(encoding='utf-8'))
+
+
+def write_visual_gate_budget_payload(payload: Mapping[str, Any], output_path: str | Path) -> Path:
+    target = Path(output_path).expanduser().resolve()
+    target.parent.mkdir(parents=True, exist_ok=True)
+    target.write_text(json.dumps(dict(payload), ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return target
+
+
+def build_visual_gate_budget_summary(
+    phase3_report: Mapping[str, Any],
+    *,
+    final_acceptance_summary: Mapping[str, Any] | None = None,
+    thresholds: Mapping[str, Any] | None = None,
+) -> dict[str, Any]:
+    resolved_thresholds = _resolve_thresholds(thresholds)
+    sample_entries = _coerce_sample_entries(phase3_report)
+    sample_subjects = _collect_subjects(sample_entries, final_acceptance_summary)
+    missing_subjects = [
+        subject
+        for subject in resolved_thresholds['required_subjects']
+        if subject not in sample_subjects
+    ]
+    default_boundary = _evaluate_default_sync_boundary(final_acceptance_summary)
+    paddle_summary = _evaluate_paddle_budget(sample_entries, phase3_report, resolved_thresholds)
+    slow_model_summary = _evaluate_slow_model_budget(sample_entries, resolved_thresholds)
+
+    blockers: list[str] = []
+    actions: list[str] = []
+    failure_codes: list[str] = []
+
+    if not default_boundary['default_sync_boundary_ok']:
+        blockers.append('default_sync_boundary_regressed')
+        failure_codes.append('default_sync_boundary_regressed')
+    if missing_subjects:
+        for subject in missing_subjects:
+            blockers.append(f'subject_coverage_missing:{subject}')
+        failure_codes.append('subject_coverage_incomplete')
+    if paddle_summary['budget_exceeded']:
+        actions.append('manual_review')
+        failure_codes.extend(paddle_summary['failure_codes'])
+    if slow_model_summary['budget_exceeded']:
+        actions.append('skip_slow_model_keep_visual_fail_open')
+        failure_codes.extend(slow_model_summary['failure_codes'])
+
+    status = 'ready'
+    if blockers:
+        status = 'blocked'
+    elif 'manual_review' in actions:
+        status = 'manual_review'
+    elif 'skip_slow_model_keep_visual_fail_open' in actions:
+        status = 'slow_model_limited'
+
+    return {
+        'report_type': 'pdf_to_word_visual_gate_budget',
+        'contract_version': VISUAL_GATE_BUDGET_VERSION,
+        'status': status,
+        'gate_passed': status == 'ready',
+        'failure_codes': _dedupe(failure_codes),
+        'blockers': blockers,
+        'actions': _dedupe(actions),
+        'thresholds': resolved_thresholds,
+        'subject_coverage': {
+            'required_subjects': list(resolved_thresholds['required_subjects']),
+            'present_subjects': sorted(sample_subjects),
+            'missing_subjects': missing_subjects,
+        },
+        'default_sync_boundary': default_boundary,
+        'paddle_budget': paddle_summary,
+        'slow_model_budget': slow_model_summary,
+        'sample_count': len(sample_entries),
+    }
+
+
+def _resolve_thresholds(overrides: Mapping[str, Any] | None) -> dict[str, Any]:
+    resolved = dict(DEFAULT_THRESHOLDS)
+    if isinstance(overrides, Mapping):
+        for key, value in overrides.items():
+            if key == 'required_subjects' and isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray)):
+                resolved[key] = [str(item).strip() for item in value if str(item).strip()]
+            else:
+                resolved[key] = value
+    resolved['required_subjects'] = [str(item).strip() for item in resolved.get('required_subjects', DEFAULT_REQUIRED_SUBJECTS) if str(item).strip()]
+    return resolved
+
+
+def _coerce_sample_entries(phase3_report: Mapping[str, Any]) -> list[dict[str, Any]]:
+    payload = phase3_report.get('samples')
+    if not isinstance(payload, list):
+        return []
+    return [dict(item) for item in payload if isinstance(item, Mapping)]
+
+
+def _collect_subjects(
+    sample_entries: Sequence[Mapping[str, Any]],
+    final_acceptance_summary: Mapping[str, Any] | None,
+) -> set[str]:
+    subjects: set[str] = set()
+    for sample in sample_entries:
+        subject = _infer_subject(sample)
+        if subject:
+            subjects.add(subject)
+    if isinstance(final_acceptance_summary, Mapping):
+        for sample in final_acceptance_summary.get('samples') or []:
+            if not isinstance(sample, Mapping):
+                continue
+            subject = _infer_subject(sample)
+            if subject:
+                subjects.add(subject)
+    return subjects
+
+
+def _infer_subject(sample: Mapping[str, Any]) -> str | None:
+    raw_subject = str(sample.get('subject') or '').strip().lower()
+    if raw_subject in DEFAULT_REQUIRED_SUBJECTS:
+        return raw_subject
+    sample_name = str(sample.get('sample_name') or sample.get('source_sample_name') or '').strip()
+    if '科学' in sample_name:
+        return 'science'
+    if '数学' in sample_name:
+        return 'math'
+    if '英语' in sample_name:
+        return 'english'
+    if '语文' in sample_name:
+        return 'chinese'
+    return None
+
+
+def _evaluate_default_sync_boundary(final_acceptance_summary: Mapping[str, Any] | None) -> dict[str, Any]:
+    if not isinstance(final_acceptance_summary, Mapping):
+        return {
+            'default_release_policy': None,
+            'required_tokens': list(DEFAULT_RELEASE_POLICY_TOKENS),
+            'missing_tokens': [],
+            'default_sync_boundary_ok': True,
+            'notes': ['final_acceptance_summary_missing'],
+        }
+    policy = str(final_acceptance_summary.get('default_release_policy') or '').strip()
+    normalized = policy.lower()
+    missing_tokens = [token for token in DEFAULT_RELEASE_POLICY_TOKENS if token not in normalized]
+    return {
+        'default_release_policy': policy or None,
+        'required_tokens': list(DEFAULT_RELEASE_POLICY_TOKENS),
+        'missing_tokens': missing_tokens,
+        'default_sync_boundary_ok': not missing_tokens,
+        'notes': [] if policy else ['default_release_policy_missing'],
+    }
+
+
+def _evaluate_paddle_budget(
+    sample_entries: Sequence[Mapping[str, Any]],
+    phase3_report: Mapping[str, Any],
+    thresholds: Mapping[str, Any],
+) -> dict[str, Any]:
+    aggregate_payload = phase3_report.get('aggregate_metrics') if isinstance(phase3_report.get('aggregate_metrics'), Mapping) else {}
+    cache_hits = int(aggregate_payload.get('cache_hits_second_run') or 0)
+    cache_misses = int(aggregate_payload.get('cache_misses_first_run') or 0)
+    cache_hit_rate = 1.0 if cache_misses == 0 else round(cache_hits / max(cache_misses, 1), 4)
+    aggregate_selected_ratio = _coerce_float(aggregate_payload.get('selected_ratio'))
+    if aggregate_selected_ratio is None:
+        total_selected = sum(len(_coerce_int_list(sample.get('selected_pages'))) for sample in sample_entries)
+        total_scope = sum(len(_coerce_int_list(sample.get('page_scope'))) for sample in sample_entries)
+        aggregate_selected_ratio = round(total_selected / total_scope, 4) if total_scope else 0.0
+
+    failure_codes: list[str] = []
+    over_budget_samples: list[str] = []
+    per_sample: list[dict[str, Any]] = []
+    for sample in sample_entries:
+        sample_name = str(sample.get('sample_name') or '').strip()
+        selected_ratio = _coerce_float(sample.get('selected_ratio'))
+        if selected_ratio is None:
+            selected_pages = _coerce_int_list(sample.get('selected_pages'))
+            scope_pages = _coerce_int_list(sample.get('page_scope'))
+            selected_ratio = round(len(selected_pages) / len(scope_pages), 4) if scope_pages else 0.0
+        latency = _coerce_float(sample.get('latency_seconds_first_run')) or 0.0
+        sample_failure_codes: list[str] = []
+        if selected_ratio > float(thresholds['paddle_selected_ratio_per_sample_max']):
+            sample_failure_codes.append('paddle_selected_ratio_per_sample_over_budget')
+        if latency > float(thresholds['paddle_latency_seconds_max']):
+            sample_failure_codes.append('paddle_latency_over_budget')
+        if sample_failure_codes:
+            over_budget_samples.append(sample_name)
+            failure_codes.extend(sample_failure_codes)
+        per_sample.append(
+            {
+                'sample_name': sample_name,
+                'selected_pages': _coerce_int_list(sample.get('selected_pages')),
+                'page_scope': _coerce_int_list(sample.get('page_scope')),
+                'selected_ratio': selected_ratio,
+                'latency_seconds_first_run': latency,
+                'cache_misses_first_run': int(sample.get('cache_misses_first_run') or 0),
+                'cache_hits_second_run': int(sample.get('cache_hits_second_run') or 0),
+                'skipped_reason': str(sample.get('skipped_reason') or '').strip() or None,
+                'failure_codes': sample_failure_codes,
+            }
+        )
+
+    if aggregate_selected_ratio > float(thresholds['paddle_selected_ratio_max']):
+        failure_codes.append('paddle_selected_ratio_over_budget')
+    if cache_hit_rate < float(thresholds['paddle_cache_hit_rate_min']):
+        failure_codes.append('paddle_cache_hit_rate_below_budget')
+
+    return {
+        'aggregate_selected_ratio': aggregate_selected_ratio,
+        'aggregate_selected_ratio_max': float(thresholds['paddle_selected_ratio_max']),
+        'cache_hit_rate_second_run': cache_hit_rate,
+        'cache_hit_rate_min': float(thresholds['paddle_cache_hit_rate_min']),
+        'cache_hits_second_run': cache_hits,
+        'cache_misses_first_run': cache_misses,
+        'over_budget_samples': over_budget_samples,
+        'samples': per_sample,
+        'budget_exceeded': bool(failure_codes),
+        'failure_codes': _dedupe(failure_codes),
+    }
+
+
+def _evaluate_slow_model_budget(
+    sample_entries: Sequence[Mapping[str, Any]],
+    thresholds: Mapping[str, Any],
+) -> dict[str, Any]:
+    aggregate_candidate_pages = 0
+    aggregate_scheduled_pages = 0
+    aggregate_cost_units = 0
+    timeout_samples: list[str] = []
+    failure_codes: list[str] = []
+    samples: list[dict[str, Any]] = []
+
+    for sample in sample_entries:
+        sample_name = str(sample.get('sample_name') or '').strip()
+        slow_metrics = _extract_slow_model_metrics(sample)
+        aggregate_candidate_pages += slow_metrics['candidate_pages']
+        aggregate_scheduled_pages += slow_metrics['scheduled_pages']
+        aggregate_cost_units += slow_metrics['cost_units']
+        sample_failure_codes: list[str] = []
+        if slow_metrics['candidate_pages'] > int(thresholds['slow_model_candidate_pages_max']):
+            sample_failure_codes.append('slow_model_candidate_pages_over_budget')
+        if slow_metrics['scheduled_pages'] > int(thresholds['slow_model_scheduled_pages_max']):
+            sample_failure_codes.append('slow_model_scheduled_pages_over_budget')
+        if slow_metrics['latency_seconds'] > float(thresholds['slow_model_timeout_seconds_max']):
+            sample_failure_codes.append('slow_model_latency_over_budget')
+        if slow_metrics['cost_units'] > int(thresholds['slow_model_cost_units_max']):
+            sample_failure_codes.append('slow_model_cost_over_budget')
+        if slow_metrics['timeout_detected']:
+            sample_failure_codes.append('slow_model_timeout_detected')
+            timeout_samples.append(sample_name)
+        if sample_failure_codes:
+            failure_codes.extend(sample_failure_codes)
+        samples.append(
+            {
+                'sample_name': sample_name,
+                **slow_metrics,
+                'failure_codes': sample_failure_codes,
+            }
+        )
+
+    return {
+        'candidate_pages_total': aggregate_candidate_pages,
+        'scheduled_pages_total': aggregate_scheduled_pages,
+        'cost_units_total': aggregate_cost_units,
+        'timeout_samples': timeout_samples,
+        'samples': samples,
+        'budget_exceeded': bool(failure_codes),
+        'failure_codes': _dedupe(failure_codes),
+    }
+
+
+def _extract_slow_model_metrics(sample: Mapping[str, Any]) -> dict[str, Any]:
+    direct_payload = sample.get('slow_model_review') if isinstance(sample.get('slow_model_review'), Mapping) else None
+    if direct_payload is not None:
+        candidate_pages = int(direct_payload.get('candidate_pages') or 0)
+        scheduled_pages = int(direct_payload.get('scheduled_pages') or 0)
+        latency_seconds = _coerce_float(direct_payload.get('latency_seconds')) or 0.0
+        cost_units = int(direct_payload.get('cost_units') or 0)
+        timeout_detected = bool(direct_payload.get('timeout_detected', False))
+        skipped_reason = str(direct_payload.get('skipped_reason') or '').strip() or None
+        return {
+            'candidate_pages': candidate_pages,
+            'scheduled_pages': scheduled_pages,
+            'latency_seconds': latency_seconds,
+            'cost_units': cost_units,
+            'timeout_detected': timeout_detected,
+            'skipped_reason': skipped_reason,
+        }
+
+    profile_audits = _load_profile_audits(sample)
+    review_audit = None
+    for key, value in profile_audits.items():
+        if str(key).strip() in SLOW_MODEL_PROFILE_NAMES and isinstance(value, Mapping):
+            review_audit = value
+            break
+    if review_audit is None:
+        return {
+            'candidate_pages': 0,
+            'scheduled_pages': 0,
+            'latency_seconds': 0.0,
+            'cost_units': 0,
+            'timeout_detected': False,
+            'skipped_reason': None,
+        }
+
+    page_scope = _coerce_int_list(review_audit.get('page_scope'))
+    selected_pages = _coerce_int_list(review_audit.get('selected_pages_or_crops') or review_audit.get('selected_pages'))
+    candidate_pages = len(page_scope)
+    scheduled_pages = len(selected_pages)
+    latency_seconds = _coerce_float(review_audit.get('latency_seconds')) or 0.0
+    skipped_reason = str(review_audit.get('skipped_reason') or '').strip() or None
+    warnings = [str(item).strip() for item in review_audit.get('adapter_warnings') or [] if str(item).strip()]
+    timeout_detected = skipped_reason == 'review_timeout' or any('timeout' in warning.lower() or '超时' in warning for warning in warnings)
+    cost_units = scheduled_pages * 6 + int(review_audit.get('candidate_count') or candidate_pages) * 3
+    return {
+        'candidate_pages': candidate_pages,
+        'scheduled_pages': scheduled_pages,
+        'latency_seconds': latency_seconds,
+        'cost_units': cost_units,
+        'timeout_detected': timeout_detected,
+        'skipped_reason': skipped_reason,
+    }
+
+
+def _load_profile_audits(sample: Mapping[str, Any]) -> dict[str, Any]:
+    inline_payload = sample.get('profile_audits')
+    if isinstance(inline_payload, Mapping):
+        return {str(key): dict(value) for key, value in inline_payload.items() if isinstance(value, Mapping)}
+    path_value = str(sample.get('profile_audits_path') or '').strip()
+    if not path_value:
+        return {}
+    path = Path(path_value).expanduser()
+    if not path.exists():
+        return {}
+    try:
+        payload = json.loads(path.read_text(encoding='utf-8'))
+    except Exception:
+        return {}
+    if not isinstance(payload, Mapping):
+        return {}
+    return {str(key): dict(value) for key, value in payload.items() if isinstance(value, Mapping)}
+
+
+def _coerce_int_list(value: Any) -> list[int]:
+    if not isinstance(value, Sequence) or isinstance(value, (str, bytes, bytearray)):
+        return []
+    result: list[int] = []
+    for item in value:
+        try:
+            normalized = int(item)
+        except (TypeError, ValueError):
+            continue
+        if normalized > 0:
+            result.append(normalized)
+    return sorted(set(result))
+
+
+def _coerce_float(value: Any) -> float | None:
+    if value is None or value == '':
+        return None
+    try:
+        return float(value)
+    except (TypeError, ValueError):
+        return None
+
+
+def _dedupe(values: Sequence[str]) -> list[str]:
+    deduped: list[str] = []
+    for value in values:
+        normalized = str(value).strip()
+        if normalized and normalized not in deduped:
+            deduped.append(normalized)
+    return deduped

