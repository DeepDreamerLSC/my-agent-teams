+from __future__ import annotations
+
+import json
+from datetime import datetime
+from html import escape
+from pathlib import Path
+from typing import Any, Mapping, Sequence
+from urllib.parse import quote
+
+
+VISUAL_DIFF_REPORT_VERSION = 'pdf_to_word_visual_diff_report/v1'
+VISUAL_DIFF_REPORT_JSON = 'visual_diff_report.json'
+VISUAL_DIFF_INDEX_HTML = 'index.html'
+VISUAL_DIFF_PAGES_DIR = 'pages'
+
+
+def load_visual_diff_payload(path: str | Path) -> dict[str, Any]:
+    return json.loads(Path(path).expanduser().resolve().read_text(encoding='utf-8'))
+
+
+def build_debug_placeholder_data_uri(
+    label: str,
+    *,
+    fill: str = '#eef2ff',
+    stroke: str = '#475569',
+    width: int = 420,
+    height: int = 240,
+) -> str:
+    safe_label = escape(str(label or 'debug-view'))
+    svg = (
+        f'<svg xmlns="http://www.w3.org/2000/svg" width="{int(width)}" height="{int(height)}" viewBox="0 0 {int(width)} {int(height)}">'
+        f'<rect width="100%" height="100%" rx="18" fill="{fill}" stroke="{stroke}" stroke-width="4"/>'
+        f'<text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" '
+        f'font-family="Arial, Helvetica, sans-serif" font-size="20" fill="{stroke}">{safe_label}</text>'
+        '</svg>'
+    )
+    return 'data:image/svg+xml;charset=utf-8,' + quote(svg)
+
+
+def build_visual_diff_report(payload: Mapping[str, Any]) -> dict[str, Any]:
+    sample_name = str(
+        payload.get('sample_name')
+        or payload.get('report_name')
+        or payload.get('artifact_name')
+        or payload.get('source_name')
+        or 'visual-diff-debug'
+    ).strip()
+    default_subject = str(payload.get('subject') or payload.get('subject_page_type') or '').strip() or None
+    pages = _collect_pages(payload, default_subject=default_subject)
+
+    subject_scope = sorted({str(page.get('subject') or 'unknown') for page in pages})
+    page_count = len(pages)
+    page_failure_count = sum(1 for page in pages if page['failure_reasons'])
+    key_region_count = sum(len(page['key_regions']) for page in pages)
+    veto_count = sum(len(page['vetoes']) for page in pages)
+    blocker_count = sum(len(page['blockers']) for page in pages)
+
+    return {
+        'report_type': VISUAL_DIFF_REPORT_VERSION,
+        'generated_at': datetime.now().astimezone().isoformat(timespec='seconds'),
+        'sample_name': sample_name,
+        'subject_scope': subject_scope,
+        'page_count': page_count,
+        'page_failure_count': page_failure_count,
+        'key_region_count': key_region_count,
+        'veto_count': veto_count,
+        'blocker_count': blocker_count,
+        'summary': {
+            'page_count': page_count,
+            'page_failure_count': page_failure_count,
+            'key_region_count': key_region_count,
+            'veto_count': veto_count,
+            'blocker_count': blocker_count,
+            'subjects': subject_scope,
+            'open_local_html_hint': 'open index.html directly in browser',
+        },
+        'pages': pages,
+    }
+
+
+def _collect_pages(payload: Mapping[str, Any], *, default_subject: str | None) -> list[dict[str, Any]]:
+    pages_payload = payload.get('pages')
+    bespoke_pages = [
+        _normalize_page(page, default_subject=default_subject, page_ordinal=index + 1)
+        for index, page in enumerate(pages_payload)
+        if isinstance(page, Mapping)
+    ] if isinstance(pages_payload, list) else []
+    if bespoke_pages:
+        return bespoke_pages
+    return _normalize_canonical_visual_similarity_pages(payload, default_subject=default_subject)
+
+
+def _normalize_canonical_visual_similarity_pages(
+    payload: Mapping[str, Any],
+    *,
+    default_subject: str | None,
+) -> list[dict[str, Any]]:
+    render_pairs = payload.get('render_pairs')
+    if not isinstance(render_pairs, list):
+        render_pairs = _dig(payload, 'render_pair_artifact', 'render_pairs')
+    page_scores = payload.get('page_scores')
+    key_regions = payload.get('key_regions')
+    vetoes = payload.get('vetoes')
+    if not any(isinstance(items, list) and items for items in (render_pairs, page_scores, key_regions, vetoes)):
+        return []
+
+    render_pair_by_page = _index_mapping_list_by_page(render_pairs)
+    page_score_by_page = _index_mapping_list_by_page(page_scores)
+    key_regions_by_page = _group_mapping_list_by_page(key_regions)
+    vetoes_by_page = _group_mapping_list_by_page(vetoes)
+
+    page_indexes = sorted(
+        set(render_pair_by_page)
+        | set(page_score_by_page)
+        | set(key_regions_by_page)
+        | set(vetoes_by_page)
+    )
+    pages: list[dict[str, Any]] = []
+    for page_ordinal, page_index in enumerate(page_indexes, start=1):
+        render_pair = render_pair_by_page.get(page_index, {})
+        page_score = page_score_by_page.get(page_index, {})
+        merged_page = {
+            'page_index': page_index,
+            'subject': (
+                _non_empty(page_score.get('subject_page_type'))
+                or _non_empty(payload.get('subject_page_type'))
+                or default_subject
+                or 'unknown'
+            ),
+            'page_title': _build_canonical_page_title(page_index, page_score),
+            'pair_status': _non_empty(render_pair.get('pair_status')) or _non_empty(page_score.get('pair_status')) or 'matched',
+            'overall_score': (
+                page_score.get('page_render_similarity')
+                if page_score.get('page_render_similarity') is not None
+                else page_score.get('score')
+            ),
+            'source_image_path': (
+                _non_empty(_dig(page_score, 'evidence', 'source_image_path'))
+                or _non_empty(_dig(render_pair, 'source_pdf', 'image_path'))
+            ),
+            'output_image_path': (
+                _non_empty(_dig(page_score, 'evidence', 'docx_image_path'))
+                or _non_empty(_dig(render_pair, 'output_docx', 'image_path'))
+            ),
+            'diff_image_path': (
+                _non_empty(_dig(page_score, 'evidence', 'diff_image_path'))
+                or _non_empty(page_score.get('diff_image_path'))
+                or _non_empty(_dig(render_pair, 'diff_image_path'))
+            ),
+            'failure_reasons': list(page_score.get('review_reasons') or []),
+            'blockers': _canonical_blockers_for_page(payload, page_index),
+            'vetoes': vetoes_by_page.get(page_index, []),
+            'key_regions': key_regions_by_page.get(page_index, []),
+            'render_pair': render_pair,
+        }
+        pages.append(_normalize_page(merged_page, default_subject=default_subject, page_ordinal=page_ordinal))
+    return pages
+
+
+def write_visual_diff_report(report: Mapping[str, Any], output_root: str | Path) -> dict[str, str]:
+    root = Path(output_root).expanduser().resolve()
+    root.mkdir(parents=True, exist_ok=True)
+    pages_dir = root / VISUAL_DIFF_PAGES_DIR
+    pages_dir.mkdir(parents=True, exist_ok=True)
+
+    report_path = root / VISUAL_DIFF_REPORT_JSON
+    report_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+
+    page_links: dict[int, str] = {}
+    for page in report.get('pages') or []:
+        if not isinstance(page, Mapping):
+            continue
+        page_index = int(page.get('page_index') or 0)
+        page_file = pages_dir / f'page-{page_index:03d}.html'
+        page_file.write_text(_render_page_html(page), encoding='utf-8')
+        page_links[page_index] = page_file.relative_to(root).as_posix()
+
+    index_path = root / VISUAL_DIFF_INDEX_HTML
+    index_path.write_text(_render_index_html(report, page_links=page_links), encoding='utf-8')
+
+    return {
+        'output_root': str(root),
+        'report_json': str(report_path),
+        'index_html': str(index_path),
+        'pages_dir': str(pages_dir),
+    }
+
+
+def generate_visual_diff_report(payload: Mapping[str, Any], output_root: str | Path) -> dict[str, Any]:
+    report = build_visual_diff_report(payload)
+    artifact_paths = write_visual_diff_report(report, output_root)
+    enriched = dict(report)
+    enriched['artifact_paths'] = artifact_paths
+    return enriched
+
+
+def _normalize_page(
+    page: Mapping[str, Any],
+    *,
+    default_subject: str | None,
+    page_ordinal: int,
+) -> dict[str, Any]:
+    page_index = _coerce_int(
+        page.get('page_index')
+        or _dig(page, 'render_pair', 'page_index')
+        or _dig(page, 'source_pdf', 'page_index')
+        or page_ordinal,
+        default=page_ordinal,
+    )
+    subject = str(page.get('subject') or default_subject or 'unknown').strip() or 'unknown'
+    source_image_path = (
+        _non_empty(page.get('source_image_path'))
+        or _non_empty(_dig(page, 'evidence', 'source_image_path'))
+        or _non_empty(_dig(page, 'render_pair', 'source_pdf', 'image_path'))
+        or _non_empty(_dig(page, 'source_pdf', 'image_path'))
+    )
+    output_image_path = (
+        _non_empty(page.get('output_image_path'))
+        or _non_empty(_dig(page, 'evidence', 'docx_image_path'))
+        or _non_empty(_dig(page, 'render_pair', 'output_docx', 'image_path'))
+        or _non_empty(_dig(page, 'output_docx', 'image_path'))
+    )
+    diff_image_path = (
+        _non_empty(page.get('diff_image_path'))
+        or _non_empty(_dig(page, 'evidence', 'diff_image_path'))
+        or _non_empty(_dig(page, 'render_pair', 'diff_image_path'))
+        or _non_empty(page.get('diff_path'))
+    )
+    key_regions = _normalize_key_regions(page)
+    blockers = _normalize_blockers(page.get('blockers'))
+    vetoes = _normalize_vetoes(page.get('vetoes'))
+    failure_reasons = _collect_failure_reasons(page, blockers=blockers, vetoes=vetoes, key_regions=key_regions)
+
+    return {
+        'page_index': page_index,
+        'subject': subject,
+        'page_title': str(page.get('page_title') or f'Page {page_index}').strip() or f'Page {page_index}',
+        'pair_status': str(page.get('pair_status') or _dig(page, 'render_pair', 'pair_status') or 'matched').strip() or 'matched',
+        'overall_score': _coerce_float(page.get('score') or page.get('overall_score')),
+        'source_image_path': source_image_path,
+        'output_image_path': output_image_path,
+        'diff_image_path': diff_image_path,
+        'source_image_uri': _to_openable_uri(source_image_path),
+        'output_image_uri': _to_openable_uri(output_image_path),
+        'diff_image_uri': _to_openable_uri(diff_image_path),
+        'failure_reasons': failure_reasons,
+        'blockers': blockers,
+        'vetoes': vetoes,
+        'key_regions': key_regions,
+    }
+
+
+def _normalize_key_regions(page: Mapping[str, Any]) -> list[dict[str, Any]]:
+    raw_items = page.get('key_regions')
+    if not isinstance(raw_items, list):
+        raw_items = page.get('region_scores')
+    if not isinstance(raw_items, list):
+        raw_items = []
+
+    results: list[dict[str, Any]] = []
+    for index, item in enumerate(raw_items, start=1):
+        if not isinstance(item, Mapping):
+            continue
+        region_id = (
+            _non_empty(item.get('region_id'))
+            or _non_empty(item.get('relation_id'))
+            or _non_empty(item.get('id'))
+            or f'region-{index}'
+        )
+        region_kind = (
+            _non_empty(item.get('region_kind'))
+            or _non_empty(item.get('region_type'))
+            or _non_empty(item.get('kind'))
+            or _non_empty(item.get('relation_kind'))
+            or 'unknown'
+        )
+        score = _coerce_float(item.get('score') if item.get('score') is not None else item.get('region_similarity'))
+        reasons = _normalize_string_list(item.get('reasons') or item.get('failure_reasons'))
+        summary = _non_empty(item.get('summary')) or ('; '.join(reasons) if reasons else None)
+        source_crop_path = (
+            _non_empty(item.get('source_crop_path'))
+            or _non_empty(_dig(item, 'evidence', 'source_crop_path'))
+            or _non_empty(_dig(item, 'crops', 'source'))
+        )
+        output_crop_path = (
+            _non_empty(item.get('output_crop_path'))
+            or _non_empty(item.get('docx_crop_path'))
+            or _non_empty(_dig(item, 'evidence', 'output_crop_path'))
+            or _non_empty(_dig(item, 'evidence', 'docx_crop_path'))
+            or _non_empty(_dig(item, 'crops', 'output'))
+        )
+        diff_crop_path = (
+            _non_empty(item.get('diff_crop_path'))
+            or _non_empty(item.get('diff_image_path'))
+            or _non_empty(_dig(item, 'evidence', 'diff_crop_path'))
+            or _non_empty(_dig(item, 'evidence', 'diff_image_path'))
+            or _non_empty(_dig(item, 'crops', 'diff'))
+        )
+        results.append({
+            'region_id': region_id,
+            'region_kind': region_kind,
+            'score': score,
+            'status': _score_status(score),
+            'summary': summary,
+            'reasons': reasons,
+            'source_crop_path': source_crop_path,
+            'output_crop_path': output_crop_path,
+            'diff_crop_path': diff_crop_path,
+            'source_crop_uri': _to_openable_uri(source_crop_path),
+            'output_crop_uri': _to_openable_uri(output_crop_path),
+            'diff_crop_uri': _to_openable_uri(diff_crop_path),
+        })
+    return results
+
+
+def _index_mapping_list_by_page(value: Any) -> dict[int, Mapping[str, Any]]:
+    if not isinstance(value, list):
+        return {}
+    indexed: dict[int, Mapping[str, Any]] = {}
+    for item in value:
+        if not isinstance(item, Mapping):
+            continue
+        page_index = _coerce_int(item.get('page_index'), default=0)
+        if page_index > 0:
+            indexed[page_index] = item
+    return indexed
+
+
+def _group_mapping_list_by_page(value: Any) -> dict[int, list[Mapping[str, Any]]]:
+    if not isinstance(value, list):
+        return {}
+    grouped: dict[int, list[Mapping[str, Any]]] = {}
+    for item in value:
+        if not isinstance(item, Mapping):
+            continue
+        page_index = _coerce_int(item.get('page_index'), default=0)
+        if page_index <= 0:
+            continue
+        grouped.setdefault(page_index, []).append(item)
+    return grouped
+
+
+def _canonical_blockers_for_page(payload: Mapping[str, Any], page_index: int) -> list[dict[str, Any]]:
+    blockers: list[dict[str, Any]] = []
+    raw_blockers = payload.get('blockers')
+    if isinstance(raw_blockers, list):
+        for item in raw_blockers:
+            if not isinstance(item, Mapping):
+                continue
+            blocker_page = _coerce_int(item.get('page_index'), default=page_index)
+            if blocker_page == page_index:
+                blockers.append(item)
+    return blockers
+
+
+def _build_canonical_page_title(page_index: int, page_score: Mapping[str, Any]) -> str:
+    subject = _non_empty(page_score.get('subject_page_type'))
+    page_role = _non_empty(page_score.get('page_role'))
+    fragments = [f'Page {page_index}']
+    if subject:
+        fragments.append(subject)
+    if page_role:
+        fragments.append(page_role)
+    return ' · '.join(fragments)
+
+
+def _normalize_blockers(value: Any) -> list[dict[str, Any]]:
+    if not isinstance(value, list):
+        return []
+    results: list[dict[str, Any]] = []
+    for item in value:
+        if isinstance(item, Mapping):
+            summary = _non_empty(item.get('summary')) or _non_empty(item.get('message')) or _non_empty(item.get('code'))
+            results.append({
+                'code': _non_empty(item.get('code')) or 'unknown_blocker',
+                'summary': summary or 'unknown blocker',
+            })
+        elif (text := _non_empty(item)) is not None:
+            results.append({'code': text, 'summary': text})
+    return results
+
+
+def _normalize_vetoes(value: Any) -> list[dict[str, Any]]:
+    if not isinstance(value, list):
+        return []
+    results: list[dict[str, Any]] = []
+    for item in value:
+        if not isinstance(item, Mapping):
+            continue
+        summary = _non_empty(item.get('summary')) or _non_empty(item.get('message')) or _non_empty(item.get('code'))
+        results.append({
+            'code': _non_empty(item.get('code')) or 'unknown_veto',
+            'summary': summary or 'unknown veto',
+            'recommended_common_code': _non_empty(item.get('recommended_common_code')),
+        })
+    return results
+
+
+def _collect_failure_reasons(
+    page: Mapping[str, Any],
+    *,
+    blockers: Sequence[Mapping[str, Any]],
+    vetoes: Sequence[Mapping[str, Any]],
+    key_regions: Sequence[Mapping[str, Any]],
+) -> list[str]:
+    results: list[str] = []
+    seen: set[str] = set()
+
+    for item in blockers:
+        summary = _non_empty(item.get('summary'))
+        if summary and summary not in seen:
+            results.append(summary)
+            seen.add(summary)
+    for item in vetoes:
+        summary = _non_empty(item.get('summary'))
+        if summary and summary not in seen:
+            results.append(summary)
+            seen.add(summary)
+    for raw in _normalize_string_list(page.get('failure_reasons') or page.get('low_score_reasons')):
+        if raw not in seen:
+            results.append(raw)
+            seen.add(raw)
+    for region in key_regions:
+        status = str(region.get('status') or '')
+        if status != 'fail':
+            continue
+        summary = _non_empty(region.get('summary')) or _non_empty(region.get('region_kind'))
+        if summary and summary not in seen:
+            results.append(summary)
+            seen.add(summary)
+    return results
+
+
+def _score_status(score: float | None) -> str:
+    if score is None:
+        return 'unknown'
+    if score < 0.75:
+        return 'fail'
+    if score < 0.88:
+        return 'warn'
+    return 'pass'
+
+
+def _render_index_html(report: Mapping[str, Any], *, page_links: Mapping[int, str]) -> str:
+    pages = report.get('pages') or []
+    cards_html = []
+    for page in pages:
+        if not isinstance(page, Mapping):
+            continue
+        page_index = int(page.get('page_index') or 0)
+        page_link = page_links.get(page_index, '#')
+        status = 'no-go' if page.get('failure_reasons') else 'pass'
+        failure_html = ''.join(f'<li>{escape(str(reason))}</li>' for reason in page.get('failure_reasons') or []) or '<li>无显式失败原因</li>'
+        cards_html.append(
+            f'''
+            <section class="page-card">
+              <div class="page-card-header">
+                <div>
+                  <h2>{escape(str(page.get("page_title") or f"Page {page_index}"))}</h2>
+                  <p class="meta">Page {page_index} · {escape(str(page.get("subject") or "unknown"))} · status={escape(status)}</p>
+                </div>
+                <a class="detail-link" href="{escape(page_link)}">打开详情页</a>
+              </div>
+              <div class="image-grid">
+                {_render_image_tile('Source PDF', page.get('source_image_uri'))}
+                {_render_image_tile('Output DOCX', page.get('output_image_uri'))}
+                {_render_image_tile('Diff Overlay', page.get('diff_image_uri'))}
+              </div>
+              <div class="failure-box">
+                <h3>失败原因</h3>
+                <ul>{failure_html}</ul>
+              </div>
+            </section>
+            '''
+        )
+
+    summary = report.get('summary') or {}
+    subjects = ', '.join(str(item) for item in summary.get('subjects') or [])
+    return f'''<!DOCTYPE html>
+<html lang="zh-CN">
+<head>
+  <meta charset="utf-8" />
+  <meta name="viewport" content="width=device-width, initial-scale=1" />
+  <title>{escape(str(report.get("sample_name") or "visual-diff-debug"))} - Visual Diff Debug</title>
+  <style>{_base_css()}</style>
+</head>
+<body>
+  <main class="container">
+    <header class="hero">
+      <h1>视觉差异 Debug 报告</h1>
+      <p class="hero-subtitle">{escape(str(report.get("sample_name") or "visual-diff-debug"))}</p>
+      <div class="summary-grid">
+        <div class="summary-card"><span>页数</span><strong>{int(summary.get("page_count") or 0)}</strong></div>
+        <div class="summary-card"><span>失败页</span><strong>{int(summary.get("page_failure_count") or 0)}</strong></div>
+        <div class="summary-card"><span>关键区域</span><strong>{int(summary.get("key_region_count") or 0)}</strong></div>
+        <div class="summary-card"><span>学科</span><strong>{escape(subjects or "-")}</strong></div>
+      </div>
+      <p class="hint">本地直接打开本页即可查看每页 source/output/diff 预览；点击详情页可进一步定位 key-region crop 与失败原因。</p>
+    </header>
+    {''.join(cards_html)}
+  </main>
+</body>
+</html>'''
+
+
+def _render_page_html(page: Mapping[str, Any]) -> str:
+    key_region_cards = []
+    for region in page.get('key_regions') or []:
+        if not isinstance(region, Mapping):
+            continue
+        reasons_html = ''.join(f'<li>{escape(str(reason))}</li>' for reason in region.get('reasons') or []) or '<li>无</li>'
+        key_region_cards.append(
+            f'''
+            <section class="region-card">
+              <div class="region-header">
+                <h3>{escape(str(region.get("region_kind") or "unknown"))}</h3>
+                <span class="badge badge-{escape(str(region.get("status") or "unknown"))}">{escape(str(region.get("status") or "unknown"))}</span>
+              </div>
+              <p class="meta">{escape(str(region.get("region_id") or "region"))} · score={escape(_format_score(region.get("score")))}</p>
+              <div class="image-grid crop-grid">
+                {_render_image_tile('Source Crop', region.get('source_crop_uri'))}
+                {_render_image_tile('Output Crop', region.get('output_crop_uri'))}
+                {_render_image_tile('Diff Crop', region.get('diff_crop_uri'))}
