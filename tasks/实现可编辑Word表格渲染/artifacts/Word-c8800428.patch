+def _parse_html_table(table_html: str) -> _ParsedTableSpec | None:
+    parser = _HTMLTableParser()
+    try:
+        parser.feed(table_html)
+        parser.close()
+    except Exception:
+        return None
+    if not parser.rows:
+        return None
+
+    cells: list[_TableCellSpec] = []
+    column_count = 0
+    pending_spans: dict[int, int] = {}
+    for row_index, row in enumerate(parser.rows):
+        current_pending = {column: remaining for column, remaining in pending_spans.items() if remaining > 0}
+        next_pending = {
+            column: remaining - 1
+            for column, remaining in current_pending.items()
+            if remaining - 1 > 0
+        }
+        column_index = 0
+        for raw_cell in row:
+            while current_pending.get(column_index, 0) > 0:
+                column_index += 1
+            row_span = _positive_int(raw_cell.get('row_span'), default=1)
+            column_span = _positive_int(raw_cell.get('column_span'), default=1)
+            body_xml = _table_text_paragraphs_xml(str(raw_cell.get('text') or ''))
+            cells.append(
+                _TableCellSpec(
+                    row_index=row_index,
+                    column_index=column_index,
+                    body_xml=body_xml,
+                    row_span=row_span,
+                    column_span=column_span,
+                )
+            )
+            if row_span > 1:
+                for covered_column in range(column_index, column_index + column_span):
+                    next_pending[covered_column] = max(next_pending.get(covered_column, 0), row_span - 1)
+            column_index += column_span
+        if current_pending:
+            column_count = max(column_count, max(current_pending) + 1)
+        if next_pending:
+            column_count = max(column_count, max(next_pending) + 1)
+        column_count = max(column_count, column_index)
+        pending_spans = next_pending
+
+    row_count = max((cell.row_index + max(cell.row_span, 1) for cell in cells), default=len(parser.rows))
+    if row_count <= 0 or column_count <= 0:
+        return None
+    return _ParsedTableSpec(row_count=row_count, column_count=column_count, cells=tuple(cells))
+
