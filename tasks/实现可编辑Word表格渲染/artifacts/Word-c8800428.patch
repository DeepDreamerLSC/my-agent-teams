+def test_exercise_docx_assembler_renders_html_table_merges_as_real_word_table_xml():
+    document = ExerciseDocument(
+        source_name='merged-html-table.pdf',
+        mode='balanced',
+        parser_backend='fixture',
+        page_count=1,
+        sections=[
+            ExerciseSection(
+                title='表格题',
+                materials=[
+                    _table_block(
+                        {
+                            'version': 1,
+                            'kind': 'table',
+                            'table_html': (
+                                '<table>'
+                                '<tr><th rowspan="2" colspan="2">总计</th><th>甲</th></tr>'
+                                '<tr><td>乙</td></tr>'
+                                '<tr><td>1</td><td>2</td><td>3</td></tr>'
+                                '</table>'
+                            ),
+                            'fallback_text': '表格降级占位',
+                        }
+                    )
+                ],
+                items=[],
+            )
+        ],
+    )
+
+    docx_bytes = assemble_exercise_docx_bytes(document)
+    document_xml = _read_document_xml(docx_bytes)
+    document_root = _read_document_root(docx_bytes)
+
+    tables = document_root.findall('.//w:tbl', WORD_NS)
+    assert len(tables) == 1
+    grid_spans = document_root.findall('.//w:gridSpan', WORD_NS)
+    v_merges = document_root.findall('.//w:vMerge', WORD_NS)
+    assert any(node.get(WORD_VAL) == '2' for node in grid_spans)
+    assert any(node.get(WORD_VAL) == 'restart' for node in v_merges)
+    assert any(node.get(WORD_VAL) is None for node in v_merges)
+    assert '总计' in document_xml
+    assert '甲' in document_xml
+    assert '乙' in document_xml
+
