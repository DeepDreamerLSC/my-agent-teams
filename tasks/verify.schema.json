{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-agent-teams.local/tasks/verify.schema.json",
  "title": "QA Verify Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "agent",
    "verified_at",
    "status",
    "pass",
    "summary"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "pass": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "test_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scenarios_verified": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "regressions_found": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
