+def collect_canonical_visual_evidence(sample_root: str | Path) -> dict[str, Any]:
+    resolved_root = Path(sample_root).expanduser().resolve()
+    artifacts: dict[str, dict[str, Any]] = {}
+    missing: list[str] = []
+    for file_name in CANONICAL_VISUAL_EVIDENCE_FILENAMES:
+        path = resolved_root / file_name
+        exists = path.exists()
+        artifacts[file_name] = {
+            "path": str(path),
+            "exists": exists,
+        }
+        if not exists:
+            missing.append(file_name)
+    return {
+        "sample_root": str(resolved_root),
+        "artifacts": artifacts,
+        "missing_artifacts": missing,
+        "complete": not missing,
+    }
