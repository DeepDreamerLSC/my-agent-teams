+
+def _validate_contract(contract: Mapping[str, Any]) -> None:
+    required = {
+        "contract_version",
+        "source_policy",
+        "thresholds",
+        "slow_model_policy",
+        "artifact_contract",
+        "page_scores",
+        "key_regions",
+        "evidence_paths",
+    }
+    missing = sorted(required - set(contract))
+    if missing:
+        raise VisualSimilarityGateError(f"missing visual similarity contract fields: {missing}")
+    if str(contract.get("contract_version") or "") != VISUAL_SIMILARITY_GATE_VERSION:
+        raise VisualSimilarityGateError("unsupported visual similarity contract_version")
+    source_policy = contract.get("source_policy") if isinstance(contract.get("source_policy"), Mapping) else {}
+    if int(source_policy.get("visual_similarity_weight") or 0) != VISUAL_SIMILARITY_DIMENSION_WEIGHT:
+        raise VisualSimilarityGateError("visual_similarity_weight must remain 17 in the 95-point route")
+
+
+def _coerce_thresholds(payload: object) -> dict[str, float]:
+    thresholds = dict(DEFAULT_THRESHOLDS)
+    if isinstance(payload, Mapping):
+        for key in DEFAULT_THRESHOLDS:
+            if key in payload:
+                thresholds[key] = float(payload[key])
+    return thresholds
+
+
+def _load_render_pair_artifact(contract: Mapping[str, Any]) -> Mapping[str, Any]:
+    inline_payload = contract.get("render_pair_artifact")
+    if isinstance(inline_payload, Mapping):
+        return inline_payload
+    path_value = str(contract.get("render_pair_artifact_path") or "").strip()
+    if not path_value:
+        return {}
+    path = Path(path_value).expanduser().resolve()
+    if not path.exists():
+        return {"status": "missing", "ok": False, "failure_code": "render_pair_artifact_missing"}
+    try:
+        payload = json.loads(path.read_text(encoding="utf-8"))
+    except Exception as exc:  # pragma: no cover
+        return {"status": "invalid", "ok": False, "failure_code": f"render_pair_artifact_unreadable:{exc}"}
+    return payload if isinstance(payload, Mapping) else {"status": "invalid", "ok": False, "failure_code": "render_pair_artifact_not_object"}
+
+
+def _build_artifact_contract(contract: Mapping[str, Any]) -> dict[str, Any]:
+    artifact_contract = contract.get("artifact_contract")
+    if isinstance(artifact_contract, Mapping):
+        return dict(artifact_contract)
+    return {
+        "required_artifacts": [
+            "render_pair.json",
+            "visual_similarity.json",
+            "fidelity_veto.json",
+            "human_review_report.json",
+        ],
+        "required_fields": [
+            "report_type",
+            "contract_version",
+            "status",
+            "failure_code",
+            "mode_boundary",
+            "score_contract",
+            "thresholds",
+            "render_pairs",
+            "page_scores",
+            "key_regions",
+            "vetoes",
+            "subject_page_type",
+            "human_review_required",
+            "evidence_paths",
+            "slow_model_review",
+        ],
+    }
+
+
+def _normalize_paths(payload: object) -> dict[str, Any]:
+    if not isinstance(payload, Mapping):
+        return {}
+    return {str(key): value for key, value in payload.items()}
+
+
+def _normalize_slow_model_policy(payload: object) -> dict[str, Any]:
+    if not isinstance(payload, Mapping):
+        return {
+            "candidate_models": ["qwen3_vl_8b"],
+            "disallowed_modes": ["fast", "balanced", DEFAULT_SYNC_MODE],
+            "fallback_action": "manual_review",
+        }
+    return {
+        "candidate_models": list(payload.get("candidate_models") or ["qwen3_vl_8b"]),
+        "disallowed_modes": list(payload.get("disallowed_modes") or ["fast", "balanced", DEFAULT_SYNC_MODE]),
+        "fallback_action": str(payload.get("fallback_action") or "manual_review"),
+    }
+
+
+def _build_page_scores(raw_scores: Sequence[object], render_pairs: Sequence[object]) -> list[dict[str, Any]]:
+    if not raw_scores:
+        return [
+            {
+                "page_index": int(pair.get("page_index") or 0),
+                "pair_status": str(pair.get("pair_status") or "unknown"),
+                "page_role": "critical",
+                "page_render_similarity": None,
+                "review_required": True,
+                "review_reasons": ["page_score_missing"],
+            }
+            for pair in render_pairs
+            if isinstance(pair, Mapping)
+        ]
+    page_scores: list[dict[str, Any]] = []
+    for item in raw_scores:
+        if not isinstance(item, Mapping):
+            continue
+        page_scores.append(
+            {
+                "page_index": int(item.get("page_index") or 0),
+                "pair_status": str(item.get("pair_status") or "unknown"),
+                "page_role": str(item.get("page_role") or "critical"),
+                "page_render_similarity": item.get("page_render_similarity"),
+                "review_required": bool(item.get("review_required", True)),
+                "review_reasons": list(item.get("review_reasons") or []),
+            }
+        )
+    return page_scores
+
+
+def _build_key_regions(raw_regions: Sequence[object]) -> list[dict[str, Any]]:
+    key_regions: list[dict[str, Any]] = []
+    for item in raw_regions:
+        if not isinstance(item, Mapping):
+            continue
+        key_regions.append(
+            {
+                "page_index": int(item.get("page_index") or 0),
+                "region_kind": str(item.get("region_kind") or "unknown"),
+                "region_label": str(item.get("region_label") or ""),
+                "region_similarity": item.get("region_similarity"),
+                "review_required": bool(item.get("review_required", True)),
+            }
+        )
+    return key_regions
+
+
+def _build_aggregate(
+    page_scores: Sequence[Mapping[str, Any]],
+    key_regions: Sequence[Mapping[str, Any]],
+    render_pairs: Sequence[object],
+) -> dict[str, Any]:
+    numeric_scores = [
+        float(item["page_render_similarity"])
+        for item in page_scores
+        if item.get("page_render_similarity") not in (None, "")
+    ]
+    return {
+        "render_pair_count": len(render_pairs),
+        "page_score_count": len(page_scores),
+        "key_region_count": len(key_regions),
+        "render_pair_ready_page_count": sum(
+            1 for pair in render_pairs if isinstance(pair, Mapping) and str(pair.get("pair_status") or "") == "matched"
+        ),
+        "overall_page_similarity_mean": round(sum(numeric_scores) / len(numeric_scores), 4) if numeric_scores else None,
+    }
+
+
+def _normalize_mode(requested_mode: str | None) -> str:
+    return str(requested_mode or "").strip().lower()

