{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-agent-teams.local/tasks/task.schema.json",
  "title": "Phase 1 Task Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "assigned_agent",
    "review_required",
    "reviewer",
    "test_required",
    "status",
    "task_level",
    "owner_pm",
    "domain",
    "write_scope",
    "depends_on",
    "blocks",
    "artifacts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "dispatched",
        "working",
        "ready_for_merge",
        "done",
        "failed",
        "timeout",
        "blocked",
        "cancelled"
      ]
    },
    "task_level": {
      "type": "string",
      "enum": [
        "execution",
        "review",
        "integration",
        "coordination",
        "domain",
        "epic"
      ]
    },
    "owner_pm": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "write_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "root_request_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "integration_owner": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "workspace_mode": {
      "type": "string",
      "enum": [
        "main",
        "worktree"
      ]
    },
    "worktree_path": {
      "type": "string"
    },
    "task_branch": {
      "type": "string"
    },
    "target_branch": {
      "type": "string"
    },
    "base_branch": {
      "type": "string"
    },
    "base_commit": {
      "type": "string"
    },
    "contract_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "last_error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "assigned_agent": {
      "type": "string",
      "minLength": 1
    },
    "review_required": {
      "type": "boolean"
    },
    "reviewer": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "test_required": {
      "type": "boolean"
    },
    "timeout_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "lease_owner": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "lease_acquired_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "lease_expires_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
