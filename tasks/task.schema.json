{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-agent-teams.local/tasks/task.schema.json",
  "title": "Phase 1 Task Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "project",
    "execution_mode",
    "target_environment",
    "assigned_agent",
    "review_required",
    "review_authority",
    "reviewer",
    "review_round",
    "max_review_rounds",
    "test_required",
    "status",
    "task_level",
    "owner_pm",
    "domain",
    "write_scope",
    "depends_on",
    "blocks",
    "artifacts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "必须使用不含空格且包含中文的标题式名称，例如 修复Word生成质量问题。",
      "allOf": [
        {
          "pattern": "^[^/\\\\\\s]+$"
        },
        {
          "pattern": ".*[\u4e00-\u9fff].*"
        }
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "dispatched",
        "working",
        "ready_for_merge",
        "done",
        "failed",
        "timeout",
        "blocked",
        "cancelled"
      ]
    },
    "task_level": {
      "type": "string",
      "enum": [
        "execution",
        "review",
        "integration",
        "coordination",
        "domain",
        "epic"
      ]
    },
    "owner_pm": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "write_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "root_request_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "integration_owner": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "workspace_mode": {
      "type": "string",
      "enum": [
        "main",
        "worktree"
      ]
    },
    "worktree_path": {
      "type": "string"
    },
    "task_branch": {
      "type": "string"
    },
    "target_branch": {
      "type": "string"
    },
    "base_branch": {
      "type": "string"
    },
    "base_commit": {
      "type": "string"
    },
    "contract_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "last_error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "assigned_agent": {
      "type": "string",
      "minLength": 1
    },
    "review_required": {
      "type": "boolean"
    },
    "reviewer": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "test_required": {
      "type": "boolean"
    },
    "timeout_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "lease_owner": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "lease_acquired_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "lease_expires_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "review_authority": {
      "type": "string",
      "enum": [
        "reviewer",
        "owner"
      ],
      "default": "reviewer"
    },
    "review_round": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "max_review_rounds": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "dev",
        "deploy"
      ]
    },
    "target_environment": {
      "type": "string",
      "enum": [
        "dev",
        "prod"
      ]
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
