+from __future__ import annotations
+
+import copy
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.image_dense_visual_gate import (
+    IMAGE_DENSE_ARTIFACT_REQUIRED_FIELDS,
+    IMAGE_DENSE_VISUAL_GATE_VERSION,
+    QUALITY_HYBRID_ASYNC_MODE,
+    ImageDenseVisualGateError,
+    build_image_dense_visual_gate_report,
+    load_image_dense_visual_contract,
+    resolve_image_dense_visual_mode,
+    write_image_dense_visual_gate_artifact,
+)
+
+
+FIXTURE_DIR = Path(__file__).parent / 'fixtures' / 'pdf_to_word' / 'visual_similarity' / 'image_dense'
+CONTRACT_PATH = FIXTURE_DIR / 'image_dense_visual_contract.json'
+RENDER_PAIR_PATH = FIXTURE_DIR / 'image_dense_render_pair.json'
+PLACEHOLDER = '__FIXTURE_ROOT__'
+
+
+def _load_json(path: Path) -> dict:
+    return json.loads(path.read_text(encoding='utf-8'))
+
+
+def _replace_placeholders(payload, *, root: Path):
+    if isinstance(payload, dict):
+        return {key: _replace_placeholders(value, root=root) for key, value in payload.items()}
+    if isinstance(payload, list):
+        return [_replace_placeholders(value, root=root) for value in payload]
+    if isinstance(payload, str):
+        return payload.replace(PLACEHOLDER, root.as_posix())
+    return payload
+
+
+def _iter_fixture_paths(payload, *, root: Path, parent_key: str = ''):
+    if isinstance(payload, dict):
+        for key, value in payload.items():
+            yield from _iter_fixture_paths(value, root=root, parent_key=key)
+        return
+    if isinstance(payload, list):
+        for value in payload:
+            yield from _iter_fixture_paths(value, root=root, parent_key=parent_key)
+        return
+    if isinstance(payload, str) and payload.startswith(root.as_posix()):
+        yield parent_key, Path(payload)
+
+
+def _ensure_fixture_path(parent_key: str, path: Path) -> None:
+    if parent_key.endswith('_dir') or parent_key == 'output_root':
+        path.mkdir(parents=True, exist_ok=True)
+        return
+    path.parent.mkdir(parents=True, exist_ok=True)
+    if path.exists():
+        return
+    if path.suffix == '.json':
+        path.write_text('{}\n', encoding='utf-8')
+    elif path.suffix in {'.html', '.md', '.txt', '.pdf'}:
+        path.write_text(f'fixture:{path.name}\n', encoding='utf-8')
+    else:
+        path.write_bytes(b'fixture')
+
+
+def _materialize_contract(tmp_path: Path) -> dict:
+    contract = _replace_placeholders(_load_json(CONTRACT_PATH), root=tmp_path)
+    render_pair_payload = _replace_placeholders(_load_json(RENDER_PAIR_PATH), root=tmp_path)
+    render_pair_path = Path(contract['render_pair_artifact_path'])
+    render_pair_path.parent.mkdir(parents=True, exist_ok=True)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+
+    for parent_key, path in _iter_fixture_paths(contract, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    for parent_key, path in _iter_fixture_paths(render_pair_payload, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return contract
+
+
+def test_fixture_freezes_image_dense_visual_contract_shape():
+    contract = load_image_dense_visual_contract(CONTRACT_PATH)
+
+    assert contract['contract_version'] == IMAGE_DENSE_VISUAL_GATE_VERSION
+    assert contract['source_policy']['image_dense_rules_generalized'] is True
+    assert contract['source_policy']['requires_visual_diff_debug'] is True
+    assert set(IMAGE_DENSE_ARTIFACT_REQUIRED_FIELDS) <= set(contract['artifact_contract']['required_fields'])
+    assert {'image_crop', 'question_order', 'graphic_binding'} <= set(contract['artifact_contract']['required_focus_tags'])
+    assert contract['render_pair_artifact_path'].endswith('image_dense_render_pair.json')
+
+
+def test_default_sync_does_not_count_image_dense_score(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='balanced', parser_backend='apple')
+
+    assert report['mode_boundary']['resolved_gate_mode'] == 'default_sync'
+    assert report['mode_boundary']['enabled'] is False
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['status'] == 'ready'
+    assert report['score_contract']['enters_95_total_score'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['score_contract']['skipped_score_reason'] == 'default_sync_excludes_image_dense_visual_dimension'
+
+
+def test_quality_ready_image_dense_contract_emits_order_binding_and_crop_evidence(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='quality', parser_backend='hybrid_experimental')
+    artifact_path = write_image_dense_visual_gate_artifact(report, tmp_path / 'artifacts' / 'image_dense_visual_gate.json')
+
+    assert report['mode_boundary']['resolved_gate_mode'] == QUALITY_HYBRID_ASYNC_MODE
+    assert report['status'] == 'ready'
+    assert report['failure_code'] is None
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['score_contract']['score_awarded'] == 1
+    assert len(report['render_pairs']) == 2
+    assert report['aggregate']['image_region_count'] == 2
+    assert report['aggregate']['question_order_check_count'] == 1
+    assert report['human_review_required'] is True
+    assert any(reason.startswith('near_threshold_') for reason in report['human_review_reasons'])
+    assert report['downstream_visual_similarity_contract']['document_page_type'] == 'image_dense_exam_paper'
+    assert len(report['downstream_visual_similarity_contract']['key_regions']) == 2
+    assert report['downstream_visual_similarity_contract']['key_regions'][0]['docx_crop_path'].endswith('math-dense-p1-image-docx.png')
+    assert Path(report['evidence_paths']['render_pair_artifact_path']).exists()
+    assert artifact_path.exists()
+
+
+def test_question_order_regression_triggers_blocking_veto(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+    contract['pages'][0]['question_order']['sequence_similarity'] = 0.71
+    contract['pages'][0]['question_order']['detected_question_ids'] = ['q2', 'q1', 'q3']
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'failed'
+    assert report['failure_code'] == 'image_dense_visual_veto_triggered'
+    assert report['artifact_ready_for_scoring'] is True
+    assert any(veto['code'] == 'question_order_similarity_below_threshold' for veto in report['vetoes'])
+    assert any(veto['code'] == 'question_order_sequence_mismatch' for veto in report['vetoes'])
+
+
+def test_missing_binding_pairs_on_binding_focus_page_is_not_ready(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+    contract['pages'][0]['question_order']['binding_pairs'] = []
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'artifact_not_ready'
+    assert report['artifact_ready_for_scoring'] is False
+    assert report['failure_code'] == 'binding_pairs_missing'
+    assert 'binding_pairs_missing:p1' in report['vetoes'][0]['details']
+
+
+def test_binding_regression_is_not_hidden_by_other_scores(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+    contract['pages'][0]['image_regions'][0]['binding_iou'] = 0.62
+    contract['pages'][0]['question_order']['binding_pairs'][0]['binding_iou'] = 0.62
+    contract['pages'][0]['question_order']['binding_pairs'][0]['bound'] = False
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'failed'
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['artifact_ready_for_scoring'] is True
+    assert 'image_question_binding_below_threshold' in report['downstream_visual_similarity_contract']['veto_forwarding_codes']
+    assert any(veto['code'] == 'image_question_binding_below_threshold' for veto in report['vetoes'])
+
+
+def test_image_crop_regression_triggers_veto(tmp_path: Path):
+    contract = _materialize_contract(tmp_path)
+    contract['pages'][1]['image_regions'][0]['region_similarity'] = 0.74
+
+    report = build_image_dense_visual_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'failed'
+    assert any(veto['code'] == 'image_region_similarity_below_threshold' for veto in report['vetoes'])
+
+
+def test_contract_validation_rejects_non_generalized_rules():
+    broken = _load_json(CONTRACT_PATH)
+    broken['source_policy']['image_dense_rules_generalized'] = False
+
+    try:
+        build_image_dense_visual_gate_report(broken, requested_mode='quality')
+    except ImageDenseVisualGateError as exc:
+        assert 'image_dense_rules_generalized' in str(exc)
+    else:  # pragma: no cover
+        raise AssertionError('expected ImageDenseVisualGateError')
+
+
+def test_mode_normalization_keeps_only_quality_paths_in_image_dense_route():
+    assert resolve_image_dense_visual_mode('quality') == QUALITY_HYBRID_ASYNC_MODE
+    assert resolve_image_dense_visual_mode('hybrid_async') == QUALITY_HYBRID_ASYNC_MODE
+    assert resolve_image_dense_visual_mode('balanced', parser_backend='apple') == 'default_sync'
+    assert resolve_image_dense_visual_mode('fast', parser_backend='hybrid_experimental') == 'default_sync'

