+        for cell_match in re.finditer(r"<t[dh]\\b[^>]*>(.*?)</t[dh]>", row_match.group(1), flags=re.IGNORECASE | re.DOTALL):
+            cell_text = re.sub(r"<[^>]+>", "", cell_match.group(1))
+            cells.append(" ".join(cell_text.split()))
+        if cells:
