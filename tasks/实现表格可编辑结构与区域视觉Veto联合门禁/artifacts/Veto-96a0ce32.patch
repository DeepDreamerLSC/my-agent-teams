+def build_table_editable_visual_gate_result(
+    table: NormalizedTableIR,
+    *,
+    sample_name: str | None = None,
+    subject: str | None = None,
+    document_page_type: str | None = None,
+    visual_regions: Sequence[Mapping[str, Any]] | None = None,
+    visual_vetoes: Sequence[Mapping[str, Any]] | None = None,
+    evidence_paths: Mapping[str, Any] | None = None,
+    region_similarity_min: float = DEFAULT_TABLE_REGION_SIMILARITY_MIN,
+) -> TableEditableVisualGateResult:
+    structure_report = validate_normalized_table_ir(table)
+    blocking_failures: list[str] = []
+    vetoes: list[dict[str, Any]] = []
+    visual_region_reports: list[dict[str, Any]] = []
+    human_review_required = False
+
+    if structure_report.status != "pass":
+        human_review_required = True
+        if structure_report.status == "fail":
+            blocking_failures.append("table_structure_contract_failed")
+        else:
+            blocking_failures.append("table_structure_contract_review")
+
+    normalized_regions = [item for item in (visual_regions or ()) if isinstance(item, Mapping)]
+    if not normalized_regions:
+        blocking_failures.append(WARN_TABLE_VISUAL_REGIONS_MISSING)
+        human_review_required = True
+    else:
+        for index, raw_region in enumerate(normalized_regions):
+            region_payload, region_failures, region_vetoes = _build_table_visual_region_report(
+                raw_region,
+                index=index,
+                similarity_min=region_similarity_min,
+            )
+            visual_region_reports.append(region_payload)
+            vetoes.extend(region_vetoes)
+            if region_failures:
+                blocking_failures.extend(region_failures)
+                human_review_required = True
+
+    for raw_veto in visual_vetoes or ():
+        veto_payload = _coerce_table_visual_veto(raw_veto)
+        if veto_payload is None:
+            continue
+        vetoes.append(veto_payload)
+        if veto_payload.get("blocking"):
+            blocking_failures.append(str(veto_payload.get("code") or "table_visual_veto_triggered"))
+            human_review_required = True
+
+    blocking_vetoes = [item for item in vetoes if item.get("blocking")]
+    if structure_report.status == "fail" or blocking_vetoes:
+        status = "failed"
+        failure_code = _first_failure_code(blocking_failures) or "table_visual_veto_triggered"
+    elif blocking_failures:
+        status = "artifact_not_ready"
+        failure_code = _first_failure_code(blocking_failures)
+    else:
+        status = "ready"
+        failure_code = None
+
+    editable_contract = {
+        "structured_cells_required": True,
+        "visual_region_veto_required": True,
+        "has_structured_cells": table.has_structured_cells,
+        "table_xml_only_is_insufficient": True,
+        "raw_visual_fallback_present": table.raw.has_visual_fallback,
+        "row_count": table.row_count,
+        "column_count": table.column_count,
+        "cell_count": len(table.cells),
+    }
+    structure_gate = {
+        "status": structure_report.status,
+        "passable": structure_report.passable,
+        "errors": list(structure_report.errors),
+        "warnings": list(structure_report.warnings),
+        "inferred_row_count": structure_report.inferred_row_count,
+        "inferred_column_count": structure_report.inferred_column_count,
+        "has_structured_cells": structure_report.has_structured_cells,
+    }
+    normalized_evidence_paths = {
+        str(key): value for key, value in (evidence_paths or {}).items()
+    }
+    if table.raw.image_path and "table_image_path" not in normalized_evidence_paths:
+        normalized_evidence_paths["table_image_path"] = table.raw.image_path
+
+    return TableEditableVisualGateResult(
+        report_type=TABLE_EDITABLE_VISUAL_GATE_REPORT_TYPE,
+        contract_version=TABLE_EDITABLE_VISUAL_GATE_VERSION,
+        status=status,
+        failure_code=failure_code,
+        gate_passed=status == "ready",
+        human_review_required=human_review_required,
+        sample_name=_optional_str(sample_name),
+        subject=_optional_str(subject),
+        document_page_type=_optional_str(document_page_type),
+        table_id=table.table_id,
+        source_candidate_id=table.source_candidate_id,
+        structure_gate=structure_gate,
+        visual_regions=tuple(visual_region_reports),
+        vetoes=tuple(vetoes),
+        blocking_failures=tuple(_unique(blocking_failures)),
+        editable_contract=editable_contract,
+        evidence_paths=normalized_evidence_paths,
