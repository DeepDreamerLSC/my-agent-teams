+                row_index=_int_value(item.get("row_index")),
+                column_index=_int_value(item.get("column_index")),
+                row_span=_int_value(item.get("row_span"), default=1),
+                column_span=_int_value(item.get("column_span"), default=1),
+                text=str(item.get("text") or item.get("content") or ""),
+                runs=_coerce_payload_runs(item.get("runs"), context=f"table payload.cells[{index}].runs", text_fallback=item.get("text") or item.get("content")),
+                bbox=_page_box_from_dict(item.get("bbox")) or bbox,
+                confidence=_float_value(item.get("confidence", 1.0), default=1.0),
