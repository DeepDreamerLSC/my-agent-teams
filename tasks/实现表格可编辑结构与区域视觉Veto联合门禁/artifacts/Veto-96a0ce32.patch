+def _coerce_table_visual_veto(raw_veto: Any) -> dict[str, Any] | None:
+    if not isinstance(raw_veto, Mapping):
+        return None
+    return {
+        "code": str(raw_veto.get("code") or "table_visual_veto"),
+        "severity": str(raw_veto.get("severity") or "p0"),
+        "scope": str(raw_veto.get("scope") or "region"),
+        "blocking": bool(raw_veto.get("blocking", True)),
+        "region_id": _optional_str(raw_veto.get("region_id")),
+        "page_index": _optional_int(raw_veto.get("page_index")),
+        "summary": str(raw_veto.get("summary") or raw_veto.get("reason") or "table visual veto triggered"),
+        "evidence_paths": [
+            str(item) for item in _sequence(raw_veto.get("evidence_paths"), "table_visual_veto.evidence_paths")
+        ]
+        if raw_veto.get("evidence_paths") is not None
+        else [],
+    }
+
