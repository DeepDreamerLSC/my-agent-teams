+def _rows_from_table_ir(table: NormalizedTableIR) -> list[list[str]] | None:
+    if table.row_count <= 0 or table.column_count <= 0:
+        return None
+    rows = [["" for _ in range(table.column_count)] for _ in range(table.row_count)]
+    for cell in table.cells:
+        if cell.row_index < 0 or cell.column_index < 0:
+            continue
+        if cell.row_index >= table.row_count or cell.column_index >= table.column_count:
+            continue
+        rows[cell.row_index][cell.column_index] = _normalize_text(cell.text)
+    return rows
+
+
