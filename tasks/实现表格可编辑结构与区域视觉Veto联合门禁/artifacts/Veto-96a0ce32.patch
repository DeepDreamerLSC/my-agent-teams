+def _build_table_visual_region_report(
+    raw_region: Mapping[str, Any],
+    *,
+    index: int,
+    similarity_min: float,
+) -> tuple[dict[str, Any], list[str], list[dict[str, Any]]]:
+    region_id = str(raw_region.get("region_id") or f"table-region-{index + 1:02d}")
+    evidence = {
+        "source_crop_path": _optional_str(raw_region.get("source_crop_path")),
+        "docx_crop_path": _optional_str(raw_region.get("docx_crop_path")),
+        "diff_image_path": _optional_str(raw_region.get("diff_image_path")),
+    }
+    similarity = _optional_float(raw_region.get("similarity"))
+    failures: list[str] = []
+    vetoes: list[dict[str, Any]] = []
+    if similarity is None:
+        failures.append(f"{WARN_TABLE_REGION_SIMILARITY_MISSING}:{region_id}")
+    if not evidence["source_crop_path"] or not evidence["docx_crop_path"]:
+        failures.append(f"{WARN_TABLE_REGION_EVIDENCE_MISSING}:{region_id}")
+    passed = similarity is not None and similarity >= similarity_min and not failures
+    if similarity is not None and similarity < similarity_min:
+        failures.append(f"table_region_similarity_below_threshold:{region_id}")
+        vetoes.append(
+            {
+                "code": "table_region_similarity_below_threshold",
+                "severity": "p0",
+                "scope": "region",
+                "blocking": True,
+                "region_id": region_id,
+                "page_index": _optional_int(raw_region.get("page_index")),
+                "summary": (
+                    f"table region similarity {similarity:.4f} below {similarity_min:.4f} for {region_id}"
+                ),
+                "evidence_paths": [path for path in evidence.values() if path],
+            }
+        )
+    payload = {
+        "region_id": region_id,
+        "page_index": _optional_int(raw_region.get("page_index")),
+        "role": _optional_str(raw_region.get("role")) or "table_region",
+        "bbox": _page_box_to_dict(raw_region.get("bbox")),
+        "similarity": similarity,
+        "similarity_min": similarity_min,
+        "passed": passed,
+        "evidence": evidence,
+        "warnings": list(failures),
+    }
+    return payload, failures, vetoes
+
