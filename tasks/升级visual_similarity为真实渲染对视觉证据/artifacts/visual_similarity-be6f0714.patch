+from __future__ import annotations
+
+import copy
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.visual_similarity_gate import (
+    ALLOWED_REGION_TYPES,
+    ALLOWED_SUBJECT_PAGE_TYPES,
+    ARTIFACT_REQUIRED_FIELDS,
+    QUALITY_HYBRID_ASYNC_MODE,
+    VISUAL_SIMILARITY_DIMENSION_KEY,
+    VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+    VISUAL_SIMILARITY_GATE_VERSION,
+    VisualSimilarityGateError,
+    build_visual_similarity_gate_report,
+    load_visual_similarity_contract,
+    resolve_visual_gate_mode,
+    write_visual_similarity_gate_artifact,
+)
+
+FIXTURE_DIR = Path(__file__).parent / 'fixtures' / 'pdf_to_word' / 'visual_similarity'
+CONTRACT_ONLY_PATH = FIXTURE_DIR / 'visual_similarity_contract.json'
+QUALITY_READY_PATH = FIXTURE_DIR / 'quality_ready_contract.json'
+QUALITY_READY_RENDER_PAIR_PATH = FIXTURE_DIR / 'quality_ready_render_pair.json'
+PLACEHOLDER = '__FIXTURE_ROOT__'
+
+
+def _load_json(path: Path) -> dict:
+    return json.loads(path.read_text(encoding='utf-8'))
+
+
+def _replace_placeholders(payload, *, root: Path):
+    if isinstance(payload, dict):
+        return {key: _replace_placeholders(value, root=root) for key, value in payload.items()}
+    if isinstance(payload, list):
+        return [_replace_placeholders(value, root=root) for value in payload]
+    if isinstance(payload, str):
+        return payload.replace(PLACEHOLDER, root.as_posix())
+    return payload
+
+
+def _iter_fixture_paths(payload, *, root: Path, parent_key: str = ''):
+    if isinstance(payload, dict):
+        for key, value in payload.items():
+            yield from _iter_fixture_paths(value, root=root, parent_key=key)
+        return
+    if isinstance(payload, list):
+        for value in payload:
+            yield from _iter_fixture_paths(value, root=root, parent_key=parent_key)
+        return
+    if isinstance(payload, str) and payload.startswith(root.as_posix()):
+        yield parent_key, Path(payload)
+
+
+def _ensure_fixture_path(parent_key: str, path: Path) -> None:
+    if parent_key.endswith('_dir') or parent_key == 'output_root':
+        path.mkdir(parents=True, exist_ok=True)
+        return
+    path.parent.mkdir(parents=True, exist_ok=True)
+    if path.exists():
+        return
+    if path.suffix == '.json':
+        path.write_text('{}\n', encoding='utf-8')
+    elif path.suffix in {'.html', '.md', '.txt', '.pdf'}:
+        path.write_text(f'fixture:{path.name}\n', encoding='utf-8')
+    else:
+        path.write_bytes(b'fixture')
+
+
+def _materialize_quality_ready_contract(tmp_path: Path) -> dict:
+    contract = _replace_placeholders(_load_json(QUALITY_READY_PATH), root=tmp_path)
+    render_pair_payload = _replace_placeholders(_load_json(QUALITY_READY_RENDER_PAIR_PATH), root=tmp_path)
+    render_pair_path = Path(contract['render_pair_artifact_path'])
+    render_pair_path.parent.mkdir(parents=True, exist_ok=True)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+
+    for parent_key, path in _iter_fixture_paths(contract, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    for parent_key, path in _iter_fixture_paths(render_pair_payload, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return contract
+
+
+def _materialize_contract_only(tmp_path: Path) -> dict:
+    contract = _replace_placeholders(_load_json(CONTRACT_ONLY_PATH), root=tmp_path)
+    for parent_key, path in _iter_fixture_paths(contract, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    return contract
+
+
+def test_fixture_freezes_real_visual_evidence_contract_shape():
+    quality_contract = load_visual_similarity_contract(QUALITY_READY_PATH)
+    contract_only = load_visual_similarity_contract(CONTRACT_ONLY_PATH)
+
+    assert quality_contract['contract_version'] == VISUAL_SIMILARITY_GATE_VERSION
+    assert quality_contract['source_policy']['visual_similarity_weight'] == VISUAL_SIMILARITY_DIMENSION_WEIGHT
+    assert quality_contract['source_policy']['target_total_score_threshold'] == 95
+    assert set(ARTIFACT_REQUIRED_FIELDS) <= set(quality_contract['artifact_contract']['required_fields'])
+    assert set(ALLOWED_SUBJECT_PAGE_TYPES) <= set(quality_contract['artifact_contract']['allowed_subject_page_types'])
+    assert {'table', 'image', 'options', 'answer_area', 'reading', 'formula_graphic', 'question_backbone'} <= set(
+        quality_contract['artifact_contract']['allowed_region_types']
+    )
+    assert quality_contract['render_pair_artifact_path'].endswith('quality_ready_render_pair.json')
+    assert contract_only['implementation_status'] == 'contract_only_render_pair_missing'
+    assert contract_only.get('render_pair_artifact_path') in (None, '')
+
+
+def test_default_sync_never_counts_visual_similarity_score_even_with_real_render_pairs(tmp_path: Path):
+    contract = _materialize_quality_ready_contract(tmp_path)
+
+    report = build_visual_similarity_gate_report(contract, requested_mode='balanced', parser_backend='apple')
+
+    assert report['mode_boundary']['resolved_gate_mode'] == 'default_sync'
+    assert report['mode_boundary']['enabled'] is False
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['status'] == 'ready'
+    assert report['score_contract']['dimension_key'] == VISUAL_SIMILARITY_DIMENSION_KEY
+    assert report['score_contract']['enters_95_total_score'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['score_contract']['skipped_score_reason'] == 'default_sync_excludes_visual_similarity_dimension'
+
+
+def test_quality_ready_contract_emits_traceable_render_pairs_and_required_fields(tmp_path: Path):
+    contract = _materialize_quality_ready_contract(tmp_path)
+
+    report = build_visual_similarity_gate_report(contract, requested_mode='quality', parser_backend='hybrid_experimental')
+    artifact_path = write_visual_similarity_gate_artifact(report, tmp_path / 'artifacts' / 'visual_similarity.json')
+
+    assert report['mode_boundary']['resolved_gate_mode'] == QUALITY_HYBRID_ASYNC_MODE
+    assert report['mode_boundary']['enabled'] is True
+    assert report['status'] == 'ready'
+    assert report['failure_code'] is None
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['score_contract']['score_awarded'] == 17
+    assert set(contract['artifact_contract']['required_fields']) <= set(report)
+    assert len(report['render_pairs']) == 2
+    assert len(report['page_scores']) == 2
+    assert len(report['key_regions']) == 3
+    assert report['aggregate']['matched_render_pair_count'] == 2
+    assert report['aggregate']['overall_page_similarity_mean'] >= contract['thresholds']['document_overall_similarity_min']
+    assert report['human_review_required'] is True
+    assert any(reason.startswith('near_threshold_region_similarity:') for reason in report['human_review_reasons'])
+    assert Path(report['evidence_paths']['render_pair_artifact_path']).exists()
+    assert artifact_path.exists()
+    assert json.loads(artifact_path.read_text(encoding='utf-8'))['status'] == 'ready'
+
+
+def test_contract_only_artifact_is_not_scorable_without_real_render_pair(tmp_path: Path):
+    contract = _materialize_contract_only(tmp_path)
+
+    report = build_visual_similarity_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'artifact_not_ready'
+    assert report['failure_code'] == 'visual_similarity_artifact_not_ready'
+    assert report['artifact_ready_for_scoring'] is False
+    assert report['score_contract']['enters_95_total_score'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert report['human_review_required'] is True
+    assert report['vetoes'][0]['code'] == 'visual_similarity_artifact_not_ready'
+    assert 'render_pair_artifact_missing' in report['vetoes'][0]['details']
+
+
+def test_render_pair_status_mismatch_is_treated_as_not_ready(tmp_path: Path):
+    contract = _materialize_quality_ready_contract(tmp_path)
+    render_pair_path = Path(contract['render_pair_artifact_path'])
+    render_pair_payload = json.loads(render_pair_path.read_text(encoding='utf-8'))
+    render_pair_payload['status'] = 'page_count_mismatch'
+    render_pair_payload['ok'] = False
+    render_pair_payload['failure_code'] = 'page_count_mismatch'
+    render_pair_payload['render_pairs'][1]['pair_status'] = 'source_only'
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+
+    report = build_visual_similarity_gate_report(contract, requested_mode='quality')
+
+    assert report['status'] == 'artifact_not_ready'
+    assert report['failure_code'] == 'visual_similarity_artifact_not_ready'
+    assert report['artifact_ready_for_scoring'] is False
+    assert report['render_pair_failure_code'] == 'page_count_mismatch'
+    assert 'render_pair_status_not_success:page_count_mismatch' in report['vetoes'][0]['details']
+
+
+def test_required_key_region_below_threshold_triggers_veto_and_zero_score(tmp_path: Path):
+    contract = _materialize_quality_ready_contract(tmp_path)
+    failing = copy.deepcopy(contract)
+    failing['key_regions'][0]['region_similarity'] = 0.72
+
+    report = build_visual_similarity_gate_report(failing, requested_mode='quality')
+
+    assert report['status'] == 'failed'
+    assert report['failure_code'] == 'visual_similarity_veto_triggered'
+    assert report['artifact_ready_for_scoring'] is True
+    assert report['gate_passed'] is False
+    assert report['score_contract']['score_awarded'] == 0
+    assert any(veto['code'] == 'key_region_similarity_below_threshold' for veto in report['vetoes'])
+
+
+def test_contract_validation_rejects_invalid_subject_scope():
+    broken = _load_json(QUALITY_READY_PATH)
+    broken['artifact_contract']['allowed_subject_page_types'] = ['math']
+
+    try:
+        build_visual_similarity_gate_report(broken, requested_mode='quality')
+    except VisualSimilarityGateError as exc:
+        assert 'allowed_subject_page_types' in str(exc)
+    else:  # pragma: no cover - plain assertion path for import-only runners
+        raise AssertionError('expected VisualSimilarityGateError')
+
+
+def test_mode_normalization_keeps_only_quality_paths_in_visual_score_route():
+    assert resolve_visual_gate_mode('quality') == QUALITY_HYBRID_ASYNC_MODE
+    assert resolve_visual_gate_mode('hybrid_async') == QUALITY_HYBRID_ASYNC_MODE
+    assert resolve_visual_gate_mode('balanced', parser_backend='apple') == 'default_sync'
+    assert resolve_visual_gate_mode('fast', parser_backend='hybrid_experimental') == 'default_sync'
