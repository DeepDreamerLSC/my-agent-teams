+
+
+def _build_aggregate(
+    render_pairs: Sequence[object],
+    page_scores: Sequence[Mapping[str, Any]],
+    key_regions: Sequence[Mapping[str, Any]],
+    vetoes: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    similarity_values = [
+        float(page['page_render_similarity'])
+        for page in page_scores
+        if page.get('page_render_similarity') is not None
+    ]
+    return {
