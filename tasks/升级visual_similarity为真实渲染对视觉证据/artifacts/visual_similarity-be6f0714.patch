+def _make_veto(
+    *,
+    code: str,
+    scope: str,
+    severity: str,
+    reason: str,
+    blocking: bool,
+    page_index: int | None = None,
+    region_id: str | None = None,
+    details: Sequence[str] | None = None,
+) -> dict[str, Any]:
+    return {
+        'code': code,
+        'scope': scope,
+        'severity': severity,
+        'blocking': blocking,
+        'page_index': page_index,
+        'region_id': region_id,
+        'reason': reason,
+        'details': list(details or []),
+    }
+
+
+def _coerce_thresholds(payload: object) -> dict[str, float]:
+    thresholds = dict(DEFAULT_THRESHOLDS)
+    if isinstance(payload, Mapping):
+        for key in DEFAULT_THRESHOLDS:
+            if key in payload:
+                thresholds[key] = float(payload[key])
+    return thresholds
+
+
+def _normalize_subject_page_type(value: object, *, fallback: str) -> str:
+    normalized = str(value or '').strip()
+    return normalized if normalized in ALLOWED_SUBJECT_PAGE_TYPES else fallback
+
+
+def _normalize_mode(mode: str | None) -> str:
+    return str(mode or '').strip().lower()
+
+
+def _optional_float(value: object) -> float | None:
+    if value is None or value == '':
+        return None
+    return float(value)
+
+
+def _mean(values: Sequence[float]) -> float | None:
+    if not values:
+        return None
+    return round(sum(values) / len(values), 4)
