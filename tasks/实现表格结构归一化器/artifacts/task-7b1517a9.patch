+@dataclass(frozen=True)
+class _StructuredCellSpec:
+    text: str
+    row_span: int = 1
+    column_span: int = 1
+    runs: tuple[TableTextRun, ...] = ()
+    bbox: PageBox | None = None
+    confidence: float = 1.0
+    warnings: tuple[str, ...] = ()
+
+
+@dataclass(frozen=True)
+class _StructuredSource:
+    source: str
+    cells: tuple[TableCellIR, ...]
+    row_count: int
+    column_count: int
+
+
+@dataclass(frozen=True)
+class _CellBoxEntry:
+    text: str
+    bbox: PageBox
+    confidence: float
+    runs: tuple[TableTextRun, ...] = ()
+    warnings: tuple[str, ...] = ()
+
+    @property
+    def center_x(self) -> float:
+        return (self.bbox.x0 + self.bbox.x1) / 2.0
+
+    @property
+    def center_y(self) -> float:
+        return (self.bbox.y0 + self.bbox.y1) / 2.0
