+@dataclass(frozen=True)
+class _HTMLCellToken:
+    text: str
+    row_span: int = 1
+    column_span: int = 1
+
+
+class _HTMLTableParser(HTMLParser):
+    def __init__(self) -> None:
+        super().__init__(convert_charrefs=True)
+        self._table_depth = 0
+        self._active_table = False
+        self._current_row: list[_HTMLCellToken] | None = None
+        self._rows: list[list[_HTMLCellToken]] = []
+        self._current_cell_text: list[str] | None = None
+        self._current_cell_row_span = 1
+        self._current_cell_column_span = 1
+
+    @property
+    def rows(self) -> list[list[_HTMLCellToken]]:
+        return self._rows
+
+    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
+        normalized_tag = tag.lower()
+        if normalized_tag == "table":
+            self._table_depth += 1
+            if self._table_depth == 1:
+                self._active_table = True
+            return
+        if not self._active_table:
+            return
+        if normalized_tag == "tr":
+            self._current_row = []
+            return
+        if normalized_tag in {"td", "th"} and self._current_row is not None:
+            attributes = {key.lower(): value for key, value in attrs}
+            self._current_cell_text = []
+            self._current_cell_row_span = _safe_positive_int(attributes.get("rowspan"), default=1)
+            self._current_cell_column_span = _safe_positive_int(attributes.get("colspan"), default=1)
+            return
+        if normalized_tag == "br" and self._current_cell_text is not None:
+            self._current_cell_text.append("\n")
+
+    def handle_endtag(self, tag: str) -> None:
+        normalized_tag = tag.lower()
+        if normalized_tag == "table":
+            if self._table_depth == 1:
+                self._active_table = False
+            self._table_depth = max(self._table_depth - 1, 0)
+            return
+        if not self._active_table:
+            return
+        if normalized_tag in {"td", "th"} and self._current_row is not None and self._current_cell_text is not None:
+            text = _normalize_text("".join(self._current_cell_text))
+            self._current_row.append(
+                _HTMLCellToken(
+                    text=text,
+                    row_span=self._current_cell_row_span,
+                    column_span=self._current_cell_column_span,
+                )
+            )
+            self._current_cell_text = None
+            self._current_cell_row_span = 1
+            self._current_cell_column_span = 1
+            return
+        if normalized_tag == "tr" and self._current_row is not None:
+            if self._current_row:
+                self._rows.append(self._current_row)
+            self._current_row = None
+
+    def handle_data(self, data: str) -> None:
+        if self._active_table and self._current_cell_text is not None:
+            self._current_cell_text.append(data)
+
