+from __future__ import annotations
+
+from app.services.pdf_to_word.parser_adapters.table_structure_normalizer import (
+    REASON_OK,
+    REASON_TABLE_GRID_INCONSISTENT,
+    REASON_TABLE_STRUCTURE_MISSING,
+    TableStructureNormalizer,
+    normalize_table_structure,
+)
+from app.services.pdf_to_word.table_ir import (
+    WARN_IMAGE_ONLY_FALLBACK,
+    WARN_TABLE_GRID_INCOMPLETE,
+    WARN_TABLE_STRUCTURE_MISSING,
+)
+
+
+def _base_payload(**overrides):
+    payload = {
+        "table_id": "table:p1:candidate-001",
+        "source_candidate_id": "mineru_full:p1:b7",
+        "assigned_question_id": "q-1",
+        "assigned_region_id": "region:p1:q1",
+        "page_index": 1,
+        "bbox": {"page": 1, "x0": 80.0, "y0": 120.0, "x1": 480.0, "y1": 300.0},
+    }
+    payload.update(overrides)
+    return payload
+
+
+def test_html_source_has_highest_priority_and_preserves_spans():
+    payload = _base_payload(
+        table_html=(
+            "<table>"
+            "<tr><th colspan='2'>实验记录</th></tr>"
+            "<tr><td>项目</td><td>结果</td></tr>"
+            "</table>"
+        ),
+        table_rows=[["should", "not"], ["win", "priority"]],
+        markdown="| ignored | value |\n| --- | --- |\n| no | use |",
+    )
+
+    result = normalize_table_structure(payload)
+
+    assert result.source == "table_html"
+    assert result.status == "pass"
+    assert result.reason == REASON_OK
+    assert result.table_ir.row_count == 2
+    assert result.table_ir.column_count == 2
+    assert result.table_ir.cells[0].text == "实验记录"
+    assert result.table_ir.cells[0].column_span == 2
+
+
+def test_table_rows_source_supports_dict_cells_and_spans():
+    payload = _base_payload(
+        table_rows=[
+            [{"text": "实验记录", "column_span": 2}],
+            [
+                {"text": "项目", "style": {"bold": True}},
+                {"text": "结果", "confidence": 0.82},
+            ],
+        ]
+    )
+
+    result = TableStructureNormalizer().normalize(payload)
+
+    assert result.source == "table_rows"
+    assert result.status == "pass"
+    assert result.table_ir.row_count == 2
+    assert result.table_ir.column_count == 2
+    assert result.table_ir.cells[0].column_span == 2
+    assert result.table_ir.cells[1].runs[0].style.bold is True
+    assert result.table_ir.cells[2].confidence == 0.82
+
+
+def test_markdown_source_parses_pipe_table_when_html_and_rows_absent():
+    payload = _base_payload(
+        markdown="说明\n\n| 项目 | 结果 |\n| --- | --- |\n| 温度 | 20℃ |\n| 湿度 | 60% |"
+    )
+
+    result = normalize_table_structure(payload)
+
+    assert result.source == "markdown"
+    assert result.status == "pass"
+    assert result.table_ir.row_count == 3
+    assert result.table_ir.column_count == 2
+    assert [cell.text for cell in result.table_ir.cells[:2]] == ["项目", "结果"]
+
+
+def test_cell_boxes_source_clusters_geometry_and_merges_slot_text():
+    payload = _base_payload(
+        cell_boxes=[
+            {"bbox": {"page": 1, "x0": 80, "y0": 120, "x1": 180, "y1": 150}, "text": "项目"},
+            {"bbox": {"page": 1, "x0": 190, "y0": 120, "x1": 300, "y1": 150}, "text": "结果"},
+            {"bbox": {"page": 1, "x0": 80, "y0": 160, "x1": 180, "y1": 190}, "text": "温度"},
+            {"bbox": {"page": 1, "x0": 190, "y0": 160, "x1": 300, "y1": 174}, "text": "20"},
+            {"bbox": {"page": 1, "x0": 190, "y0": 176, "x1": 300, "y1": 190}, "text": "℃"},
+        ]
+    )
+
+    result = normalize_table_structure(payload)
+
+    assert result.source == "cell_boxes"
+    assert result.status == "pass"
+    assert result.table_ir.row_count == 2
+    assert result.table_ir.column_count == 2
+    assert result.table_ir.cells[-1].text == "20 ℃"
+
+
+def test_image_only_fallback_stays_review_and_never_fakes_structure():
+    payload = _base_payload(image_path="crops/page-1/table-like-001.png")
+
+    result = normalize_table_structure(payload)
+
+    assert result.source == "image_only"
+    assert result.status == "review"
+    assert result.reason == REASON_TABLE_STRUCTURE_MISSING
+    assert result.table_ir.cells == ()
+    assert WARN_TABLE_STRUCTURE_MISSING in result.warnings
+    assert WARN_IMAGE_ONLY_FALLBACK in result.warnings
+
+
+def test_irregular_rows_report_grid_inconsistency_instead_of_false_success():
+    payload = _base_payload(table_rows=[["项目", "结果"], ["温度"]])
+
+    result = normalize_table_structure(payload)
+
+    assert result.source == "table_rows"
+    assert result.status == "review"
+    assert result.reason == REASON_TABLE_GRID_INCONSISTENT
+    assert WARN_TABLE_GRID_INCOMPLETE in result.warnings
+    assert result.table_ir.row_count == 2
+    assert result.table_ir.column_count == 2
