+def _parse_filter_boundary(value: str | None, *, end_of_day: bool) -> datetime | None:
+    normalized = _normalize_date_string(value)
+    if normalized is None:
+        return None
+    tz = _local_timezone()
+    parsed_date = date.fromisoformat(normalized)
+    return datetime.combine(parsed_date, time.max if end_of_day else time.min, tz)
