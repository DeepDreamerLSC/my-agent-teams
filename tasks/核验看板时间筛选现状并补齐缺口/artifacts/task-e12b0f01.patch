+function formatLocalDateInput(date) {
+  if (!(date instanceof Date) || Number.isNaN(date.getTime())) return ''
+  const year = date.getFullYear()
+  const month = String(date.getMonth() + 1).padStart(2, '0')
+  const day = String(date.getDate()).padStart(2, '0')
+  return `${year}-${month}-${day}`
+}
+
+function buildDashboardTimeQuery(state = ganttFilterState, now = new Date()) {
+  const range = getGanttDateRange(state, now)
+  if (range.warning || (!range.start && !range.end)) {
+    return { range, query: '', params: {} }
+  }
+  const params = new URLSearchParams()
+  if (state.mode) {
+    params.set('range', state.mode)
+  }
+  if (range.start) {
+    params.set('start_date', formatLocalDateInput(range.start))
+  }
+  if (range.end) {
+    params.set('end_date', formatLocalDateInput(range.end))
+  }
+  return { range, query: `?${params.toString()}`, params: Object.fromEntries(params.entries()) }
+}
+
+function buildDashboardApiUrl(path, state = ganttFilterState, now = new Date()) {
