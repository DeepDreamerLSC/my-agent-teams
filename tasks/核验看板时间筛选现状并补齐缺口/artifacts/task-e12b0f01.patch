+def _resolve_time_filter_dates(
+    *,
+    time_range: str | None = None,
+    start_date: str | None = None,
+    end_date: str | None = None,
+) -> tuple[str | None, str | None, str | None]:
+    normalized_start = _normalize_date_string(start_date)
+    normalized_end = _normalize_date_string(end_date)
+    normalized_range = str(time_range or '').strip().lower() or None
+
+    if normalized_start or normalized_end:
+        return normalized_start, normalized_end, normalized_range or 'custom'
+
+    if normalized_range in (None, '', 'all'):
+        return None, None, 'all' if normalized_range == 'all' else normalized_range
+    if normalized_range not in SUPPORTED_TIME_RANGE_PRESETS:
+        return None, None, normalized_range
+
+    today = _local_today()
+    days_by_range = {
+        '24h': 1,
+        'today': 1,
+        '3d': 3,
+        '7d': 7,
+        '30d': 30,
+        '1m': 30,
+    }
+    if normalized_range == 'custom':
+        return None, None, normalized_range
+    days = days_by_range.get(normalized_range)
+    if days is None:
+        return None, None, normalized_range
+    resolved_start = (today - timedelta(days=days - 1)).isoformat()
+    return resolved_start, today.isoformat(), normalized_range
+
