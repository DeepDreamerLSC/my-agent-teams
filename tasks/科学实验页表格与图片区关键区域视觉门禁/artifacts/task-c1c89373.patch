+from __future__ import annotations
+
+import copy
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.science_visual_gate import (
+    SCIENCE_VISUAL_GATE_REPORT_TYPE,
+    evaluate_science_visual_gate,
+    load_science_visual_gate_payload,
+)
+
+
+FIXTURES_ROOT = Path(__file__).resolve().parent / 'fixtures' / 'pdf_to_word' / 'visual_similarity' / 'science'
+
+
+def _load_fixture(name: str) -> dict:
+    return load_science_visual_gate_payload(FIXTURES_ROOT / name)
+
+
+def test_science_visual_gate_scores_key_regions_for_science_experiment_page():
+    payload = _load_fixture('science_experiment_happy.json')
+
+    summary = evaluate_science_visual_gate(payload)
+
+    assert summary['report_type'] == SCIENCE_VISUAL_GATE_REPORT_TYPE
+    assert summary['status'] == 'ready'
+    assert summary['sample_name'] == '五下科学'
+    assert summary['document_page_type'] == 'science_experiment_table_and_image_mixed'
+    assert summary['overall_score'] >= 0.9
+    assert summary['human_review_required'] is False
+    assert summary['blockers'] == []
+    assert summary['vetoes'] == []
+    assert summary['key_region_scores']['table_min_score'] >= 0.9
+    assert summary['key_region_scores']['image_min_score'] >= 0.9
+    assert summary['key_region_scores']['experiment_record_min_score'] >= 0.88
+
+    page = summary['pages'][0]
+    assert page['status'] == 'ready'
+    assert page['score'] >= 0.9
+    relation_by_kind = {item['relation_kind']: item for item in page['relation_scores']}
+    assert relation_by_kind['table_prompt_adjacency']['score'] >= 0.9
+    assert relation_by_kind['image_prompt_binding']['score'] >= 0.9
+    assert relation_by_kind['experiment_record_adjacency']['score'] >= 0.88
+
+
+def test_science_visual_gate_identifies_table_and_record_adjacency_failure():
+    payload = _load_fixture('science_experiment_table_fail.json')
+
+    summary = evaluate_science_visual_gate(payload)
+
+    assert summary['overall_score'] < 0.7
+    assert summary['human_review_required'] is True
+    veto_codes = {item['code'] for item in summary['vetoes']}
+    assert 'science_table_region_critical_distortion' in veto_codes
+    assert 'science_experiment_record_adjacency_broken' in veto_codes
+
+    recommended_common_codes = {item['recommended_common_code'] for item in summary['vetoes']}
+    assert 'table_visual_adjacency_severe_misalignment' in recommended_common_codes
+
+    page = summary['pages'][0]
+    region_by_kind = {item['kind']: item for item in page['region_scores']}
+    assert region_by_kind['table']['score'] < 0.55
+    assert 'table_row_column_mismatch' in region_by_kind['table']['reasons']
+
+    relation_by_kind = {item['relation_kind']: item for item in page['relation_scores']}
+    assert relation_by_kind['experiment_record_adjacency']['score'] < 0.55
+    assert any(
+        reason in relation_by_kind['experiment_record_adjacency']['reasons']
+        for reason in {'relative_gap_deviates', 'relative_orientation_changed'}
+    )
+
+
+def test_science_visual_gate_identifies_image_prompt_binding_failure():
+    payload = _load_fixture('science_experiment_image_binding_fail.json')
+
+    summary = evaluate_science_visual_gate(payload)
+
+    assert summary['overall_score'] < 0.8
+    assert summary['human_review_required'] is True
+    veto_codes = {item['code'] for item in summary['vetoes']}
+    assert 'science_image_prompt_binding_broken' in veto_codes
+
+    page = summary['pages'][0]
+    relation_by_kind = {item['relation_kind']: item for item in page['relation_scores']}
+    assert relation_by_kind['image_prompt_binding']['score'] < 0.55
+    assert 'relative_orientation_changed' in relation_by_kind['image_prompt_binding']['reasons']
+
+    image_region = next(item for item in page['region_scores'] if item['kind'] == 'image')
+    assert image_region['score'] < 0.55
+    assert 'bbox_iou_below_threshold' in image_region['reasons']
+
+
+def test_science_visual_gate_fixture_loader_reads_json_payload():
+    fixture_path = FIXTURES_ROOT / 'science_experiment_happy.json'
+
+    payload = load_science_visual_gate_payload(fixture_path)
+
+    assert isinstance(payload, dict)
+    assert json.loads(fixture_path.read_text(encoding='utf-8')) == payload
+
+
+def test_science_visual_gate_marks_missing_required_source_region_as_not_ready():
+    payload = copy.deepcopy(_load_fixture('science_experiment_happy.json'))
+    payload['pages'][0]['source_regions'] = [
+        item for item in payload['pages'][0]['source_regions']
+        if item.get('kind') != 'table'
+    ]
+
+    summary = evaluate_science_visual_gate(payload)
+
+    assert summary['status'] == 'not_ready'
+    assert summary['overall_score'] == 0.0
+    assert summary['raw_overall_score'] > 0.0
+    assert summary['human_review_required'] is True
+    assert summary['blocker_count'] >= 1
+    blocker_codes = {item['code'] for item in summary['blockers']}
+    assert 'science_required_region_missing' in blocker_codes
+    assert any(item.get('required_region_kind') == 'table' for item in summary['blockers'])
+
+    page = summary['pages'][0]
+    assert page['status'] == 'not_ready'
+    assert page['score'] == 0.0
+    assert page['raw_score'] > 0.0
+    assert any(
+        item.startswith('4:science_required_region_missing:table')
+        for item in page['low_score_reasons']
+    )
+
+
+def test_science_visual_gate_marks_missing_required_relations_as_not_ready():
+    payload = copy.deepcopy(_load_fixture('science_experiment_happy.json'))
+    for region in payload['pages'][0]['source_regions']:
+        region['adjacent_to'] = []
+
+    summary = evaluate_science_visual_gate(payload)
+
+    assert summary['status'] == 'not_ready'
+    assert summary['overall_score'] == 0.0
+    assert summary['raw_overall_score'] > 0.9
+    assert summary['human_review_required'] is True
+    relation_blockers = [
+        item for item in summary['blockers']
+        if item.get('code') == 'science_required_relation_missing'
+    ]
+    assert relation_blockers
+    required_pairs = {tuple(item.get('required_relation_kind_pair') or []) for item in relation_blockers}
+    assert ('image', 'question_stem') in required_pairs
+    assert ('question_stem', 'table') in required_pairs
+    assert ('experiment_record', 'table') in required_pairs
+
+    page = summary['pages'][0]
+    assert page['status'] == 'not_ready'
+    assert page['score'] == 0.0
+    assert page['relation_scores'] == []
+    assert any(
+        item.startswith("4:science_required_relation_missing:['image', 'question_stem']")
+        or item.startswith("4:science_required_relation_missing:['question_stem', 'table']")
+        or item.startswith("4:science_required_relation_missing:['experiment_record', 'table']")
+        for item in page['low_score_reasons']
+    )
