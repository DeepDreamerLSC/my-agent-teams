+from __future__ import annotations
+
+import json
+import math
+from pathlib import Path
+from typing import Any, Iterable, Mapping, Sequence
+
+
+SCIENCE_VISUAL_GATE_REPORT_TYPE = 'pdf_to_word_science_visual_gate/v1'
+SCIENCE_REGION_WARN_THRESHOLD = 0.82
+SCIENCE_REGION_VETO_THRESHOLD = 0.55
+SCIENCE_KEY_REGION_KINDS = {'table', 'image', 'experiment_record'}
+SCIENCE_ANCHOR_REGION_KINDS = {'question_stem'}
+SCIENCE_EVALUATED_REGION_KINDS = SCIENCE_KEY_REGION_KINDS | SCIENCE_ANCHOR_REGION_KINDS
+SCIENCE_REQUIRED_REGION_KINDS = ('table', 'image', 'experiment_record', 'question_stem')
+SCIENCE_REQUIRED_RELATION_KIND_PAIRS = (
+    ('image', 'question_stem'),
+    ('question_stem', 'table'),
+    ('experiment_record', 'table'),
+)
+SCIENCE_VETO_CODE_MAP: dict[str, tuple[str, str]] = {
+    'table': ('science_table_region_critical_distortion', 'table_visual_adjacency_severe_misalignment'),
+    'image': ('science_image_prompt_binding_broken', 'critical_page_reading_order_break'),
+    'experiment_record': ('science_experiment_record_adjacency_broken', 'table_visual_adjacency_severe_misalignment'),
+    'image_prompt_binding': ('science_image_prompt_binding_broken', 'critical_page_reading_order_break'),
+    'table_prompt_adjacency': ('science_table_region_critical_distortion', 'table_visual_adjacency_severe_misalignment'),
+    'table_image_adjacency': ('science_table_region_critical_distortion', 'table_visual_adjacency_severe_misalignment'),
+    'experiment_record_adjacency': ('science_experiment_record_adjacency_broken', 'table_visual_adjacency_severe_misalignment'),
+}
+
+
+def load_science_visual_gate_payload(path: str | Path) -> dict[str, Any]:
+    return json.loads(Path(path).expanduser().resolve().read_text(encoding='utf-8'))
+
+
+def evaluate_science_visual_gate(
+    payload: Mapping[str, Any],
+    *,
+    warn_threshold: float = SCIENCE_REGION_WARN_THRESHOLD,
+    veto_threshold: float = SCIENCE_REGION_VETO_THRESHOLD,
+) -> dict[str, Any]:
+    pages_payload = payload.get('pages')
+    pages = [
+        _normalize_page(item)
+        for item in pages_payload
+        if isinstance(item, Mapping)
+    ] if isinstance(pages_payload, list) else []
+
+    page_results: list[dict[str, Any]] = []
+    blockers: list[dict[str, Any]] = []
+    all_vetoes: list[dict[str, Any]] = []
+    low_score_reasons: list[str] = []
+    summary_scores: dict[str, list[float]] = {
+        'table': [],
+        'image': [],
+        'experiment_record': [],
+        'relation': [],
+    }
+
+    for page in pages:
+        page_result = _evaluate_page(page, warn_threshold=warn_threshold, veto_threshold=veto_threshold)
+        page_results.append(page_result)
+        blockers.extend(page_result['blockers'])
+        all_vetoes.extend(page_result['vetoes'])
+        for reason in page_result['low_score_reasons']:
+            if reason not in low_score_reasons:
+                low_score_reasons.append(reason)
+        for region in page_result['region_scores']:
+            kind = str(region.get('kind') or '')
+            if kind in summary_scores:
+                summary_scores[kind].append(float(region.get('score') or 0.0))
+        for relation in page_result['relation_scores']:
+            summary_scores['relation'].append(float(relation.get('score') or 0.0))
+
+    raw_overall_score = _mean([float(page.get('raw_score') or 0.0) for page in page_results], default=0.0)
+    overall_score = 0.0 if blockers else raw_overall_score
+    key_region_scores = {
+        'table_min_score': _min_or_none(summary_scores['table']),
+        'image_min_score': _min_or_none(summary_scores['image']),
+        'experiment_record_min_score': _min_or_none(summary_scores['experiment_record']),
+        'relation_min_score': _min_or_none(summary_scores['relation']),
+    }
+    human_review_required = bool(blockers or all_vetoes) or any(
+        any(float(item.get('score') or 0.0) < warn_threshold for item in page_result['region_scores'] + page_result['relation_scores'])
+        for page_result in page_results
+    )
+    status = 'not_ready' if blockers else 'ready'
+
+    return {
+        'report_type': SCIENCE_VISUAL_GATE_REPORT_TYPE,
+        'status': status,
+        'sample_name': str(payload.get('sample_name') or '').strip() or None,
+        'subject': str(payload.get('subject') or 'science').strip() or 'science',
+        'document_page_type': str(payload.get('document_page_type') or '').strip() or None,
+        'overall_score': _round(overall_score),
+        'raw_overall_score': _round(raw_overall_score),
+        'human_review_required': human_review_required,
+        'key_region_scores': key_region_scores,
+        'low_score_reasons': low_score_reasons,
+        'blocker_count': len(blockers),
+        'blockers': blockers,
+        'vetoes': all_vetoes,
+        'pages': page_results,
+        'integration': {
+            'visual_similarity_key_regions_field': 'pages[].region_scores + pages[].relation_scores',
+            'fidelity_veto_field': 'vetoes',
+            'recommended_common_code_field': 'recommended_common_code',
+            'contract_blocker_field': 'blockers',
+        },
+    }
+
+
+def _evaluate_page(
+    page: dict[str, Any],
+    *,
+    warn_threshold: float,
+    veto_threshold: float,
+) -> dict[str, Any]:
+    source_regions = page['source_regions']
+    output_regions = page['output_regions']
+    region_scores: list[dict[str, Any]] = []
+    relation_scores: list[dict[str, Any]] = []
+    low_score_reasons: list[str] = []
+    blockers = _collect_contract_blockers(page, source_regions)
+    for blocker in blockers:
+        blocker_code = str(blocker.get('code') or 'science_contract_blocker')
+        blocker_detail = (
+            blocker.get('required_region_kind')
+            or blocker.get('required_relation_kind_pair')
+            or blocker.get('summary')
+        )
+        token = f"{page['page_index']}:{blocker_code}:{blocker_detail}"
+        if token not in low_score_reasons:
+            low_score_reasons.append(token)
+
+    for source_region in source_regions.values():
+        if source_region['kind'] not in SCIENCE_EVALUATED_REGION_KINDS:
+            continue
+        region_result = _compare_region(page, source_region, output_regions.get(source_region['region_id']))
+        if source_region['kind'] in SCIENCE_KEY_REGION_KINDS:
+            region_scores.append(region_result)
+        if float(region_result['score']) < warn_threshold:
+            for reason in region_result['reasons']:
+                token = f"{page['page_index']}:{source_region['region_id']}:{reason}"
+                if token not in low_score_reasons:
+                    low_score_reasons.append(token)
+
+    for relation in _collect_relations(source_regions):
+        relation_result = _compare_relation(page, relation, source_regions, output_regions)
+        relation_scores.append(relation_result)
+        if float(relation_result['score']) < warn_threshold:
+            for reason in relation_result['reasons']:
+                token = f"{page['page_index']}:{relation_result['relation_id']}:{reason}"
+                if token not in low_score_reasons:
+                    low_score_reasons.append(token)
+
+    raw_page_score = _mean(
+        [float(item.get('score') or 0.0) for item in region_scores + relation_scores],
+        default=0.0,
+    )
+    page_score = 0.0 if blockers else raw_page_score
+    vetoes = _build_vetoes(
+        page_index=page['page_index'],
+        region_scores=region_scores,
+        relation_scores=relation_scores,
+        veto_threshold=veto_threshold,
+    )
+    return {
+        'page_index': page['page_index'],
+        'status': 'not_ready' if blockers else 'ready',
+        'score': _round(page_score),
+        'raw_score': _round(raw_page_score),
+        'human_review_required': bool(blockers or vetoes) or any(
+            float(item.get('score') or 0.0) < warn_threshold
+            for item in region_scores + relation_scores
+        ),
+        'blockers': blockers,
+        'region_scores': region_scores,
+        'relation_scores': relation_scores,
+        'low_score_reasons': low_score_reasons,
+        'vetoes': vetoes,
+    }
+
+
+def _collect_contract_blockers(
+    page: dict[str, Any],
+    source_regions: Mapping[str, dict[str, Any]],
+) -> list[dict[str, Any]]:
+    blockers: list[dict[str, Any]] = []
+    required_region_kinds = tuple(page.get('required_region_kinds') or SCIENCE_REQUIRED_REGION_KINDS)
+    required_relation_pairs = tuple(page.get('required_relation_kind_pairs') or SCIENCE_REQUIRED_RELATION_KIND_PAIRS)
+
+    available_regions_by_kind: dict[str, list[dict[str, Any]]] = {}
+    for region in source_regions.values():
+        available_regions_by_kind.setdefault(str(region.get('kind') or ''), []).append(region)
+
+    for required_kind in required_region_kinds:
+        matching_regions = [
+            region
+            for region in available_regions_by_kind.get(str(required_kind), [])
+            if region.get('bbox') is not None
+        ]
+        if matching_regions:
+            continue
+        blockers.append({
+            'code': 'science_required_region_missing',
+            'scope': 'page',
+            'page_index': int(page.get('page_index') or 0),
+            'required_region_kind': str(required_kind),
+            'summary': f'科学实验页缺少关键 source region：{required_kind}。',
+            'status': 'not_ready',
+        })
+
+    existing_relation_pairs = _collect_relation_kind_pairs(source_regions)
+    for left_kind, right_kind in required_relation_pairs:
+        normalized_pair = tuple(sorted((str(left_kind), str(right_kind))))
+        if normalized_pair in existing_relation_pairs:
+            continue
+        if not (
+            available_regions_by_kind.get(str(left_kind))
+            and available_regions_by_kind.get(str(right_kind))
+        ):
+            continue
+        blockers.append({
+            'code': 'science_required_relation_missing',
+            'scope': 'page',
+            'page_index': int(page.get('page_index') or 0),
+            'required_relation_kind_pair': list(normalized_pair),
+            'summary': f'科学实验页缺少关键关系定义：{normalized_pair[0]} <-> {normalized_pair[1]}。',
+            'status': 'not_ready',
+        })
+    return blockers
+
+
+def _build_vetoes(
+    *,
+    page_index: int,
+    region_scores: Sequence[dict[str, Any]],
+    relation_scores: Sequence[dict[str, Any]],
+    veto_threshold: float,
+) -> list[dict[str, Any]]:
+    vetoes: list[dict[str, Any]] = []
+    seen: set[tuple[Any, ...]] = set()
+
+    for item in list(region_scores) + list(relation_scores):
+        score = float(item.get('score') or 0.0)
+        signal = str(item.get('kind') or item.get('relation_kind') or '')
+        if score >= veto_threshold or signal not in SCIENCE_VETO_CODE_MAP:
+            continue
+        code, common_code = SCIENCE_VETO_CODE_MAP[signal]
+        region_id = str(item.get('region_id') or item.get('relation_id') or signal)
+        summary = _build_veto_summary(item)
+        key = (code, page_index, region_id)
+        if key in seen:
+            continue
+        seen.add(key)
+        vetoes.append({
+            'code': code,
+            'recommended_common_code': common_code,
+            'scope': 'region',
+            'page_index': page_index,
+            'region_kind': signal,
+            'region_id': region_id,
+            'score': _round(score),
+            'summary': summary,
+            'reasons': list(item.get('reasons') or []),
+        })
+    return vetoes
+
+
+def _build_veto_summary(item: dict[str, Any]) -> str:
+    signal = str(item.get('kind') or item.get('relation_kind') or 'region')
+    if signal == 'table':
+        return '科学实验页表格外框/行列观感与原稿偏差过大。'
+    if signal in {'table_prompt_adjacency', 'table_image_adjacency'}:
+        return '科学实验页表格与题干/图片区邻接关系严重错位。'
+    if signal == 'image':
+        return '科学实验页图片区尺度或位置偏差过大。'
+    if signal == 'image_prompt_binding':
+        return '科学实验页图片区与题干绑定关系断裂。'
+    if signal in {'experiment_record', 'experiment_record_adjacency'}:
+        return '科学实验记录区与表格/题干邻接关系严重失真。'
+    return '科学实验页关键区域视觉失真。'
+
+
+def _normalize_page(payload: Mapping[str, Any]) -> dict[str, Any]:
+    page_index = _coerce_int(payload.get('page_index'), default=1)
+    source_regions = _normalize_regions(payload.get('source_regions'))
+    output_regions = _normalize_regions(payload.get('output_regions'))
+    page_size = (
+        _normalize_page_size(payload.get('page_size'))
+        or _normalize_page_size(payload.get('source_page'))
+        or _normalize_page_size(payload.get('output_page'))
+        or {'width': 1000.0, 'height': 1000.0}
+    )
+    return {
+        'page_index': page_index,
+        'page_size': page_size,
+        'required_region_kinds': _normalize_required_region_kinds(payload.get('required_region_kinds')),
+        'required_relation_kind_pairs': _normalize_required_relation_kind_pairs(payload.get('required_relation_kind_pairs')),
+        'source_regions': source_regions,
+        'output_regions': output_regions,
+    }
+
+
+def _normalize_regions(payload: Any) -> dict[str, dict[str, Any]]:
+    if not isinstance(payload, list):
+        return {}
+    result: dict[str, dict[str, Any]] = {}
+    for item in payload:
+        if not isinstance(item, Mapping):
+            continue
+        region_id = str(item.get('region_id') or '').strip()
+        kind = str(item.get('kind') or '').strip()
+        if not region_id or not kind:
+            continue
+        result[region_id] = {
+            'region_id': region_id,
+            'kind': kind,
+            'bbox': _normalize_bbox(item.get('bbox')),
+            'rows': _coerce_int(item.get('rows') or item.get('row_count')),
+            'columns': _coerce_int(item.get('columns') or item.get('column_count')),
+            'adjacent_to': _normalize_string_list(item.get('adjacent_to')),
+        }
+    return result
+
+
+def _normalize_page_size(payload: Any) -> dict[str, float] | None:
+    if not isinstance(payload, Mapping):
+        return None
+    width = _coerce_float(payload.get('width') or payload.get('pixel_width'))
+    height = _coerce_float(payload.get('height') or payload.get('pixel_height'))
+    if width is None or height is None or width <= 0 or height <= 0:
+        return None
+    return {'width': width, 'height': height}
+
+
+def _normalize_bbox(payload: Any) -> dict[str, float] | None:
+    if not isinstance(payload, Mapping):
+        return None
+    try:
+        x0 = float(payload['x0'])
+        y0 = float(payload['y0'])
+        x1 = float(payload['x1'])
+        y1 = float(payload['y1'])
+    except (KeyError, TypeError, ValueError):
+        return None
+    if x1 <= x0 or y1 <= y0:
+        return None
+    return {'x0': x0, 'y0': y0, 'x1': x1, 'y1': y1}
+
+
+def _compare_region(
+    page: dict[str, Any],
+    source_region: dict[str, Any],
+    output_region: dict[str, Any] | None,
+) -> dict[str, Any]:
+    page_diagonal = _page_diagonal(page['page_size'])
+    reasons: list[str] = []
+    if output_region is None or output_region.get('bbox') is None or source_region.get('bbox') is None:
+        reasons.append('missing_output_region')
+        return {
+            'region_id': source_region['region_id'],
+            'kind': source_region['kind'],
+            'score': 0.0,
+            'metrics': {
+                'bbox_iou': 0.0,
+                'center_distance_score': 0.0,
+                'size_similarity': 0.0,
+                'aspect_similarity': 0.0,
+                'row_column_similarity': 0.0,
+            },
+            'reasons': reasons,
+        }
+
+    source_bbox = source_region['bbox']
+    output_bbox = output_region['bbox']
+    bbox_iou = _iou(source_bbox, output_bbox)
+    center_distance_score = _center_distance_score(source_bbox, output_bbox, page_diagonal)
+    size_similarity = _size_similarity(source_bbox, output_bbox)
+    aspect_similarity = _aspect_similarity(source_bbox, output_bbox)
+    row_column_similarity = _grid_similarity(source_region, output_region)
+
+    if bbox_iou < 0.65:
+        reasons.append('bbox_iou_below_threshold')
+    if center_distance_score < 0.75:
+        reasons.append('center_shift_too_large')
+    if size_similarity < 0.75:
+        reasons.append('size_similarity_below_threshold')
+    if aspect_similarity < 0.7:
+        reasons.append('aspect_similarity_below_threshold')
+    if source_region['kind'] == 'table' and row_column_similarity < 0.8:
+        reasons.append('table_row_column_mismatch')
+
+    if source_region['kind'] == 'table':
+        score = (
+            0.35 * bbox_iou
+            + 0.15 * center_distance_score
+            + 0.15 * size_similarity
+            + 0.15 * aspect_similarity
+            + 0.20 * row_column_similarity
+        )
+    else:
+        score = (
+            0.4 * bbox_iou
+            + 0.2 * center_distance_score
+            + 0.2 * size_similarity
+            + 0.2 * aspect_similarity
+        )
+
+    return {
+        'region_id': source_region['region_id'],
+        'kind': source_region['kind'],
+        'score': _round(score),
+        'metrics': {
+            'bbox_iou': _round(bbox_iou),
+            'center_distance_score': _round(center_distance_score),
+            'size_similarity': _round(size_similarity),
+            'aspect_similarity': _round(aspect_similarity),
+            'row_column_similarity': _round(row_column_similarity),
+        },
+        'reasons': reasons,
+    }
+
+
+def _collect_relations(source_regions: Mapping[str, dict[str, Any]]) -> list[dict[str, Any]]:
+    relations: list[dict[str, Any]] = []
+    seen: set[tuple[str, str]] = set()
+    for region in source_regions.values():
+        for adjacent_id in region.get('adjacent_to') or []:
+            if adjacent_id not in source_regions:
+                continue
+            relation_key = tuple(sorted((region['region_id'], adjacent_id)))
+            if relation_key in seen:
+                continue
+            seen.add(relation_key)
+            left = source_regions[relation_key[0]]
+            right = source_regions[relation_key[1]]
+            relations.append({
+                'left_region_id': left['region_id'],
+                'right_region_id': right['region_id'],
+                'relation_id': f"{left['region_id']}->{right['region_id']}",
+                'relation_kind': _classify_relation_kind(left['kind'], right['kind']),
+            })
+    return relations
+
+
+def _collect_relation_kind_pairs(source_regions: Mapping[str, dict[str, Any]]) -> set[tuple[str, str]]:
+    pairs: set[tuple[str, str]] = set()
+    for relation in _collect_relations(source_regions):
+        left_source = source_regions.get(str(relation.get('left_region_id') or ''))
+        right_source = source_regions.get(str(relation.get('right_region_id') or ''))
+        if not left_source or not right_source:
+            continue
+        left_kind = str(left_source.get('kind') or '')
+        right_kind = str(right_source.get('kind') or '')
+        if left_kind and right_kind:
+            pairs.add(tuple(sorted((left_kind, right_kind))))
+    return pairs
+
+
+def _classify_relation_kind(left_kind: str, right_kind: str) -> str:
+    kinds = {left_kind, right_kind}
+    if kinds == {'image', 'question_stem'}:
+        return 'image_prompt_binding'
+    if kinds == {'table', 'question_stem'}:
+        return 'table_prompt_adjacency'
+    if kinds == {'table', 'image'}:
+        return 'table_image_adjacency'
+    if kinds == {'experiment_record', 'table'} or kinds == {'experiment_record', 'question_stem'}:
+        return 'experiment_record_adjacency'
+    return 'generic_adjacency'
+
+
+def _compare_relation(
+    page: dict[str, Any],
+    relation: dict[str, Any],
+    source_regions: Mapping[str, dict[str, Any]],
+    output_regions: Mapping[str, dict[str, Any]],
+) -> dict[str, Any]:
+    left_source = source_regions[relation['left_region_id']]
+    right_source = source_regions[relation['right_region_id']]
+    left_output = output_regions.get(relation['left_region_id'])
+    right_output = output_regions.get(relation['right_region_id'])
+    reasons: list[str] = []
+
+    if (
+        left_source.get('bbox') is None
+        or right_source.get('bbox') is None
+        or left_output is None
+        or right_output is None
+        or left_output.get('bbox') is None
+        or right_output.get('bbox') is None
+    ):
+        reasons.append('relation_endpoint_missing')
+        return {
+            'relation_id': relation['relation_id'],
+            'relation_kind': relation['relation_kind'],
+            'score': 0.0,
+            'metrics': {
+                'orientation_match': 0.0,
+                'gap_similarity': 0.0,
+                'axis_overlap_similarity': 0.0,
+            },
+            'reasons': reasons,
+        }
+
+    source_descriptor = _relation_descriptor(left_source['bbox'], right_source['bbox'], page['page_size'])
+    output_descriptor = _relation_descriptor(left_output['bbox'], right_output['bbox'], page['page_size'])
+    orientation_match = 1.0 if source_descriptor['orientation'] == output_descriptor['orientation'] else 0.0
+    gap_similarity = max(
+        0.0,
+        1.0 - min(abs(source_descriptor['gap'] - output_descriptor['gap']) / 0.35, 1.0),
+    )
+    axis_overlap_similarity = max(
+        0.0,
+        1.0 - min(abs(source_descriptor['axis_overlap'] - output_descriptor['axis_overlap']), 1.0),
+    )
+    score = 0.45 * orientation_match + 0.35 * gap_similarity + 0.20 * axis_overlap_similarity
+
+    if orientation_match < 1.0:
+        reasons.append('relative_orientation_changed')
+    if gap_similarity < 0.7:
+        reasons.append('relative_gap_deviates')
+    if axis_overlap_similarity < 0.7:
+        reasons.append('axis_overlap_deviates')
+
+    return {
+        'relation_id': relation['relation_id'],
+        'relation_kind': relation['relation_kind'],
+        'score': _round(score),
+        'metrics': {
+            'orientation_match': _round(orientation_match),
+            'gap_similarity': _round(gap_similarity),
+            'axis_overlap_similarity': _round(axis_overlap_similarity),
+        },
+        'reasons': reasons,
+    }
+
+
+def _relation_descriptor(
+    left_bbox: dict[str, float],
+    right_bbox: dict[str, float],
+    page_size: dict[str, float],
+) -> dict[str, Any]:
+    left_center_x = (left_bbox['x0'] + left_bbox['x1']) / 2.0
+    left_center_y = (left_bbox['y0'] + left_bbox['y1']) / 2.0
+    right_center_x = (right_bbox['x0'] + right_bbox['x1']) / 2.0
+    right_center_y = (right_bbox['y0'] + right_bbox['y1']) / 2.0
+    dx = right_center_x - left_center_x
+    dy = right_center_y - left_center_y
+
+    if _iou(left_bbox, right_bbox) > 0.05:
+        orientation = 'overlap'
+    elif abs(dx) >= abs(dy):
+        orientation = 'right_of' if dx >= 0 else 'left_of'
+    else:
+        orientation = 'below' if dy >= 0 else 'above'
+
+    horizontal_gap = max(0.0, max(left_bbox['x0'], right_bbox['x0']) - min(left_bbox['x1'], right_bbox['x1']))
+    vertical_gap = max(0.0, max(left_bbox['y0'], right_bbox['y0']) - min(left_bbox['y1'], right_bbox['y1']))
+    page_diagonal = _page_diagonal(page_size)
+    gap = math.hypot(horizontal_gap, vertical_gap) / page_diagonal if page_diagonal else 0.0
+
+    if orientation in {'left_of', 'right_of', 'overlap'}:
+        axis_overlap = _axis_overlap_ratio(left_bbox['y0'], left_bbox['y1'], right_bbox['y0'], right_bbox['y1'])
+    else:
+        axis_overlap = _axis_overlap_ratio(left_bbox['x0'], left_bbox['x1'], right_bbox['x0'], right_bbox['x1'])
+
+    return {
+        'orientation': orientation,
+        'gap': gap,
+        'axis_overlap': axis_overlap,
+    }
+
+
+def _center_distance_score(
+    left_bbox: dict[str, float],
+    right_bbox: dict[str, float],
+    page_diagonal: float,
+) -> float:
+    left_center_x = (left_bbox['x0'] + left_bbox['x1']) / 2.0
+    left_center_y = (left_bbox['y0'] + left_bbox['y1']) / 2.0
+    right_center_x = (right_bbox['x0'] + right_bbox['x1']) / 2.0
+    right_center_y = (right_bbox['y0'] + right_bbox['y1']) / 2.0
+    if page_diagonal <= 0:
+        return 0.0
+    distance = math.hypot(left_center_x - right_center_x, left_center_y - right_center_y) / page_diagonal
+    return max(0.0, 1.0 - min(distance / 0.4, 1.0))
+
+
+def _page_diagonal(page_size: dict[str, float]) -> float:
+    return math.hypot(float(page_size['width']), float(page_size['height']))
+
+
+def _size_similarity(left_bbox: dict[str, float], right_bbox: dict[str, float]) -> float:
+    left_area = _area(left_bbox)
+    right_area = _area(right_bbox)
+    if left_area <= 0 or right_area <= 0:
+        return 0.0
+    return min(left_area, right_area) / max(left_area, right_area)
+
+
+def _aspect_similarity(left_bbox: dict[str, float], right_bbox: dict[str, float]) -> float:
+    left_ratio = _aspect_ratio(left_bbox)
+    right_ratio = _aspect_ratio(right_bbox)
+    if left_ratio <= 0 or right_ratio <= 0:
+        return 0.0
+    return min(left_ratio, right_ratio) / max(left_ratio, right_ratio)
+
+
+def _grid_similarity(left_region: dict[str, Any], right_region: dict[str, Any]) -> float:
+    left_rows = left_region.get('rows')
+    right_rows = right_region.get('rows')
+    left_columns = left_region.get('columns')
+    right_columns = right_region.get('columns')
+    if not left_rows or not right_rows or not left_columns or not right_columns:
+        return 1.0
+    row_similarity = _count_similarity(int(left_rows), int(right_rows))
+    column_similarity = _count_similarity(int(left_columns), int(right_columns))
+    return (row_similarity + column_similarity) / 2.0
+
+
+def _count_similarity(left_value: int, right_value: int) -> float:
+    if left_value <= 0 or right_value <= 0:
+        return 0.0
+    if left_value == right_value:
+        return 1.0
+    delta = abs(left_value - right_value)
+    return max(0.0, 1.0 - min(delta / max(left_value, right_value), 1.0))
+
+
+def _axis_overlap_ratio(left_start: float, left_end: float, right_start: float, right_end: float) -> float:
+    overlap = max(0.0, min(left_end, right_end) - max(left_start, right_start))
+    left_span = max(left_end - left_start, 0.0)
+    right_span = max(right_end - right_start, 0.0)
+    smaller = min(left_span, right_span)
+    if smaller <= 0:
+        return 0.0
+    return overlap / smaller
+
+
+def _iou(left_bbox: dict[str, float], right_bbox: dict[str, float]) -> float:
+    intersection = _intersection_area(left_bbox, right_bbox)
+    if intersection <= 0:
+        return 0.0
+    union = _area(left_bbox) + _area(right_bbox) - intersection
+    if union <= 0:
+        return 0.0
+    return intersection / union
+
+
+def _intersection_area(left_bbox: dict[str, float], right_bbox: dict[str, float]) -> float:
+    width = max(0.0, min(left_bbox['x1'], right_bbox['x1']) - max(left_bbox['x0'], right_bbox['x0']))
+    height = max(0.0, min(left_bbox['y1'], right_bbox['y1']) - max(left_bbox['y0'], right_bbox['y0']))
+    return width * height
+
+
+def _area(bbox: dict[str, float]) -> float:
+    return max(bbox['x1'] - bbox['x0'], 0.0) * max(bbox['y1'] - bbox['y0'], 0.0)
+
+
+def _aspect_ratio(bbox: dict[str, float]) -> float:
+    height = max(bbox['y1'] - bbox['y0'], 0.0)
+    if height <= 0:
+        return 0.0
+    return max(bbox['x1'] - bbox['x0'], 0.0) / height
+
+
+def _normalize_string_list(values: Any) -> list[str]:
+    if not isinstance(values, Sequence) or isinstance(values, (str, bytes, bytearray)):
+        return []
+    result: list[str] = []
+    for value in values:
+        text = str(value or '').strip()
+        if text and text not in result:
+            result.append(text)
+    return result
+
+
+def _normalize_required_region_kinds(values: Any) -> list[str]:
+    normalized = _normalize_string_list(values)
+    return normalized or list(SCIENCE_REQUIRED_REGION_KINDS)
+
+
+def _normalize_required_relation_kind_pairs(values: Any) -> list[tuple[str, str]]:
+    if not isinstance(values, Sequence) or isinstance(values, (str, bytes, bytearray)):
+        return list(SCIENCE_REQUIRED_RELATION_KIND_PAIRS)
+    result: list[tuple[str, str]] = []
+    for item in values:
+        if not isinstance(item, Sequence) or isinstance(item, (str, bytes, bytearray)) or len(item) != 2:
+            continue
+        left = str(item[0] or '').strip()
+        right = str(item[1] or '').strip()
+        if not left or not right:
+            continue
+        pair = tuple(sorted((left, right)))
+        if pair not in result:
+            result.append(pair)
+    return result or list(SCIENCE_REQUIRED_RELATION_KIND_PAIRS)
+
+
+def _coerce_int(value: Any, *, default: int | None = None) -> int | None:
+    try:
+        return int(value)
+    except (TypeError, ValueError):
+        return default
+
+
+def _coerce_float(value: Any) -> float | None:
+    try:
+        return float(value)
+    except (TypeError, ValueError):
+        return None
+
+
+def _mean(values: Iterable[float], *, default: float) -> float:
+    items = [float(value) for value in values]
+    if not items:
+        return default
+    return sum(items) / len(items)
+
+
+def _min_or_none(values: Sequence[float]) -> float | None:
+    return _round(min(values)) if values else None
+
+
+def _round(value: float) -> float:
+    return round(float(value), 4)
