+from __future__ import annotations
+
+import json
+from collections.abc import Mapping, Sequence
+from pathlib import Path
+from typing import Any
+
+
+MATH_VISUAL_GATE_VERSION = 'pdf_to_word_math_visual_gate/v1'
+MATH_VISUAL_REPORT_TYPE = 'pdf_to_word_math_visual_gate'
+MATH_VISUAL_ARTIFACT_NAME = 'math_visual_gate.json'
+QUALITY_HYBRID_ASYNC_MODE = 'quality/hybrid_async'
+DEFAULT_SYNC_MODE = 'default_sync'
+QUALITY_GATE_MODES = {'quality', 'hybrid_async', QUALITY_HYBRID_ASYNC_MODE}
+DEFAULT_SYNC_MODES = {'', 'auto', 'apple', 'fast', 'balanced', DEFAULT_SYNC_MODE}
+SUBJECT_PAGE_TYPE = 'math'
+MATH_REGION_CLASSES = ('formula', 'graphic', 'table')
+MATH_ARTIFACT_REQUIRED_FIELDS = (
+    'report_type',
+    'contract_version',
+    'status',
+    'failure_code',
+    'subject_page_type',
+    'artifact_ready_for_scoring',
+    'mode_boundary',
+    'score_contract',
+    'render_pairs',
+    'math_key_regions',
+    'question_order_checks',
+    'vetoes',
+    'human_review_required',
+    'evidence_paths',
+    'downstream_visual_similarity_contract',
+)
+DEFAULT_THRESHOLDS: dict[str, float] = {
+    'formula_region_similarity_min': 0.90,
+    'graphic_region_similarity_min': 0.90,
+    'table_region_similarity_min': 0.90,
+    'bbox_iou_min': 0.85,
+    'question_order_similarity_min': 0.93,
+    'question_graphic_binding_iou_min': 0.88,
+    'slow_review_band': 0.03,
+}
+COMMON_REGION_TYPE_BY_CLASS = {
+    'formula': 'formula_graphic',
+    'graphic': 'image',
+    'table': 'table',
+}
+
+
+class MathVisualGateError(ValueError):
+    """Raised when a math-visual gate contract is structurally invalid."""
+
+
+def load_math_visual_contract(path: str | Path) -> dict[str, Any]:
+    contract_path = Path(path).expanduser().resolve()
+    return json.loads(contract_path.read_text(encoding='utf-8'))
+
+
+def resolve_math_visual_mode(requested_mode: str | None, *, parser_backend: str | None = None) -> str:
+    mode = _normalize_mode(requested_mode)
+    backend = str(parser_backend or '').strip().lower()
+    if mode in QUALITY_GATE_MODES:
+        return QUALITY_HYBRID_ASYNC_MODE
+    if backend == 'hybrid_experimental' and mode == 'quality':
+        return QUALITY_HYBRID_ASYNC_MODE
+    if mode in DEFAULT_SYNC_MODES:
+        return DEFAULT_SYNC_MODE
+    return DEFAULT_SYNC_MODE
+
+
+def write_math_visual_gate_artifact(report: Mapping[str, Any], output_path: str | Path) -> Path:
+    artifact_path = Path(output_path).expanduser().resolve()
+    artifact_path.parent.mkdir(parents=True, exist_ok=True)
+    artifact_path.write_text(json.dumps(report, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return artifact_path
+
+
+def build_math_visual_gate_report(
+    contract: Mapping[str, Any],
+    *,
+    requested_mode: str | None = None,
+    parser_backend: str | None = None,
+) -> dict[str, Any]:
+    _validate_contract(contract)
+    thresholds = _coerce_thresholds(contract.get('thresholds'))
+    gate_mode = resolve_math_visual_mode(requested_mode, parser_backend=parser_backend)
+    gate_enabled = gate_mode == QUALITY_HYBRID_ASYNC_MODE
+    render_pair_artifact, render_pair_artifact_path, render_pair_load_error = _load_render_pair_artifact(contract)
+    render_pair_validation = _validate_render_pair_artifact(
+        render_pair_artifact,
+        render_pair_artifact_path,
+        load_error=render_pair_load_error,
+    )
+    render_pairs = list(render_pair_artifact.get('render_pairs') or []) if isinstance(render_pair_artifact, Mapping) else []
+
+    (
+        math_key_regions,
+        question_order_checks,
+        specialized_vetoes,
+        review_reasons,
+        readiness_failures,
+    ) = _build_math_pages(contract.get('pages') or [], thresholds=thresholds)
+
+    readiness_failures = list(render_pair_validation['readiness_failures']) + readiness_failures
+    readiness_failures = sorted(set(readiness_failures))
+    artifact_ready_for_scoring = not readiness_failures
+
+    vetoes: list[dict[str, Any]] = []
+    if readiness_failures:
+        vetoes.append(
+            _make_veto(
+                code=_top_failure_code(readiness_failures),
+                scope='document',
+                severity='p0',
+                reason='math visual artifact lacks real render-pair evidence or complete math-specialized scoring payload',
+                blocking=True,
+                details=readiness_failures,
+            )
+        )
+    vetoes.extend(specialized_vetoes)
+
+    blocking_vetoes = [veto for veto in vetoes if veto.get('blocking')]
+    if not artifact_ready_for_scoring:
+        status = 'artifact_not_ready'
+        failure_code = _top_failure_code(readiness_failures)
+    elif blocking_vetoes:
+        status = 'failed'
+        failure_code = 'math_visual_veto_triggered'
+    else:
+        status = 'ready'
+        failure_code = None
+
+    aggregate = _build_aggregate(render_pairs, math_key_regions, question_order_checks, vetoes)
+    human_review_reasons = sorted(set(review_reasons) | ({failure_code} if status == 'artifact_not_ready' and failure_code else set()))
+
+    report = {
+        'report_type': MATH_VISUAL_REPORT_TYPE,
+        'contract_version': str(contract.get('contract_version') or MATH_VISUAL_GATE_VERSION),
+        'artifact_name': MATH_VISUAL_ARTIFACT_NAME,
+        'implementation_status': str(
+            contract.get('implementation_status')
+            or ('math_render_pair_artifact_ready' if artifact_ready_for_scoring else 'math_render_pair_not_ready')
+        ),
+        'status': status,
+        'failure_code': failure_code,
+        'subject_page_type': SUBJECT_PAGE_TYPE,
+        'artifact_ready_for_scoring': artifact_ready_for_scoring,
+        'mode_boundary': {
+            'requested_mode': _normalize_mode(requested_mode),
+            'parser_backend': str(parser_backend or '').strip() or None,
+            'resolved_gate_mode': gate_mode,
+            'enabled': gate_enabled,
+            'default_sync_safe': True,
+            'default_sync_invokes_math_visual_scoring': False,
+        },
+        'score_contract': _build_score_contract(
+            gate_enabled=gate_enabled,
+            artifact_ready_for_scoring=artifact_ready_for_scoring,
+            blocking_vetoes=blocking_vetoes,
+        ),
+        'thresholds': thresholds,
+        'render_pair_status': render_pair_validation['status'],
+        'render_pair_failure_code': render_pair_validation['failure_code'],
+        'render_pairs': render_pairs,
+        'math_key_regions': math_key_regions,
+        'question_order_checks': question_order_checks,
+        'vetoes': vetoes,
+        'human_review_required': bool(human_review_reasons),
+        'human_review_reasons': human_review_reasons,
+        'evidence_paths': _build_evidence_paths(contract, render_pair_artifact, render_pair_artifact_path),
+        'downstream_visual_similarity_contract': _build_downstream_contract(
+            math_key_regions=math_key_regions,
+            question_order_checks=question_order_checks,
+            vetoes=vetoes,
+            human_review_required=bool(human_review_reasons),
+        ),
+        'aggregate': aggregate,
+        'gate_passed': artifact_ready_for_scoring and not blocking_vetoes,
+        'known_gaps': list(contract.get('known_gaps') or []),
+        'downstream_required_work': list(contract.get('downstream_required_work') or []),
+    }
+    return report
+
+
+def _validate_contract(contract: Mapping[str, Any]) -> None:
+    required = {
+        'contract_version',
+        'source_policy',
+        'thresholds',
+        'artifact_contract',
+        'pages',
+        'evidence_paths',
+    }
+    missing = sorted(required - set(contract))
+    if missing:
+        raise MathVisualGateError(f'missing math visual gate fields: {missing}')
+    if str(contract.get('contract_version') or '') != MATH_VISUAL_GATE_VERSION:
+        raise MathVisualGateError('unsupported math visual gate contract_version')
+    if str(contract.get('subject_page_type') or SUBJECT_PAGE_TYPE) != SUBJECT_PAGE_TYPE:
+        raise MathVisualGateError('math visual gate subject_page_type must remain math')
+
+    source_policy = contract.get('source_policy') if isinstance(contract.get('source_policy'), Mapping) else {}
+    if str(source_policy.get('quality_target_scope') or '') != 'quality/hybrid_async only':
+        raise MathVisualGateError('quality_target_scope must remain quality/hybrid_async only')
+    if not bool(source_policy.get('formula_audit_only_not_sufficient', False)):
+        raise MathVisualGateError('formula_audit_only_not_sufficient must remain true')
+
+    artifact_contract = contract.get('artifact_contract')
+    if not isinstance(artifact_contract, Mapping):
+        raise MathVisualGateError('artifact_contract must be an object')
+    required_fields = set(artifact_contract.get('required_fields') or [])
+    if not set(MATH_ARTIFACT_REQUIRED_FIELDS).issubset(required_fields):
+        raise MathVisualGateError('artifact_contract.required_fields must include all math visual evidence fields')
+    region_classes = set(artifact_contract.get('required_region_classes') or [])
+    if set(MATH_REGION_CLASSES) != region_classes:
+        raise MathVisualGateError('artifact_contract.required_region_classes must be exactly formula/graphic/table')
+
+
+def _load_render_pair_artifact(contract: Mapping[str, Any]) -> tuple[dict[str, Any] | None, str | None, str | None]:
+    inline_payload = contract.get('render_pair_artifact')
+    if isinstance(inline_payload, Mapping):
+        return dict(inline_payload), None, None
+    render_pair_path = str(contract.get('render_pair_artifact_path') or '').strip()
+    if not render_pair_path:
+        return None, None, None
+    path = Path(render_pair_path).expanduser().resolve()
+    if not path.exists():
+        return None, str(path), 'render_pair_artifact_missing'
+    try:
+        return json.loads(path.read_text(encoding='utf-8')), str(path), None
+    except Exception as exc:  # pragma: no cover - defensive runtime guard
+        return None, str(path), f'render_pair_artifact_unreadable:{exc}'
+
+
+def _validate_render_pair_artifact(
+    payload: Mapping[str, Any] | None,
+    artifact_path: str | None,
+    *,
+    load_error: str | None,
+) -> dict[str, Any]:
+    readiness_failures: list[str] = []
+    failure_code: str | None = None
+    status = 'missing'
+    if load_error:
+        readiness_failures.append(load_error)
+        failure_code = _top_failure_code(readiness_failures)
+    elif not isinstance(payload, Mapping):
+        readiness_failures.append('render_pair_artifact_missing')
+        failure_code = 'render_pair_artifact_missing'
+    else:
+        status = str(payload.get('status') or '').strip() or 'missing'
+        if artifact_path and not Path(artifact_path).exists():
+            readiness_failures.append('render_pair_artifact_path_missing')
+        if status != 'success' or payload.get('ok') is not True or payload.get('failure_code'):
+            readiness_failures.append(f'render_pair_status_not_success:{status or "unknown"}')
+            failure_code = str(payload.get('failure_code') or status or 'render_pair_failed')
+        render_pairs = list(payload.get('render_pairs') or [])
+        if not render_pairs:
+            readiness_failures.append('render_pair_list_missing')
+            failure_code = failure_code or 'render_pair_list_missing'
+        for pair in render_pairs:
+            if not isinstance(pair, Mapping):
+                readiness_failures.append('render_pair_entry_invalid')
+                failure_code = failure_code or 'render_pair_entry_invalid'
+                continue
+            page_index = int(pair.get('page_index') or 0)
+            pair_status = str(pair.get('pair_status') or '').strip()
+            if pair_status != 'matched':
+                readiness_failures.append(f'render_pair_not_matched:p{page_index}')
+                failure_code = failure_code or 'render_pair_not_matched'
+            for side_key in ('source_pdf', 'output_docx'):
+                side = pair.get(side_key)
+                if not isinstance(side, Mapping):
+                    readiness_failures.append(f'render_pair_side_missing:{side_key}:p{page_index}')
+                    failure_code = failure_code or 'render_pair_side_missing'
+                    continue
+                for field_name in ('image_path', 'render_artifact'):
+                    raw_path = str(side.get(field_name) or '').strip()
+                    if not raw_path:
+                        readiness_failures.append(f'render_pair_field_missing:{side_key}:{field_name}:p{page_index}')
+                        failure_code = failure_code or 'render_pair_field_missing'
+                        continue
+                    if not Path(raw_path).expanduser().exists():
+                        readiness_failures.append(f'render_pair_path_missing:{side_key}:{field_name}:p{page_index}')
+                        failure_code = failure_code or 'render_pair_path_missing'
+    return {
+        'status': status,
+        'failure_code': failure_code,
+        'readiness_failures': readiness_failures,
+    }
+
+
+def _build_math_pages(
+    raw_pages: Sequence[object],
+    *,
+    thresholds: Mapping[str, float],
+) -> tuple[list[dict[str, Any]], list[dict[str, Any]], list[dict[str, Any]], list[str], list[str]]:
+    math_key_regions: list[dict[str, Any]] = []
+    question_order_checks: list[dict[str, Any]] = []
+    vetoes: list[dict[str, Any]] = []
+    review_reasons: list[str] = []
+    readiness_failures: list[str] = []
+
+    for page in raw_pages:
+        if not isinstance(page, Mapping):
+            continue
+        page_index = int(page.get('page_index') or 0)
+        page_role = str(page.get('page_role') or 'critical').strip().lower() or 'critical'
+        focus_tags = [str(tag).strip() for tag in page.get('focus_tags') or [] if str(tag).strip()]
+        readiness_failures.extend(_validate_focus_payloads(page, page_index=page_index, focus_tags=focus_tags))
+        for region_class in MATH_REGION_CLASSES:
+            raw_regions = page.get(f'{region_class}_regions') or []
+            reports, region_vetoes, region_reviews, region_readiness = _build_region_reports(
+                region_class=region_class,
+                raw_regions=raw_regions,
+                page_index=page_index,
+                page_role=page_role,
+                thresholds=thresholds,
+            )
+            math_key_regions.extend(reports)
+            vetoes.extend(region_vetoes)
+            review_reasons.extend(region_reviews)
+            readiness_failures.extend(region_readiness)
+        check, order_vetoes, order_reviews, order_readiness = _build_question_order_check(
+            page_index=page_index,
+            focus_tags=focus_tags,
+            raw_order=page.get('question_order'),
+            thresholds=thresholds,
+        )
+        if check is not None:
+            question_order_checks.append(check)
+        vetoes.extend(order_vetoes)
+        review_reasons.extend(order_reviews)
+        readiness_failures.extend(order_readiness)
+    return math_key_regions, question_order_checks, vetoes, review_reasons, readiness_failures
+
+
+def _validate_focus_payloads(
+    page: Mapping[str, Any],
+    *,
+    page_index: int,
+    focus_tags: Sequence[str],
+) -> list[str]:
+    readiness_failures: list[str] = []
+    focus_tag_set = {str(tag).strip() for tag in focus_tags if str(tag).strip()}
+    for region_class in MATH_REGION_CLASSES:
+        if region_class not in focus_tag_set:
+            continue
+        if list(page.get(f'{region_class}_regions') or []):
+            continue
+        readiness_failures.append(f'{region_class}_regions_missing:p{page_index}')
+    return readiness_failures
+
+
+def _build_region_reports(
+    *,
+    region_class: str,
+    raw_regions: Sequence[object],
+    page_index: int,
+    page_role: str,
+    thresholds: Mapping[str, float],
+) -> tuple[list[dict[str, Any]], list[dict[str, Any]], list[str], list[str]]:
+    reports: list[dict[str, Any]] = []
+    vetoes: list[dict[str, Any]] = []
+    review_reasons: list[str] = []
+    readiness_failures: list[str] = []
+    similarity_threshold = thresholds[f'{region_class}_region_similarity_min']
+
+    for index, region in enumerate(raw_regions, start=1):
+        if not isinstance(region, Mapping):
+            continue
+        region_id = str(region.get('region_id') or f'math:p{page_index}:{region_class}-{index:02d}').strip()
+        required = bool(region.get('required', True))
+        evidence_mode = str(region.get('evidence_mode') or 'visual_render_pair').strip()
+        formula_audit_status = str(region.get('formula_audit_status') or '').strip() or None
+        similarity = _optional_float(region.get('region_similarity'))
+        bbox_iou = _optional_float(region.get('bbox_iou'))
+        binding_iou = _optional_float(region.get('binding_iou'))
+        bbox = dict(region.get('bbox') or {})
+        region_type = str(region.get('region_type') or region_class).strip()
+        evidence = {
+            'source_crop_path': str(region.get('source_crop_path') or ''),
+            'docx_crop_path': str(region.get('docx_crop_path') or ''),
+            'diff_image_path': str(region.get('diff_image_path') or ''),
+        }
+        passed = True
+        region_review_reasons: list[str] = []
+
+        if region_class == 'formula' and evidence_mode != 'visual_render_pair':
+            readiness_failures.append(f'formula_audit_only_not_scorable:{region_id}')
+            passed = False
+        if similarity is None or bbox_iou is None:
+            readiness_failures.append(f'{region_class}_region_metrics_incomplete:{region_id}')
+            passed = False
+
+        if similarity is not None and required and similarity < similarity_threshold:
+            vetoes.append(
+                _make_veto(
+                    code=f'{region_class}_region_similarity_below_threshold',
+                    scope='region',
+                    severity='p0',
+                    reason=(
+                        f'{region_class} region similarity {similarity:.4f} below {similarity_threshold:.4f} for {region_id}'
+                    ),
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=region_id,
+                )
+            )
+            passed = False
+        elif similarity is not None and similarity < similarity_threshold + thresholds['slow_review_band']:
+            region_review_reasons.append(f'near_threshold_{region_class}_region:{region_id}')
+
+        if bbox_iou is not None and required and bbox_iou < thresholds['bbox_iou_min']:
+            vetoes.append(
+                _make_veto(
+                    code=f'{region_class}_region_bbox_iou_below_threshold',
+                    scope='region',
+                    severity='p0',
+                    reason=f'{region_class} region bbox IoU {bbox_iou:.4f} below {thresholds["bbox_iou_min"]:.4f} for {region_id}',
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=region_id,
+                )
+            )
+            passed = False
+
+        if region_class == 'graphic' and binding_iou is not None and binding_iou < thresholds['question_graphic_binding_iou_min']:
+            vetoes.append(
+                _make_veto(
+                    code='graphic_question_binding_below_threshold',
+                    scope='region',
+                    severity='p0',
+                    reason=(
+                        f'graphic/question binding IoU {binding_iou:.4f} below '
+                        f'{thresholds["question_graphic_binding_iou_min"]:.4f} for {region_id}'
+                    ),
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=region_id,
+                )
+            )
+            passed = False
+        elif region_class == 'graphic' and binding_iou is not None and binding_iou < thresholds['question_graphic_binding_iou_min'] + thresholds['slow_review_band']:
+            region_review_reasons.append(f'near_threshold_graphic_binding:{region_id}')
+
+        reports.append(
+            {
+                'page_index': page_index,
+                'page_role': page_role,
+                'subject_page_type': SUBJECT_PAGE_TYPE,
+                'region_id': region_id,
+                'region_class': region_class,
+                'region_type': region_type,
+                'required': required,
+                'evidence_mode': evidence_mode,
+                'formula_audit_status': formula_audit_status,
+                'bbox': bbox,
+                'region_similarity': similarity,
+                'bbox_iou': bbox_iou,
+                'binding_iou': binding_iou,
+                'thresholds': {
+                    'region_similarity_min': similarity_threshold,
+                    'bbox_iou_min': thresholds['bbox_iou_min'],
+                    'question_graphic_binding_iou_min': thresholds['question_graphic_binding_iou_min'],
+                },
+                'passed': passed,
+                'review_required': bool(region_review_reasons),
+                'review_reasons': region_review_reasons,
+                'evidence': evidence,
+            }
+        )
+        review_reasons.extend(region_review_reasons)
+    return reports, vetoes, review_reasons, readiness_failures
+
+
+def _build_question_order_check(
+    *,
+    page_index: int,
+    focus_tags: Sequence[str],
+    raw_order: object,
+    thresholds: Mapping[str, float],
+) -> tuple[dict[str, Any] | None, list[dict[str, Any]], list[str], list[str]]:
+    focus_tag_set = {str(tag).strip() for tag in focus_tags if str(tag).strip()}
+    requires_binding_evidence = bool({'graphic', 'question_order'} & focus_tag_set)
+    if raw_order is None and not requires_binding_evidence:
+        return None, [], [], []
+    if not isinstance(raw_order, Mapping):
+        return None, [], [], [f'question_order_missing:p{page_index}']
+
+    sequence_similarity = _optional_float(raw_order.get('sequence_similarity'))
+    expected_question_ids = [str(item).strip() for item in raw_order.get('expected_question_ids') or [] if str(item).strip()]
+    detected_question_ids = [str(item).strip() for item in raw_order.get('detected_question_ids') or [] if str(item).strip()]
+    question_blocks = list(raw_order.get('question_blocks') or [])
+    raw_binding_pairs = list(raw_order.get('binding_pairs') or [])
+
+    review_reasons: list[str] = []
+    readiness_failures: list[str] = []
+    vetoes: list[dict[str, Any]] = []
+    passed = True
+
+    if requires_binding_evidence and not raw_binding_pairs:
+        readiness_failures.append(f'binding_pairs_missing:p{page_index}')
+        passed = False
+
+    if sequence_similarity is None:
+        readiness_failures.append(f'question_order_similarity_missing:p{page_index}')
+        passed = False
+    elif sequence_similarity < thresholds['question_order_similarity_min']:
+        vetoes.append(
+            _make_veto(
+                code='question_order_similarity_below_threshold',
+                scope='page',
+                severity='p0',
+                reason=(
+                    f'question order similarity {sequence_similarity:.4f} below '
+                    f'{thresholds["question_order_similarity_min"]:.4f} on page {page_index}'
+                ),
+                blocking=True,
+                page_index=page_index,
+            )
+        )
+        passed = False
+    elif sequence_similarity < thresholds['question_order_similarity_min'] + thresholds['slow_review_band']:
+        review_reasons.append(f'near_threshold_question_order:p{page_index}')
+
+    if expected_question_ids != detected_question_ids:
+        vetoes.append(
+            _make_veto(
+                code='question_order_sequence_mismatch',
+                scope='page',
+                severity='p0',
+                reason=f'question order sequence mismatch on page {page_index}',
+                blocking=True,
+                page_index=page_index,
+                details=[f'expected={expected_question_ids}', f'detected={detected_question_ids}'],
+            )
+        )
+        passed = False
+
+    binding_pairs: list[dict[str, Any]] = []
+    for binding in raw_binding_pairs:
+        if not isinstance(binding, Mapping):
+            continue
+        question_id = str(binding.get('question_id') or '').strip()
+        graphic_region_id = str(binding.get('graphic_region_id') or '').strip()
+        bound = bool(binding.get('bound', True))
+        binding_iou = _optional_float(binding.get('binding_iou'))
+        binding_entry = {
+            'question_id': question_id,
+            'graphic_region_id': graphic_region_id,
+            'bound': bound,
+            'binding_iou': binding_iou,
+        }
+        binding_pairs.append(binding_entry)
+        if binding_iou is None:
+            readiness_failures.append(f'binding_pair_iou_missing:p{page_index}:{question_id or graphic_region_id or "unknown"}')
+            passed = False
+            continue
+        if (not bound) or binding_iou < thresholds['question_graphic_binding_iou_min']:
+            vetoes.append(
+                _make_veto(
+                    code='graphic_question_binding_below_threshold',
+                    scope='page',
+                    severity='p0',
+                    reason=(
+                        f'graphic/question binding invalid for {question_id or graphic_region_id} on page {page_index}'
+                    ),
+                    blocking=True,
+                    page_index=page_index,
+                    region_id=graphic_region_id or None,
+                )
+            )
+            passed = False
+        elif binding_iou < thresholds['question_graphic_binding_iou_min'] + thresholds['slow_review_band']:
+            review_reasons.append(f'near_threshold_graphic_binding:p{page_index}:{question_id}')
+
+    check = {
+        'page_index': page_index,
+        'subject_page_type': SUBJECT_PAGE_TYPE,
+        'expected_question_ids': expected_question_ids,
+        'detected_question_ids': detected_question_ids,
+        'question_blocks': question_blocks,
+        'sequence_similarity': sequence_similarity,
+        'binding_pairs': binding_pairs,
+        'thresholds': {
+            'question_order_similarity_min': thresholds['question_order_similarity_min'],
+            'question_graphic_binding_iou_min': thresholds['question_graphic_binding_iou_min'],
+        },
+        'passed': passed,
+        'review_required': bool(review_reasons),
+        'review_reasons': review_reasons,
+    }
+    return check, vetoes, review_reasons, readiness_failures
+
+
+def _build_evidence_paths(
+    contract: Mapping[str, Any],
+    render_pair_artifact: Mapping[str, Any] | None,
+    render_pair_artifact_path: str | None,
+) -> dict[str, Any]:
+    contract_paths = contract.get('evidence_paths') if isinstance(contract.get('evidence_paths'), Mapping) else {}
+    render_pair_paths = render_pair_artifact.get('evidence_paths') if isinstance(render_pair_artifact, Mapping) and isinstance(render_pair_artifact.get('evidence_paths'), Mapping) else {}
+    return {
+        'render_pair_artifact_path': render_pair_artifact_path,
+        'render_pair_output_root': str(render_pair_paths.get('output_root') or ''),
+        'source_pdf_render_dir': str(render_pair_paths.get('source_pdf_render_dir') or ''),
+        'output_docx_render_dir': str(render_pair_paths.get('output_docx_render_dir') or ''),
+        'docx_converted_pdf_path': str(render_pair_paths.get('docx_converted_pdf_path') or ''),
+        **{str(key): value for key, value in contract_paths.items()},
+    }
+
+
+def _build_downstream_contract(
+    *,
+    math_key_regions: Sequence[Mapping[str, Any]],
+    question_order_checks: Sequence[Mapping[str, Any]],
+    vetoes: Sequence[Mapping[str, Any]],
+    human_review_required: bool,
+) -> dict[str, Any]:
+    passthrough_regions = []
+    for region in math_key_regions:
+        region_class = str(region.get('region_class') or '').strip()
+        passthrough_regions.append(
+            {
+                'page_index': int(region.get('page_index') or 0),
+                'region_id': str(region.get('region_id') or ''),
+                'region_type': COMMON_REGION_TYPE_BY_CLASS.get(region_class, 'question_backbone'),
+                'required': bool(region.get('required', True)),
+                'bbox': dict(region.get('bbox') or {}),
+                'region_similarity': region.get('region_similarity'),
+                'bbox_iou': region.get('bbox_iou'),
+            }
+        )
+    return {
+        'subject_page_type': SUBJECT_PAGE_TYPE,
+        'key_regions': passthrough_regions,
+        'question_order_checks': list(question_order_checks),
+        'vetoes': list(vetoes),
+        'human_review_required': human_review_required,
+        'veto_forwarding_codes': sorted({str(veto.get('code') or '') for veto in vetoes if str(veto.get('code') or '')}),
+    }
+
+
+def _build_aggregate(
+    render_pairs: Sequence[object],
+    math_key_regions: Sequence[Mapping[str, Any]],
+    question_order_checks: Sequence[Mapping[str, Any]],
+    vetoes: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    return {
+        'render_pair_count': len(render_pairs),
+        'math_region_count': len(math_key_regions),
+        'formula_region_count': sum(1 for region in math_key_regions if region.get('region_class') == 'formula'),
+        'graphic_region_count': sum(1 for region in math_key_regions if region.get('region_class') == 'graphic'),
+        'table_region_count': sum(1 for region in math_key_regions if region.get('region_class') == 'table'),
+        'question_order_check_count': len(question_order_checks),
+        'blocking_veto_count': sum(1 for veto in vetoes if veto.get('blocking')),
+        'human_review_region_count': sum(1 for region in math_key_regions if region.get('review_required')),
+    }
+
+
+def _build_score_contract(
+    *,
+    gate_enabled: bool,
+    artifact_ready_for_scoring: bool,
+    blocking_vetoes: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    blocked = bool(blocking_vetoes)
+    if not gate_enabled:
+        skipped_score_reason = 'default_sync_excludes_math_visual_dimension'
+    elif not artifact_ready_for_scoring:
+        skipped_score_reason = 'math_visual_artifact_not_ready'
+    elif blocked:
+        skipped_score_reason = 'math_visual_veto_triggered'
+    else:
+        skipped_score_reason = None
+    return {
+        'dimension_key': 'math_visual_specialized',
+        'dimension_scope': 'feeds_visual_similarity_veto_only',
+        'enters_95_total_score': gate_enabled and artifact_ready_for_scoring,
+        'score_awarded': 1 if gate_enabled and artifact_ready_for_scoring and not blocked else 0,
+        'score_awarded_when_passed': 1,
+        'skipped_score_reason': skipped_score_reason,
+    }
+
+
+def _coerce_thresholds(payload: object) -> dict[str, float]:
+    thresholds = dict(DEFAULT_THRESHOLDS)
+    if isinstance(payload, Mapping):
+        for key in DEFAULT_THRESHOLDS:
+            if key in payload:
+                thresholds[key] = float(payload[key])
+    return thresholds
+
+
+def _make_veto(
+    *,
+    code: str,
+    scope: str,
+    severity: str,
+    reason: str,
+    blocking: bool,
+    page_index: int | None = None,
+    region_id: str | None = None,
+    details: Sequence[str] | None = None,
+) -> dict[str, Any]:
+    return {
+        'code': code,
+        'scope': scope,
+        'severity': severity,
+        'blocking': blocking,
+        'page_index': page_index,
+        'region_id': region_id,
+        'reason': reason,
+        'details': list(details or []),
+    }
+
+
+def _top_failure_code(failures: Sequence[str]) -> str:
+    if not failures:
+        return 'math_visual_artifact_not_ready'
+    return str(failures[0]).split(':', 1)[0]
+
+
+def _normalize_mode(mode: str | None) -> str:
+    return str(mode or '').strip().lower()
+
+
+def _optional_float(value: object) -> float | None:
+    if value is None or value == '':
+        return None
+    return float(value)
