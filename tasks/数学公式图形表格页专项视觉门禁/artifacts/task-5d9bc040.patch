new file mode 100644
index 0000000..2c4b6d3
--- /dev/null
+++ b/backend/tests/test_pdf_to_word_math_visual_gate.py
@@ -0,0 +1,250 @@
+from __future__ import annotations
+
+import copy
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.math_visual_gate import (
+    MATH_ARTIFACT_REQUIRED_FIELDS,
+    MATH_REGION_CLASSES,
+    MATH_VISUAL_GATE_VERSION,
+    QUALITY_HYBRID_ASYNC_MODE,
+    MathVisualGateError,
+    build_math_visual_gate_report,
+    load_math_visual_contract,
+    resolve_math_visual_mode,
+    write_math_visual_gate_artifact,
+)
+
+FIXTURE_DIR = Path(__file__).parent / 'fixtures' / 'pdf_to_word' / 'visual_similarity' / 'math'
+CONTRACT_PATH = FIXTURE_DIR / 'math_visual_contract.json'
+RENDER_PAIR_PATH = FIXTURE_DIR / 'math_render_pair.json'
+PLACEHOLDER = '__FIXTURE_ROOT__'
+
+
+def _load_json(path: Path) -> dict:
+    return json.loads(path.read_text(encoding='utf-8'))
+
+
+def _replace_placeholders(payload, *, root: Path):
+    if isinstance(payload, dict):
+        return {key: _replace_placeholders(value, root=root) for key, value in payload.items()}
+    if isinstance(payload, list):
+        return [_replace_placeholders(value, root=root) for value in payload]
+    if isinstance(payload, str):
+        return payload.replace(PLACEHOLDER, root.as_posix())
+    return payload
+
+
+def _iter_fixture_paths(payload, *, root: Path, parent_key: str = ''):
+    if isinstance(payload, dict):
+        for key, value in payload.items():
+            yield from _iter_fixture_paths(value, root=root, parent_key=key)
+        return
+    if isinstance(payload, list):
+        for value in payload:
+            yield from _iter_fixture_paths(value, root=root, parent_key=parent_key)
+        return
+    if isinstance(payload, str) and payload.startswith(root.as_posix()):
+        yield parent_key, Path(payload)
+
+
+def _ensure_fixture_path(parent_key: str, path: Path) -> None:
+    if parent_key.endswith('_dir') or parent_key == 'output_root':
+        path.mkdir(parents=True, exist_ok=True)
+        return
+    path.parent.mkdir(parents=True, exist_ok=True)
+    if path.exists():
+        return
+    if path.suffix == '.json':
+        path.write_text('{}\n', encoding='utf-8')
+    elif path.suffix in {'.html', '.md', '.txt', '.pdf'}:
+        path.write_text(f'fixture:{path.name}\n', encoding='utf-8')
+    else:
+        path.write_bytes(b'fixture')
+
+
+def _materialize_contract(tmp_path: Path) -> dict:
+    contract = _replace_placeholders(_load_json(CONTRACT_PATH), root=tmp_path)
+    render_pair_payload = _replace_placeholders(_load_json(RENDER_PAIR_PATH), root=tmp_path)
+    render_pair_path = Path(contract['render_pair_artifact_path'])
+    render_pair_path.parent.mkdir(parents=True, exist_ok=True)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+
+    for parent_key, path in _iter_fixture_paths(contract, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    for parent_key, path in _iter_fixture_paths(render_pair_payload, root=tmp_path):
+        _ensure_fixture_path(parent_key, path)
+    render_pair_path.write_text(json.dumps(render_pair_payload, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
+    return contract
+
