diff --git a/scripts/reserve-task.sh b/scripts/reserve-task.sh
new file mode 100755
index 0000000..94dc0af
--- /dev/null
+++ b/scripts/reserve-task.sh
@@ -0,0 +1,392 @@
+#!/bin/bash
+set -euo pipefail
+
+TASK_DIR=""
+TASK_ID=""
+AGENT_ID=""
+REASON=""
+RELEASE=0
+FORCE=0
+TTL_SECONDS=""
+UNTIL=""
+BY_ACTOR=""
+ORIGIN=""
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+WORKSPACE_ROOT="${WORKSPACE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
+TASKS_ROOT="${TASKS_ROOT:-$WORKSPACE_ROOT/tasks}"
+CONFIG_PATH="${CONFIG_PATH:-$WORKSPACE_ROOT/config.json}"
+
+usage() {
+  cat <<'USAGE'
+usage:
+  reserve-task.sh --task-dir <task-dir> --agent <agent-id> --reason <reason> [--ttl-seconds <seconds> | --until <iso8601>] [--force] [--by-actor <actor>] [--origin <origin>]
+  reserve-task.sh --task-id <task-id> --agent <agent-id> --reason <reason> [--ttl-seconds <seconds> | --until <iso8601>] [--force] [--by-actor <actor>] [--origin <origin>]
+  reserve-task.sh --task-dir <task-dir> --release --reason <reason> [--by-actor <actor>] [--origin <origin>]
+USAGE
+}
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --task-dir) TASK_DIR="${2:-}"; shift 2 ;;
+    --task-id) TASK_ID="${2:-}"; shift 2 ;;
+    --agent) AGENT_ID="${2:-}"; shift 2 ;;
+    --reason) REASON="${2:-}"; shift 2 ;;
+    --ttl-seconds) TTL_SECONDS="${2:-}"; shift 2 ;;
+    --until) UNTIL="${2:-}"; shift 2 ;;
+    --force) FORCE=1; shift ;;
+    --release) RELEASE=1; shift ;;
+    --by-actor) BY_ACTOR="${2:-}"; shift 2 ;;
+    --origin) ORIGIN="${2:-}"; shift 2 ;;
+    -h|--help) usage; exit 0 ;;
+    *) echo "unknown option: $1" >&2; usage >&2; exit 2 ;;
+  esac
+done
+
+if [ -z "$TASK_DIR" ] && [ -n "$TASK_ID" ]; then
+  TASK_DIR="$TASKS_ROOT/$TASK_ID"
+fi
+
+if [ -z "$TASK_DIR" ] || [ -z "$REASON" ]; then
+  usage >&2
+  exit 2
+fi
+
+if [ "$RELEASE" -ne 1 ] && [ -z "$AGENT_ID" ]; then
+  usage >&2
+  exit 2
+fi
+
+python3 - "$TASK_DIR" "$AGENT_ID" "$REASON" "$CONFIG_PATH" "$TTL_SECONDS" "$RELEASE" "$FORCE" "$UNTIL" "$BY_ACTOR" "$ORIGIN" <<'PY'
+from __future__ import annotations
+
+import json
+import os
+import sys
+import tempfile
+from datetime import datetime, timedelta
+from pathlib import Path
+
+PRE_RESERVABLE_STATUSES = {"pending", "pooled", "dependency_wait"}
+VALID_ORIGINS = {"manual_pm", "watcher_auto_preheat", "handoff"}
+
+task_dir = Path(sys.argv[1]).expanduser().resolve()
+agent_id = sys.argv[2].strip()
+reason = sys.argv[3].strip()
+config_path = Path(sys.argv[4]).expanduser().resolve()
+ttl_arg = sys.argv[5].strip()
+release_mode = sys.argv[6] == '1'
+force_mode = sys.argv[7] == '1'
+until_arg = sys.argv[8].strip()
+by_actor_arg = sys.argv[9].strip()
+origin_arg = sys.argv[10].strip()
+
+task_path = task_dir / 'task.json'
+transitions_path = task_dir / 'transitions.jsonl'
+tasks_root = task_dir.parent
+lock_path = task_dir / '.pre-reserve.lock'
+if not task_path.exists():
+    raise SystemExit(f'missing task.json: {task_path}')
+
+task = json.loads(task_path.read_text(encoding='utf-8'))
+config = json.loads(config_path.read_text(encoding='utf-8')) if config_path.exists() else {}
+
+
+def atomic_write(path: Path, payload: dict):
+    with tempfile.NamedTemporaryFile('w', delete=False, dir=str(path.parent), encoding='utf-8') as tmp:
+        json.dump(payload, tmp, ensure_ascii=False, indent=2)
+        tmp.write('\n')
+    os.replace(tmp.name, path)
+
+
+def parse_iso(value):
+    raw = str(value or '').strip()
+    if not raw:
+        return None
+    try:
+        dt = datetime.fromisoformat(raw.replace('Z', '+00:00'))
+    except Exception:
+        return None
+    if dt.tzinfo is None:
+        return dt.astimezone()
+    return dt.astimezone()
+
+
+def int_value(value, default):
+    try:
+        if value in (None, ''):
+            return default
+        return int(value)
+    except (TypeError, ValueError):
+        return default
+
+
+def normalized_claim_scope(current_task: dict) -> list[str]:
+    scope = current_task.get('claim_scope')
+    if isinstance(scope, list):
+        values = [str(item).strip() for item in scope if str(item).strip()]
+        if values:
+            return values
+
+    task_type = str(current_task.get('task_type') or '').strip().lower()
+    domain = str(current_task.get('domain') or '').strip().lower()
+    agents = config.get('agents') or {}
+    output: list[str] = []
+    for candidate, payload in agents.items():
+        role = str((payload or {}).get('role') or '').strip().lower()
+        if task_type in {'development', 'investigation'}:
+            if role == 'fullstack_dev' or str(candidate).startswith('dev-'):
+                output.append(str(candidate))
+        elif task_type == 'verification' or domain == 'quality':
+            if role == 'qa' or str(candidate).startswith('qa-'):
+                output.append(str(candidate))
+        elif task_type == 'design':
+            if role == 'architect' or str(candidate) == 'arch-1':
+                output.append(str(candidate))
+    return output
+
+
+def active_pre_reservation(current_task: dict, *, now: datetime | None = None):
+    if str(current_task.get('status') or '').strip().lower() not in PRE_RESERVABLE_STATUSES:
+        return None
+    pre_reserved_by = str(current_task.get('pre_reserved_by') or '').strip()
+    until_raw = str(current_task.get('pre_reserved_until') or current_task.get('pre_reserved_expires_at') or '').strip()
+    if not pre_reserved_by or not until_raw:
+        return None
+    until = parse_iso(until_raw)
+    now = now or datetime.now().astimezone()
+    if until is None or until <= now:
+        return None
+    return {
+        'agent_id': pre_reserved_by,
+        'until': until,
+        'until_raw': until_raw,
+        'by_actor': str(current_task.get('pre_reserved_by_actor') or '').strip(),
+        'reason': str(current_task.get('pre_reserved_reason') or '').strip(),
+        'origin': str(current_task.get('pre_reserved_origin') or '').strip(),
+    }
+
+
+def resolved_actor() -> str:
+    return (
+        by_actor_arg
+        or os.environ.get('PRE_RESERVED_BY_ACTOR', '').strip()
+        or os.environ.get('RESERVE_BY_ACTOR', '').strip()
+        or 'pm-chief'
+    )
+
+
+def resolved_origin() -> str:
+    value = (
+        origin_arg
+        or os.environ.get('PRE_RESERVED_ORIGIN', '').strip()
+        or os.environ.get('RESERVE_ORIGIN', '').strip()
+        or 'manual_pm'
+    )
+    if value not in VALID_ORIGINS:
+        raise SystemExit(f'invalid pre_reserved_origin: {value}')
+    return value
+
+
+def resolve_until(now: datetime) -> tuple[datetime, int | None]:
+    if until_arg:
+        until = parse_iso(until_arg)
+        if until is None:
+            raise SystemExit(f'invalid --until value: {until_arg}')
+        if until <= now:
+            raise SystemExit(f'--until must be in the future: {until_arg}')
+        ttl_seconds = max(1, int((until - now).total_seconds()))
+        return until, ttl_seconds
+    if ttl_arg:
+        ttl_seconds = max(1, int(ttl_arg))
+    else:
+        pool = config.get('task_pool') or {}
+        ttl_seconds = max(1, int(pool.get('default_pre_reserve_ttl_seconds') or pool.get('prewarm_reserve_ttl_seconds') or 1800))
+    return now + timedelta(seconds=ttl_seconds), ttl_seconds
+
+
+def reserved_limit_for(agent: str) -> int:
+    pool_config = config.get('task_pool') or {}
+    return max(1, int_value(pool_config.get('default_reserved_limit'), 1))
+
+
+def reserved_count_excluding_current_task(agent: str) -> int:
+    count = 0
+    now = datetime.now().astimezone()
+    for other_path in tasks_root.glob('*/task.json'):
+        if other_path.parent == task_dir:
+            continue
+        try:
+            other = json.loads(other_path.read_text(encoding='utf-8'))
+        except Exception:
+            continue
+        other_status = str(other.get('status') or '').strip().lower()
+        if other_status == 'dispatched' and str(other.get('assigned_agent') or '').strip() == agent:
+            count += 1
+            continue
+        other_reservation = active_pre_reservation(other, now=now)
+        if other_reservation and other_reservation['agent_id'] == agent:
+            count += 1
+    return count
+
+
+def archive_pre_reservation(current_task: dict, *, now_iso: str, release_reason: str):
+    previous_agent = str(current_task.get('pre_reserved_by') or '').strip()
+    previous_at = str(current_task.get('pre_reserved_at') or '').strip()
+    previous_until = str(current_task.get('pre_reserved_until') or current_task.get('pre_reserved_expires_at') or '').strip()
+    previous_actor = str(current_task.get('pre_reserved_by_actor') or '').strip()
+    previous_reason = str(current_task.get('pre_reserved_reason') or '').strip()
+    previous_origin = str(current_task.get('pre_reserved_origin') or '').strip()
+    if previous_agent:
+        current_task['last_pre_reserved_by'] = previous_agent
+    if previous_at:
+        current_task['last_pre_reserved_at'] = previous_at
+    if previous_until:
+        current_task['last_pre_reserved_until'] = previous_until
+    if previous_actor:
+        current_task['last_pre_reserved_by_actor'] = previous_actor
+    if previous_reason:
+        current_task['last_pre_reserved_reason'] = previous_reason
+    if previous_origin:
+        current_task['last_pre_reserved_origin'] = previous_origin
+    current_task['last_pre_reserved_released_at'] = now_iso
+    current_task['last_pre_reserved_release_reason'] = release_reason
+    for key in (
+        'pre_reserved_by',
+        'pre_reserved_at',
+        'pre_reserved_until',
+        'pre_reserved_expires_at',
+        'pre_reserved_by_actor',
+        'pre_reserved_reason',
+        'pre_reserved_origin',
+    ):
+        current_task.pop(key, None)
+
+
+status = str(task.get('status') or '').strip().lower()
+if status not in PRE_RESERVABLE_STATUSES:
+    raise SystemExit(f'task status must be one of {sorted(PRE_RESERVABLE_STATUSES)} to reserve/release, got {status}')
+
+if task_dir.joinpath('claim.json').exists() and not release_mode:
+    raise SystemExit('task already has pending claim.json; cannot prewarm reserve')
+
+agents = config.get('agents') or {}
+if not release_mode and agent_id not in agents:
+    raise SystemExit(f'agent {agent_id} not found in config.agents')
+
+scope = normalized_claim_scope(task)
+if not release_mode and scope and agent_id not in scope:
+    raise SystemExit(f'agent {agent_id} is not in claim_scope: {scope}')
+
+now = datetime.now().astimezone()
+now_iso = now.isoformat(timespec='seconds')
+actor = resolved_actor()
+origin = resolved_origin()
+
+lock_fd = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o644)
+try:
+    import fcntl
+    fcntl.flock(lock_fd, fcntl.LOCK_EX)
+
+    task = json.loads(task_path.read_text(encoding='utf-8'))
+    status = str(task.get('status') or '').strip().lower()
+    if status not in PRE_RESERVABLE_STATUSES:
+        raise SystemExit(f'task status changed while reserving: {status}')
+
+    active = active_pre_reservation(task, now=now)
+    stale_pre_reserve = any(task.get(key) for key in (
+        'pre_reserved_by', 'pre_reserved_at', 'pre_reserved_until', 'pre_reserved_expires_at',
+        'pre_reserved_by_actor', 'pre_reserved_reason', 'pre_reserved_origin'
+    )) and active is None
+
+    if release_mode:
+        previous_agent = str(task.get('pre_reserved_by') or '').strip()
+        if previous_agent or stale_pre_reserve:
+            archive_pre_reservation(task, now_iso=now_iso, release_reason=f'manual_release:{reason}')
+        task['updated_at'] = now_iso
+        atomic_write(task_path, task)
+        with transitions_path.open('a', encoding='utf-8') as fp:
+            fp.write(json.dumps({
+                'from': status,
+                'to': status,
+                'at': now_iso,
+                'event': 'pre_reserve_release',
+                'reason': f'reserve-task: released pre-reservation ({reason})',
+                'actor': actor,
+            }, ensure_ascii=False) + '\n')
+        print(json.dumps({
+            'task_id': str(task.get('id') or task_dir.name),
+            'released': True,
+            'previous_agent': previous_agent or None,
+            'released_at': now_iso,
+            'reason': reason,
+            'pre_reserved_by_actor': actor,
+            'pre_reserved_origin': origin,
+        }, ensure_ascii=False))
+        raise SystemExit(0)
+
+    if active and active['agent_id'] != agent_id and not force_mode:
+        raise SystemExit(f"task already pre-reserved for {active['agent_id']} until {active['until_raw']}")
+
+    reserved_count = reserved_count_excluding_current_task(agent_id)
+    reserved_limit = reserved_limit_for(agent_id)
+    if reserved_count >= reserved_limit and not force_mode:
+        raise SystemExit(
+            f'agent {agent_id} already reached reserved_limit={reserved_limit} '
+            f'(reserved_count_excluding_current_task={reserved_count})'
+        )
+
+    until_dt, ttl_seconds = resolve_until(now)
+    until_iso = until_dt.isoformat(timespec='seconds')
+    previous_agent = str(task.get('pre_reserved_by') or '').strip()
+    forced_override = False
+    if stale_pre_reserve:
+        archive_pre_reservation(task, now_iso=now_iso, release_reason='replaced_stale_pre_reservation')
+    elif active and (force_mode or previous_agent != agent_id):
+        forced_override = previous_agent != agent_id or force_mode
+        archive_pre_reservation(task, now_iso=now_iso, release_reason=f'force_override:{reason}' if force_mode else f'reassigned:{reason}')
+
+    task['pre_reserved_by'] = agent_id
+    task['pre_reserved_at'] = now_iso
+    task['pre_reserved_until'] = until_iso
+    task['pre_reserved_by_actor'] = actor
+    task['pre_reserved_reason'] = reason
+    task['pre_reserved_origin'] = origin
+    task['updated_at'] = now_iso
+    task.pop('pre_reserved_expires_at', None)
+    atomic_write(task_path, task)
+
+    event = 'pre_reserve_lock'
+    if forced_override:
+        event = 'pre_reserve_force_override'
+    with transitions_path.open('a', encoding='utf-8') as fp:
+        fp.write(json.dumps({
+            'from': status,
+            'to': status,
+            'at': now_iso,
+            'event': event,
+            'reason': f'reserve-task: pre-reserved for {agent_id} ({reason}) until {until_iso}',
+            'actor': actor,
+            'pre_reserved_origin': origin,
+            'forced': force_mode,
+            'previous_pre_reserved_by': previous_agent or None,
+        }, ensure_ascii=False) + '\n')
+
+    print(json.dumps({
+        'task_id': str(task.get('id') or task_dir.name),
+        'agent': agent_id,
+        'pre_reserved_at': now_iso,
+        'pre_reserved_until': until_iso,
+        'pre_reserved_by_actor': actor,
+        'pre_reserved_origin': origin,
+        'reason': reason,
+        'ttl_seconds': ttl_seconds,
+        'forced': force_mode,
+        'status': status,
+    }, ensure_ascii=False))
+finally:
+    try:
+        os.close(lock_fd)
+    except OSError:
+        pass
+PY
