+def test_generate_render_pairs_success_emits_png_hash_size_and_artifact(tmp_path: Path):
+    contract = _load_contract()
+    source_pdf = _write_minimal_pdf(tmp_path / "source.pdf", page_count=2)
+    output_docx = _write_placeholder_docx(tmp_path / "output.docx")
+
+    summary = generate_render_pairs(
+        source_pdf_path=source_pdf,
+        output_docx_path=output_docx,
+        output_root=tmp_path / "render-pair-success",
+        render_dpi=180,
+        docx_to_pdf_converter=_fake_docx_to_pdf_factory(page_count=2),
+    )
+
+    assert summary["report_type"] == RENDER_PAIR_REPORT_VERSION
+    assert summary["status"] == "success"
+    assert summary["ok"] is True
+    assert summary["failure_code"] is None
+    assert summary["page_counts"] == {"source_pdf": 2, "output_docx": 2, "matched": 2}
+    assert Path(summary["artifact_path"]).exists()
+    assert set(contract["required_top_level_fields"]) <= set(summary)
+    assert len(summary["render_pairs"]) == 2
+    for pair in summary["render_pairs"]:
+        assert pair["pair_status"] == "matched"
+        assert set(contract["required_pair_fields"]) <= set(pair)
+        source_page = pair["source_pdf"]
+        docx_page = pair["output_docx"]
+        assert Path(source_page["image_path"]).exists()
+        assert Path(docx_page["image_path"]).exists()
+        assert len(source_page["image_sha256"]) == 64
+        assert len(docx_page["image_sha256"]) == 64
+        assert source_page["page_size_points"]["width"] > 0
+        assert docx_page["page_size_points"]["height"] > 0
+
