+def convert_docx_to_pdf(
+    docx_path: str | Path,
+    *,
+    output_pdf_path: str | Path,
+    converter: Callable[[Path, Path], str | Path | None] | None = None,
+    timeout_seconds: int = DOCX_RENDER_TIMEOUT_SECONDS,
+) -> Path:
+    resolved_docx_path = Path(docx_path).expanduser().resolve()
+    resolved_output_pdf_path = Path(output_pdf_path).expanduser().resolve()
+
+    if not resolved_docx_path.exists():
+        raise PageRenderError(
+            "docx_not_found",
+            f"DOCX file not found: {resolved_docx_path}",
+            details={"docx_path": str(resolved_docx_path)},
+        )
+
+    resolved_output_pdf_path.parent.mkdir(parents=True, exist_ok=True)
+
+    if converter is not None:
+        try:
+            candidate = converter(resolved_docx_path, resolved_output_pdf_path)
+        except PageRenderError:
+            raise
+        except Exception as exc:
+            raise PageRenderError(
+                "docx_pdf_conversion_failed",
+                f"custom docx converter failed for {resolved_docx_path.name}",
+                details={"docx_path": str(resolved_docx_path), "error": str(exc)},
+            ) from exc
+        candidate_path = Path(candidate).expanduser().resolve() if candidate else resolved_output_pdf_path
+        if not candidate_path.exists():
+            raise PageRenderError(
+                "docx_pdf_missing",
+                "custom docx converter did not produce a PDF artifact",
+                details={
+                    "docx_path": str(resolved_docx_path),
+                    "expected_pdf_path": str(candidate_path),
+                },
+            )
+        if candidate_path != resolved_output_pdf_path:
+            shutil.copy2(candidate_path, resolved_output_pdf_path)
+        return resolved_output_pdf_path
+
+    renderer_binary = shutil.which("soffice") or shutil.which("libreoffice")
+    if not renderer_binary:
+        raise PageRenderError(
+            "docx_renderer_unavailable",
+            "LibreOffice/soffice is required to render DOCX pages into PDF",
+            details={"docx_path": str(resolved_docx_path)},
+        )
+
+    command = [
+        renderer_binary,
+        "--headless",
+        "--convert-to",
+        "pdf",
+        "--outdir",
+        str(resolved_output_pdf_path.parent),
+        str(resolved_docx_path),
+    ]
+    try:
+        completed = subprocess.run(command, capture_output=True, text=True, timeout=timeout_seconds)
+    except subprocess.TimeoutExpired as exc:
+        timeout_stdout = getattr(exc, "stdout", None)
+        if timeout_stdout is None:
+            timeout_stdout = getattr(exc, "output", None)
+        raise PageRenderError(
+            "docx_pdf_conversion_timeout",
+            f"docx to pdf conversion timed out for {resolved_docx_path.name}",
+            details={
+                "docx_path": str(resolved_docx_path),
+                "command": command,
+                "timeout_seconds": timeout_seconds,
+                "stdout": _normalize_process_output(timeout_stdout),
+                "stderr": _normalize_process_output(getattr(exc, "stderr", None)),
+            },
+        ) from exc
+    if completed.returncode != 0:
+        raise PageRenderError(
+            "docx_pdf_conversion_failed",
+            f"docx to pdf conversion failed for {resolved_docx_path.name}",
+            details={
+                "docx_path": str(resolved_docx_path),
+                "command": command,
+                "stdout": _normalize_process_output(completed.stdout),
+                "stderr": _normalize_process_output(completed.stderr),
+                "returncode": completed.returncode,
+            },
+        )
+
+    generated_pdf = resolved_output_pdf_path.parent / f"{resolved_docx_path.stem}.pdf"
+    candidate_path = generated_pdf if generated_pdf.exists() else resolved_output_pdf_path
+    if not candidate_path.exists():
+        raise PageRenderError(
+            "docx_pdf_missing",
+            f"docx conversion finished without a PDF artifact for {resolved_docx_path.name}",
+            details={
+                "docx_path": str(resolved_docx_path),
+                "expected_pdf_path": str(candidate_path),
+            },
+        )
+    if candidate_path != resolved_output_pdf_path:
+        shutil.move(str(candidate_path), str(resolved_output_pdf_path))
+    return resolved_output_pdf_path
+
+
+def render_docx_pages(
+    docx_path: str | Path,
+    *,
+    render_root: Path,
+    render_dpi: int,
+    converted_pdf_path: str | Path | None = None,
+    converter: Callable[[Path, Path], str | Path | None] | None = None,
+    timeout_seconds: int = DOCX_RENDER_TIMEOUT_SECONDS,
+) -> dict:
+    resolved_docx_path = Path(docx_path).expanduser().resolve()
+    resolved_render_root = Path(render_root).expanduser().resolve()
+    resolved_render_root.mkdir(parents=True, exist_ok=True)
+
+    pdf_path = (
+        Path(converted_pdf_path).expanduser().resolve()
+        if converted_pdf_path is not None
+        else resolved_render_root / f"{resolved_docx_path.stem}.rendered.pdf"
+    )
+    converted_pdf = convert_docx_to_pdf(
+        resolved_docx_path,
+        output_pdf_path=pdf_path,
+        converter=converter,
+        timeout_seconds=timeout_seconds,
+    )
+    pages = render_pdf_pages(
+        converted_pdf,
+        source_name=resolved_docx_path.name,
+        render_root=resolved_render_root,
+        render_dpi=render_dpi,
+        metadata_extra={
+            "source_docx": str(resolved_docx_path),
+            "converted_pdf_path": str(converted_pdf),
+        },
+    )
+    return {
+        "docx_path": str(resolved_docx_path),
+        "converted_pdf_path": str(converted_pdf),
+        "pages": pages,
+    }
