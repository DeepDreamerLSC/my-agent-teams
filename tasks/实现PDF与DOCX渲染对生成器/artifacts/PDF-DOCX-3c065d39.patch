+def test_generate_render_pairs_surfaces_default_converter_timeout(tmp_path: Path, monkeypatch):
+    source_pdf = _write_minimal_pdf(tmp_path / "source-timeout.pdf", page_count=1)
+    output_docx = _write_placeholder_docx(tmp_path / "timeout-output.docx")
+
+    def _fake_which(binary: str) -> str | None:
+        return "/fake/bin/soffice" if binary == "soffice" else None
+
+    def _timeout_run(command, **kwargs):
+        raise subprocess.TimeoutExpired(
+            cmd=command,
+            timeout=kwargs["timeout"],
+            output="partial stdout",
+            stderr="partial stderr",
+        )
+
+    monkeypatch.setattr(page_renderer.shutil, "which", _fake_which)
+    monkeypatch.setattr(page_renderer.subprocess, "run", _timeout_run)
+
+    summary = generate_render_pairs(
+        source_pdf_path=source_pdf,
+        output_docx_path=output_docx,
+        output_root=tmp_path / "render-pair-timeout",
+        render_dpi=180,
+    )
+
+    assert summary["status"] == "failed"
+    assert summary["ok"] is False
+    assert summary["failure_code"] == "docx_pdf_conversion_timeout"
+    assert summary["errors"][0]["code"] == "docx_pdf_conversion_timeout"
+    assert summary["errors"][0]["details"]["timeout_seconds"] == page_renderer.DOCX_RENDER_TIMEOUT_SECONDS
+    assert summary["errors"][0]["details"]["stdout"] == "partial stdout"
+    assert summary["errors"][0]["details"]["stderr"] == "partial stderr"
+    assert Path(summary["artifact_path"]).exists()
+
+    artifact_payload = json.loads(Path(summary["artifact_path"]).read_text(encoding="utf-8"))
+    assert artifact_payload["status"] == "failed"
+    assert artifact_payload["failure_code"] == "docx_pdf_conversion_timeout"
+    assert artifact_payload["errors"][0]["code"] == "docx_pdf_conversion_timeout"
+
+
