+def test_generate_render_pairs_surfaces_docx_conversion_failure(tmp_path: Path):
+    source_pdf = _write_minimal_pdf(tmp_path / "source.pdf", page_count=1)
+    output_docx = _write_placeholder_docx(tmp_path / "broken-output.docx")
+
+    def _broken_converter(docx_path: Path, output_pdf_path: Path) -> Path:
+        raise RuntimeError("converter exploded")
+
+    summary = generate_render_pairs(
+        source_pdf_path=source_pdf,
+        output_docx_path=output_docx,
+        output_root=tmp_path / "render-pair-failure",
+        render_dpi=180,
+        docx_to_pdf_converter=_broken_converter,
+    )
+
+    assert summary["status"] == "failed"
+    assert summary["ok"] is False
+    assert summary["failure_code"] == "docx_pdf_conversion_failed"
+    assert summary["errors"][0]["code"] == "docx_pdf_conversion_failed"
+    assert "converter exploded" in summary["errors"][0]["details"]["error"]
+    assert Path(summary["artifact_path"]).exists()
+
