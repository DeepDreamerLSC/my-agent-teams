+++ b/backend/app/services/pdf_to_word/render_pair_generator.py
@@ -0,0 +1,169 @@
+from __future__ import annotations
+
+import json
+from datetime import datetime
+from pathlib import Path
+from typing import Callable
+
+from app.services.pdf_to_word.page_renderer import PageRenderError, render_docx_pages, render_pdf_pages
+
+
+RENDER_PAIR_REPORT_VERSION = "pdf_to_word_render_pair/v1"
+RENDER_PAIR_ARTIFACT_NAME = "render_pair.json"
+
+
+def write_render_pair_artifact(summary: dict, output_root: str | Path) -> Path:
+    target_root = Path(output_root).expanduser().resolve()
+    target_root.mkdir(parents=True, exist_ok=True)
+    artifact_path = target_root / RENDER_PAIR_ARTIFACT_NAME
+    artifact_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+    return artifact_path
+
+
+def generate_render_pairs(
+    *,
+    source_pdf_path: str | Path,
+    output_docx_path: str | Path,
+    output_root: str | Path,
+    render_dpi: int = 180,
+    source_name: str | None = None,
+    docx_to_pdf_converter: Callable[[Path, Path], str | Path | None] | None = None,
+) -> dict:
+    resolved_source_pdf_path = Path(source_pdf_path).expanduser().resolve()
+    resolved_output_docx_path = Path(output_docx_path).expanduser().resolve()
+    resolved_output_root = Path(output_root).expanduser().resolve()
+    source_render_root = resolved_output_root / "source_pdf"
+    docx_render_root = resolved_output_root / "output_docx"
+
+    summary = {
+        "report_type": RENDER_PAIR_REPORT_VERSION,
+        "generated_at": datetime.now().astimezone().isoformat(timespec="seconds"),
+        "source_name": source_name or resolved_source_pdf_path.name,
+        "source_pdf_path": str(resolved_source_pdf_path),
+        "output_docx_path": str(resolved_output_docx_path),
+        "render_dpi": int(render_dpi),
+        "status": "failed",
+        "ok": False,
+        "failure_code": None,
+        "errors": [],
+        "page_counts": {
+            "source_pdf": 0,
+            "output_docx": 0,
+            "matched": 0,
+        },
+        "render_pairs": [],
+        "evidence_paths": {
+            "output_root": str(resolved_output_root),
+            "source_pdf_render_dir": str(source_render_root),
+            "output_docx_render_dir": str(docx_render_root),
+            "docx_converted_pdf_path": None,
+        },
+    }
+
+    resolved_output_root.mkdir(parents=True, exist_ok=True)
+
+    try:
+        source_pages = render_pdf_pages(
+            resolved_source_pdf_path,
+            source_name=summary["source_name"],
+            render_root=source_render_root,
+            render_dpi=render_dpi,
+        )
+    except PageRenderError as exc:
+        summary["failure_code"] = exc.code
+        summary["errors"].append(exc.to_dict())
+        artifact_path = write_render_pair_artifact(summary, resolved_output_root)
+        summary["artifact_path"] = str(artifact_path)
+        return summary
+
+    try:
+        docx_render = render_docx_pages(
+            resolved_output_docx_path,
+            render_root=docx_render_root,
+            render_dpi=render_dpi,
+            converter=docx_to_pdf_converter,
+        )
+    except PageRenderError as exc:
+        summary["page_counts"]["source_pdf"] = len(source_pages)
+        summary["failure_code"] = exc.code
+        summary["errors"].append(exc.to_dict())
+        artifact_path = write_render_pair_artifact(summary, resolved_output_root)
+        summary["artifact_path"] = str(artifact_path)
+        return summary
+
+    docx_pages = list(docx_render.get("pages") or [])
+    summary["evidence_paths"]["docx_converted_pdf_path"] = str(docx_render.get("converted_pdf_path") or "")
+    summary["page_counts"] = {
+        "source_pdf": len(source_pages),
+        "output_docx": len(docx_pages),
+        "matched": min(len(source_pages), len(docx_pages)),
+    }
+    summary["render_pairs"] = _build_render_pairs(source_pages, docx_pages)
+
+    if len(source_pages) != len(docx_pages):
+        summary["status"] = "page_count_mismatch"
+        summary["failure_code"] = "page_count_mismatch"
+        summary["errors"].append(
+            {
+                "code": "page_count_mismatch",
+                "message": "source PDF page count does not match rendered DOCX page count",
+                "details": {
+                    "source_pdf_page_count": len(source_pages),
+                    "output_docx_page_count": len(docx_pages),
+                },
+            }
+        )
+        artifact_path = write_render_pair_artifact(summary, resolved_output_root)
+        summary["artifact_path"] = str(artifact_path)
+        return summary
+
+    summary["status"] = "success"
+    summary["ok"] = True
+    artifact_path = write_render_pair_artifact(summary, resolved_output_root)
+    summary["artifact_path"] = str(artifact_path)
+    return summary
+
+
+def _build_render_pairs(source_pages: list[dict], docx_pages: list[dict]) -> list[dict]:
+    max_page_count = max(len(source_pages), len(docx_pages))
+    results: list[dict] = []
+    for index in range(max_page_count):
+        source_page = source_pages[index] if index < len(source_pages) else None
+        docx_page = docx_pages[index] if index < len(docx_pages) else None
+        if source_page is not None and docx_page is not None:
+            pair_status = "matched"
+        elif source_page is not None:
+            pair_status = "source_only"
+        else:
+            pair_status = "docx_only"
+
+        results.append(
+            {
+                "page_index": index + 1,
+                "pair_status": pair_status,
+                "alignment_mode": "page_index",
+                "source_pdf": _normalize_page_payload(source_page),
+                "output_docx": _normalize_page_payload(docx_page),
+            }
+        )
+    return results
+
+
+def _normalize_page_payload(page: dict | None) -> dict | None:
+    if page is None:
+        return None
+    return {
+        "page_index": int(page.get("page_index") or 0),
+        "image_path": str(page.get("image_path") or ""),
+        "image_sha256": str(page.get("image_sha256") or ""),
+        "render_artifact": str(page.get("render_artifact") or ""),
+        "page_size_points": {
+            "width": float(page.get("width_points") or 0.0),
+            "height": float(page.get("height_points") or 0.0),
+        },
+        "pixel_size": {
+            "width": int(page.get("pixel_width") or 0),
+            "height": int(page.get("pixel_height") or 0),
+        },
+        "rotation_degrees": int(page.get("rotation_degrees") or 0),
+    }
