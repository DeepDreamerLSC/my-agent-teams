{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-agent-teams.local/tasks/ack.schema.json",
  "title": "Phase 1 Ack Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "agent",
    "acked_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "acked_at": {
      "type": "string",
      "format": "date-time"
    },
    "note": {
      "type": "string"
    }
  }
}
