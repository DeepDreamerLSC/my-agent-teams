@@ -0,0 +1,142 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "fidelity"
+MANIFEST_PATH = FIXTURE_DIR / "fidelity_manifest.json"
+SCHEMA_PATH = FIXTURE_DIR / "fidelity_manifest.schema.json"
+
+
+def _load_json(path: Path) -> dict:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def _load_manifest() -> dict:
+    return _load_json(MANIFEST_PATH)
+
+
+def _current_sample_map(manifest: dict) -> dict[str, dict]:
+    return {
+        sample["sample_name"]: sample
+        for sample in manifest["sample_sets"]["current_samples"]
+    }
+
+
+def test_manifest_schema_requires_expected_top_level_sections():
+    schema = _load_json(SCHEMA_PATH)
+
+    assert schema["$schema"] == "https://json-schema.org/draft/2020-12/schema"
+    assert schema["title"] == "PDF to Word Fidelity Manifest"
+    assert set(schema["required"]) == {
+        "manifest_version",
+        "manifest_name",
+        "frozen_at",
+        "target",
+        "source_documents",
+        "release_boundary",
+        "aggregate_facts",
+        "scoring_dimensions",
+        "p0_blockers",
+        "sample_sets",
+    }
+
+
+
+def test_manifest_freezes_all_eight_scoring_dimensions_and_weight_sum():
+    manifest = _load_manifest()
+    dimensions = manifest["scoring_dimensions"]
+
+    assert manifest["manifest_version"] == "pdf_to_word_fidelity_manifest/v1"
+    assert len(dimensions) == 8
+    assert [item["key"] for item in dimensions] == [
+        "text_and_question_backbone",
+        "exerciseir_structure",
+        "editable_word_tables",
+        "image_and_graph_attachments",
+        "formula_and_special_symbols",
+        "answer_and_work_area",
+        "visual_similarity",
+        "stability_and_audit",
+    ]
+    assert sum(item["weight"] for item in dimensions) == 100
+    assert {item["weight"] for item in dimensions if item["key"] == "editable_word_tables"} == {18}
+
+
+
+def test_manifest_freezes_target_mode_and_p0_blockers():
+    manifest = _load_manifest()
+
+    assert manifest["target"] == {
+        "score_threshold": 95,
+        "score_scale": 100,
+        "mode": "quality/hybrid_async",
+        "default_sync_policy": "apple default + hybrid_experimental quality gray + formula audit-only / merge-disabled",
+    }
+    assert manifest["release_boundary"]["quality_target_scope"] == "quality/hybrid_async only"
+    assert {item["key"] for item in manifest["p0_blockers"]} == {
+        "docx_invalid",
+        "baseline_text_regression",
+        "question_order_regression",
+        "table_detected_but_no_word_table",
+        "candidate_assignment_missing",
+        "silent_fallback",
+        "default_sync_slowdown",
+    }
+
+
+
+def test_manifest_current_samples_cover_four_positive_or_mixed_and_one_negative():
+    manifest = _load_manifest()
+    current_samples = manifest["sample_sets"]["current_samples"]
+    sample_map = _current_sample_map(manifest)
+
+    assert manifest["aggregate_facts"]["sample_count"] == len(current_samples) == 5
+    assert manifest["aggregate_facts"]["sample_with_table_xml_count"] == 2
+    assert manifest["aggregate_facts"]["document_fallback_sample_count"] == 1
+    assert {sample["sample_name"] for sample in current_samples} == {
+        "五下科学",
