+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+from app.services.pdf_to_word.answer_section_gate import evaluate_answer_section_gate, load_answer_section_gate_payload
+
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "answer_section"
+
+
+def _load_payload(name: str) -> dict:
+    return load_answer_section_gate_payload(FIXTURE_DIR / name)
+
+
+def test_load_answer_section_gate_payload_reads_fixture_contract():
+    payload = _load_payload("authoritative_summary.json")
+
+    assert payload["aggregate"]["sample_count"] == 5
+    assert {sample["sample_name"] for sample in payload["samples"]} == {
+        "五下科学",
+        "数学八年级",
+        "数学试卷",
+        "英语八年级",
+        "语文五年级",
+    }
+
+
+def test_student_gate_stays_in_mainline_but_excludes_answer_capability():
+    report = evaluate_answer_section_gate(_load_payload("authoritative_summary.json"), variant="student")
+
+    assert report["variant"] == "student"
+    assert report["included_in_main_final_fidelity"] is True
+    assert report["answer_capability_included_in_main_final_fidelity"] is False
+    assert report["decision"] == "pass"
+    assert report["blockers"] == []
+    assert report["checks"]["student_answer_heading_leak_guard"]["ok"] is True
+    assert "答案区、教师版、解析区能力不在该结论内" in report["recommended_pm_wording"]
+
+
+def test_student_gate_vetoes_when_answer_heading_leaks_into_student_output():
+    report = evaluate_answer_section_gate(_load_payload("student_leak_regression.json"), variant="student")
+
+    assert report["included_in_main_final_fidelity"] is True
+    assert report["decision"] == "no_go"
+    assert report["blockers"] == ["student_answer_heading_regressed"]
+    assert report["checks"]["student_answer_heading_leak_guard"]["actual"] is True
+
+
+def test_teacher_gate_is_independent_and_rejects_incomplete_authoritative_coverage():
+    report = evaluate_answer_section_gate(_load_payload("authoritative_summary.json"), variant="teacher")
+
+    assert report["included_in_main_final_fidelity"] is False
+    assert report["decision"] == "not_ready"
+    assert report["checks"]["teacher_coverage_complete"]["actual"] == 2
+    assert report["checks"]["teacher_coverage_complete"]["expected"] == 5
+    assert "teacher_coverage_incomplete:2/5" in report["blockers"]
+    assert "teacher_missing_answer_heading:英语八年级" in report["blockers"]
+    assert "teacher_missing_answer_heading:语文五年级" in report["blockers"]
+    assert "不应混入主线 final fidelity" in report["recommended_pm_wording"]
+
+
+def test_teacher_gate_can_pass_independently_once_full_coverage_is_ready():
+    report = evaluate_answer_section_gate(_load_payload("teacher_full_coverage.json"), variant="teacher")
+
+    assert report["included_in_main_final_fidelity"] is False
+    assert report["decision"] == "pass"
+    assert report["blockers"] == []
+    assert report["checks"]["teacher_output_variant_implemented"]["ok"] is True
+    assert report["checks"]["teacher_coverage_complete"]["actual"] == 3
+    assert report["checks"]["teacher_coverage_complete"]["expected"] == 3
+
+
+def test_answer_and_analysis_variants_remain_out_of_mainline_until_they_are_real_outputs():
+    payload = _load_payload("authoritative_summary.json")
+
+    answer_report = evaluate_answer_section_gate(payload, variant="answer")
+    analysis_report = evaluate_answer_section_gate(payload, variant="analysis")
+
+    assert answer_report["included_in_main_final_fidelity"] is False
+    assert answer_report["decision"] == "not_ready"
+    assert "output_variant_not_implemented:answer" in answer_report["blockers"]
+    assert "answer_signal_coverage_incomplete:3/5" in answer_report["blockers"]
+
+    assert analysis_report["included_in_main_final_fidelity"] is False
+    assert analysis_report["decision"] == "not_ready"
+    assert "output_variant_not_implemented:analysis" in analysis_report["blockers"]
+    assert "analysis_signal_coverage_incomplete:2/5" in analysis_report["blockers"]
+
+
+def test_load_helper_returns_plain_json_object_for_followup_serialization():
+    payload = _load_payload("teacher_full_coverage.json")
+    serialized = json.dumps(payload, ensure_ascii=False)
+
+    assert '"implemented_output_variants"' in serialized
