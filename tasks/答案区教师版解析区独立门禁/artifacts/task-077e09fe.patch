+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any, Literal, Mapping, cast
+
+
+ANSWER_SECTION_GATE_VERSION = "pdf_to_word_answer_section_gate/v1"
+AnswerSectionVariant = Literal["student", "teacher", "answer", "analysis"]
+AnswerSectionGateDecision = Literal["pass", "no_go", "not_ready", "not_applicable"]
+
+_SUPPORTED_VARIANTS = frozenset({"student", "teacher", "answer", "analysis"})
+_DEFAULT_IMPLEMENTED_OUTPUT_VARIANTS = frozenset({"student", "teacher", "review"})
+
+
+def load_answer_section_gate_payload(path: str | Path) -> dict[str, Any]:
+    payload = json.loads(Path(path).expanduser().resolve().read_text(encoding="utf-8"))
+    if not isinstance(payload, dict):
+        raise ValueError("answer section gate payload must be a JSON object")
+    return payload
+
+
+def evaluate_answer_section_gate(
+    payload: Mapping[str, Any],
+    *,
+    variant: AnswerSectionVariant | str,
+) -> dict[str, Any]:
+    normalized_variant = _normalize_variant(variant)
+    aggregate = _mapping(payload.get("aggregate"))
+    gate_context = _mapping(payload.get("gate_context"))
+    samples = _sample_list(payload.get("samples"))
+    sample_count = int(aggregate.get("sample_count") or len(samples))
+    implemented_output_variants = _implemented_output_variants(gate_context)
+
+    report: dict[str, Any] = {
+        "report_type": "pdf_to_word_answer_section_independent_gate",
+        "version": ANSWER_SECTION_GATE_VERSION,
+        "variant": normalized_variant,
+        "included_in_main_final_fidelity": normalized_variant == "student",
+        "main_final_fidelity_scope": _main_final_scope(normalized_variant),
+        "answer_capability_included_in_main_final_fidelity": False,
+        "independent_gate_applicable": True,
+        "decision": "not_applicable",
+        "decision_summary": "",
+        "checks": {},
+        "warnings": [],
+        "blockers": [],
+        "evidence": {
+            "sample_count": sample_count,
+            "answer_area_hit_sample_count": int(aggregate.get("answer_area_hit_sample_count") or 0),
+            "answer_section_hit_sample_count": int(aggregate.get("answer_section_hit_sample_count") or 0),
+            "teacher_samples_with_answer_heading": int(aggregate.get("teacher_samples_with_answer_heading") or 0),
+            "student_contains_answer_heading_regressed": bool(aggregate.get("student_contains_answer_heading_regressed")),
+            "implemented_output_variants": sorted(implemented_output_variants),
+        },
+        "sample_breakdown": [_project_sample(sample) for sample in samples],
+        "recommended_pm_wording": "",
+    }
+
+    if normalized_variant == "student":
+        return _evaluate_student_gate(report, aggregate=aggregate, sample_count=sample_count)
+    if normalized_variant == "teacher":
+        return _evaluate_teacher_gate(
+            report,
+            aggregate=aggregate,
+            samples=samples,
+            sample_count=sample_count,
+            implemented_output_variants=implemented_output_variants,
+        )
+    if normalized_variant == "answer":
+        return _evaluate_answer_gate(
+            report,
+            aggregate=aggregate,
+            samples=samples,
+            sample_count=sample_count,
+            implemented_output_variants=implemented_output_variants,
+        )
+    return _evaluate_analysis_gate(
+        report,
+        aggregate=aggregate,
+        samples=samples,
+        sample_count=sample_count,
+        implemented_output_variants=implemented_output_variants,
+    )
+
+
+def _evaluate_student_gate(
+    report: dict[str, Any],
+    *,
+    aggregate: Mapping[str, Any],
+    sample_count: int,
+) -> dict[str, Any]:
+    leakage_regressed = bool(aggregate.get("student_contains_answer_heading_regressed"))
+    report["checks"] = {
+        "student_answer_heading_leak_guard": _check(
+            ok=not leakage_regressed,
+            actual=leakage_regressed,
+            expected=False,
+            severity="blocker",
+            detail="student 主线只允许保留题目正文，不允许把答案标题泄漏进最终输出。",
+        ),
+        "student_scope_excludes_answer_capability": _check(
+            ok=True,
+            actual="question_body_only",
+            expected="question_body_only",
+            severity="info",
+            detail="主线 final fidelity 仅覆盖 student 题干/题目结构，不覆盖答案区、教师版、解析区能力。",
+        ),
+    }
+    if sample_count <= 0:
+        report["decision"] = "not_ready"
+        report["blockers"] = ["no_authoritative_samples"]
+        report["decision_summary"] = "缺少 authoritative 样例，无法确认 student 主线是否守住答案泄漏边界。"
+        report["recommended_pm_wording"] = "当前缺少 authoritative student 样例，主线 final fidelity 暂不能补充答案区边界结论。"
+        return report
+    if leakage_regressed:
+        report["decision"] = "no_go"
+        report["blockers"] = ["student_answer_heading_regressed"]
+        report["decision_summary"] = "student 输出已出现答案标题泄漏，主线 final fidelity 不能继续视为通过。"
+        report["recommended_pm_wording"] = "student 主线出现答案标题泄漏，当前 final fidelity 结论需立即降级。"
+        return report
+
+    report["decision"] = "pass"
+    report["decision_summary"] = "student 主线保持题目正文边界，未把答案标题混入主线输出。"
+    report["recommended_pm_wording"] = (
+        "主线 final fidelity 仅覆盖 student 题目正文/结构；答案区、教师版、解析区能力不在该结论内，"
+        "且当前 student 未出现答案标题泄漏。"
+    )
+    return report
+
+
+def _evaluate_teacher_gate(
+    report: dict[str, Any],
+    *,
+    aggregate: Mapping[str, Any],
+    samples: list[dict[str, Any]],
+    sample_count: int,
+    implemented_output_variants: frozenset[str],
+) -> dict[str, Any]:
+    implemented = "teacher" in implemented_output_variants
+    teacher_hits = int(aggregate.get("teacher_samples_with_answer_heading") or 0)
+    missing_samples = [
+        str(sample.get("sample_name") or f"sample-{index + 1}")
+        for index, sample in enumerate(samples)
+        if not bool(sample.get("teacher_contains_answer_heading"))
+    ]
+    report["checks"] = {
+        "teacher_output_variant_implemented": _check(
+            ok=implemented,
+            actual=implemented,
+            expected=True,
+            severity="blocker",
+            detail="teacher 变体虽然已存在渲染链路，但必须单独走答案区专项门禁。",
+        ),
+        "teacher_coverage_complete": _check(
+            ok=sample_count > 0 and teacher_hits == sample_count and not missing_samples,
+            actual=teacher_hits,
+            expected=sample_count,
+            severity="blocker",
+            detail="teacher 版要对外宣称可交付，必须在 authoritative 样例集中稳定出现 teacher 答案标题/答案块。",
+        ),
+    }
+    blockers: list[str] = []
+    if not implemented:
+        blockers.append("output_variant_not_implemented:teacher")
+    if sample_count <= 0:
+        blockers.append("no_authoritative_samples")
+    if teacher_hits != sample_count:
+        blockers.append(f"teacher_coverage_incomplete:{teacher_hits}/{sample_count}")
+    blockers.extend(f"teacher_missing_answer_heading:{sample_name}" for sample_name in missing_samples)
+    report["blockers"] = blockers
+
+    if not blockers:
+        report["decision"] = "pass"
+        report["decision_summary"] = "teacher 版答案/解析能力已在独立门禁下覆盖全部 authoritative 样例。"
+        report["recommended_pm_wording"] = "teacher 版答案/解析能力已通过独立门禁，但该结论仍不混入主线 final fidelity。"
+        return report
+
+    report["decision"] = "not_ready"
+    report["decision_summary"] = "teacher 版只能单列专项门禁；当前 authoritative 覆盖不足，不能并入主线或对外宣称全学科通过。"
+    report["recommended_pm_wording"] = (
+        "teacher 版答案/解析能力只能按专项门禁单列；当前 authoritative 样例仍有缺口，"
+        "暂不具备全学科通过结论，也不应混入主线 final fidelity。"
+    )
+    return report
+
+
+def _evaluate_answer_gate(
+    report: dict[str, Any],
+    *,
+    aggregate: Mapping[str, Any],
+    samples: list[dict[str, Any]],
+    sample_count: int,
+    implemented_output_variants: frozenset[str],
+) -> dict[str, Any]:
+    implemented = "answer" in implemented_output_variants
+    answer_signal_samples = _answer_signal_sample_count(aggregate, samples)
+    report["checks"] = {
+        "answer_output_variant_implemented": _check(
+            ok=implemented,
+            actual=implemented,
+            expected=True,
+            severity="blocker",
+            detail="answer-only 变体尚未成为主链一等输出变体，不能直接对外承诺。",
+        ),
+        "answer_signal_coverage_complete": _check(
+            ok=sample_count > 0 and answer_signal_samples == sample_count,
+            actual=answer_signal_samples,
+            expected=sample_count,
+            severity="blocker",
+            detail="answer-only 变体若要对外声明，至少要在 authoritative 样例上形成完整答案信号覆盖。",
+        ),
+    }
+    blockers: list[str] = []
+    if not implemented:
+        blockers.append("output_variant_not_implemented:answer")
+    if sample_count <= 0:
+        blockers.append("no_authoritative_samples")
+    if answer_signal_samples != sample_count:
+        blockers.append(f"answer_signal_coverage_incomplete:{answer_signal_samples}/{sample_count}")
+    report["blockers"] = blockers
+
+    if not blockers:
+        report["decision"] = "pass"
+        report["decision_summary"] = "answer-only 变体已具备独立输出与样例覆盖，可单独按专项门禁说明。"
+        report["recommended_pm_wording"] = "answer-only 变体已通过独立门禁，但不属于当前主线 final fidelity 口径。"
+        return report
+
+    report["decision"] = "not_ready"
+    report["decision_summary"] = "answer-only 变体尚未形成可对外承诺的实现与 coverage，不纳入主线 final fidelity。"
+    report["recommended_pm_wording"] = "answer-only 变体暂未纳入当前对外能力说明，只保留为独立专项待补齐。"
+    return report
+
+
+def _evaluate_analysis_gate(
+    report: dict[str, Any],
+    *,
+    aggregate: Mapping[str, Any],
+    samples: list[dict[str, Any]],
+    sample_count: int,
+    implemented_output_variants: frozenset[str],
+) -> dict[str, Any]:
+    implemented = "analysis" in implemented_output_variants
+    analysis_signal_samples = _analysis_signal_sample_count(aggregate, samples)
+    report["checks"] = {
+        "analysis_output_variant_implemented": _check(
+            ok=implemented,
+            actual=implemented,
+            expected=True,
+            severity="blocker",
+            detail="analysis-only 变体当前未作为主链稳定输出，不能直接并入 final fidelity。",
+        ),
+        "analysis_signal_coverage_complete": _check(
+            ok=sample_count > 0 and analysis_signal_samples == sample_count,
+            actual=analysis_signal_samples,
+            expected=sample_count,
+            severity="blocker",
+            detail="analysis-only 变体若要单独承诺，需要 authoritative 样例层面形成稳定解析命中。",
+        ),
+    }
+    blockers: list[str] = []
+    if not implemented:
+        blockers.append("output_variant_not_implemented:analysis")
+    if sample_count <= 0:
+        blockers.append("no_authoritative_samples")
+    if analysis_signal_samples != sample_count:
+        blockers.append(f"analysis_signal_coverage_incomplete:{analysis_signal_samples}/{sample_count}")
+    report["blockers"] = blockers
+
+    if not blockers:
+        report["decision"] = "pass"
+        report["decision_summary"] = "analysis-only 变体已具备独立输出与 authoritative coverage，可单列专项通过。"
+        report["recommended_pm_wording"] = "analysis-only 变体已通过独立门禁，但不计入当前主线 final fidelity。"
+        return report
+
+    report["decision"] = "not_ready"
+    report["decision_summary"] = "analysis-only 变体尚未形成稳定独立输出与 coverage，不纳入主线 final fidelity。"
+    report["recommended_pm_wording"] = "解析区能力暂不纳入当前主线 final fidelity，只保留专项跟踪结论。"
+    return report
+
+
+def _project_sample(sample: Mapping[str, Any]) -> dict[str, Any]:
+    return {
+        "sample_name": str(sample.get("sample_name") or ""),
+        "status": str(sample.get("status") or ""),
+        "answer_area_count": int(sample.get("answer_area_count") or 0),
+        "answer_section_count": int(sample.get("answer_section_count") or 0),
+        "teacher_contains_answer_heading": bool(sample.get("teacher_contains_answer_heading")),
+        "student_contains_answer_heading": bool(sample.get("student_contains_answer_heading")),
+        "answer_source_types": list(sample.get("answer_source_types") or []),
+        "explanation": str(sample.get("explanation") or ""),
+    }
+
+
+def _implemented_output_variants(gate_context: Mapping[str, Any]) -> frozenset[str]:
+    raw = gate_context.get("implemented_output_variants")
+    if not isinstance(raw, list) or not raw:
+        return _DEFAULT_IMPLEMENTED_OUTPUT_VARIANTS
+    normalized = {
+        str(item).strip().lower()
+        for item in raw
+        if str(item).strip()
+    }
+    return frozenset(normalized or _DEFAULT_IMPLEMENTED_OUTPUT_VARIANTS)
+
+
+def _answer_signal_sample_count(aggregate: Mapping[str, Any], samples: list[dict[str, Any]]) -> int:
+    explicit = aggregate.get("answer_signal_sample_count")
+    if explicit is not None:
+        return int(explicit or 0)
+    return sum(
+        1
+        for sample in samples
+        if int(sample.get("answer_area_count") or 0) > 0
+        or int(sample.get("answer_section_count") or 0) > 0
+    )
+
+
+def _analysis_signal_sample_count(aggregate: Mapping[str, Any], samples: list[dict[str, Any]]) -> int:
+    explicit = aggregate.get("analysis_signal_sample_count")
+    if explicit is not None:
+        return int(explicit or 0)
+    count = 0
+    for sample in samples:
+        sections = sample.get("answer_sections") or []
+        titles = {str(section.get("title") or "").strip() for section in sections if isinstance(section, Mapping)}
+        source_types = {
+            str(section.get("source_type") or "").strip()
+            for section in sections
+            if isinstance(section, Mapping)
+        }
+        if "analysis_heading" in source_types or any("解析" in title for title in titles):
+            count += 1
+    return count
+
+
+def _check(*, ok: bool, actual: Any, expected: Any, severity: str, detail: str) -> dict[str, Any]:
+    return {
+        "ok": bool(ok),
+        "actual": actual,
+        "expected": expected,
+        "severity": severity,
+        "detail": detail,
+    }
+
+
+def _main_final_scope(variant: AnswerSectionVariant) -> str:
+    if variant == "student":
+        return "主线 final fidelity 仅覆盖 student 题干/题目结构，不覆盖答案区、教师版、解析区能力。"
+    if variant == "teacher":
+        return "teacher 版答案/解析能力必须单独门禁，不纳入当前主线 final fidelity 记分。"
+    if variant == "answer":
+        return "answer-only 变体不在当前主线 final fidelity 范围内，只能走独立专项门禁。"
+    return "analysis-only 变体不在当前主线 final fidelity 范围内，只能走独立专项门禁。"
+
+
+def _normalize_variant(variant: AnswerSectionVariant | str) -> AnswerSectionVariant:
+    candidate = str(variant or "").strip().lower()
+    if candidate not in _SUPPORTED_VARIANTS:
+        raise ValueError(f"unsupported answer section gate variant: {variant}")
+    return cast(AnswerSectionVariant, candidate)
+
+
+def _mapping(value: Any) -> dict[str, Any]:
+    return dict(value) if isinstance(value, Mapping) else {}
+
+
+def _sample_list(value: Any) -> list[dict[str, Any]]:
+    if not isinstance(value, list):
+        return []
+    return [dict(item) for item in value if isinstance(item, Mapping)]
