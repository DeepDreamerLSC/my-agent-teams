diff --git a/backend/app/services/pdf_to_word/fidelity_gate.py b/backend/app/services/pdf_to_word/fidelity_gate.py
new file mode 100644
index 0000000..4515e30
--- /dev/null
+++ b/backend/app/services/pdf_to_word/fidelity_gate.py
@@ -0,0 +1,210 @@
+from __future__ import annotations
+
+from io import BytesIO
+from pathlib import Path
+import re
+import zipfile
+from xml.etree import ElementTree as ET
+
+_DOCX_MAIN_NS = "http://schemas.openxmlformats.org/wordprocessingml/2006/main"
+_PKG_REL_NS = "http://schemas.openxmlformats.org/package/2006/relationships"
+_OFFICE_REL_NS = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
+_IMAGE_REL_TYPE = "http://schemas.openxmlformats.org/officeDocument/2006/relationships/image"
+_NS = {
+    "w": _DOCX_MAIN_NS,
+    "pr": _PKG_REL_NS,
+}
+_IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp", ".emf", ".wmf"}
+_TABLE_FALLBACK_TEXT_PATTERNS = (
+    re.compile(r"表格占位"),
+    re.compile(r"table[\s_-]?fallback", re.IGNORECASE),
+    re.compile(r"table[\s_-]?placeholder", re.IGNORECASE),
+    re.compile(r"image[\s_-]?fallback", re.IGNORECASE),
+)
+_TABLE_FALLBACK_PATH_PATTERNS = (
+    re.compile(r"table.*fallback", re.IGNORECASE),
+    re.compile(r"fallback.*table", re.IGNORECASE),
+    re.compile(r"table.*placeholder", re.IGNORECASE),
+    re.compile(r"placeholder.*table", re.IGNORECASE),
+)
+
+
+def inspect_docx_package(source: str | Path | bytes | bytearray) -> dict[str, object]:
+    path, payload = _coerce_docx_source(source)
+    result: dict[str, object] = {
+        "source_path": str(path) if path else None,
+        "docx_valid": False,
+        "content_types_present": False,
+        "package_relationships_present": False,
+        "word_document_xml_present": False,
+        "document_xml_parseable": False,
+        "document_relationships_present": False,
+        "archive_entry_count": 0,
+        "w_tbl_count": 0,
+        "w_tr_count": 0,
+        "w_tc_count": 0,
+        "w_drawing_count": 0,
+        "has_table_xml": False,
+        "word_media_count": 0,
+        "word_media_entries": [],
+        "media_relationship_count": 0,
+        "media_relationship_targets": [],
+        "image_fallback_table_count": 0,
+        "fallback_text_markers": [],
+        "fallback_media_entries": [],
+        "errors": [],
+        "warnings": [],
+    }
+
+    try:
+        with zipfile.ZipFile(BytesIO(payload)) as archive:
+            names = archive.namelist()
+            name_set = set(names)
+            result["archive_entry_count"] = len(names)
+            result["content_types_present"] = "[Content_Types].xml" in name_set
+            result["package_relationships_present"] = "_rels/.rels" in name_set
+            result["word_document_xml_present"] = "word/document.xml" in name_set
+            result["document_relationships_present"] = "word/_rels/document.xml.rels" in name_set
+
+            media_entries = sorted(
+                name
+                for name in names
+                if name.startswith("word/media/") and Path(name).suffix.lower() in _IMAGE_EXTENSIONS
+            )
+            result["word_media_entries"] = media_entries
+            result["word_media_count"] = len(media_entries)
+
+            document_xml = ""
+            if result["word_document_xml_present"]:
+                try:
+                    document_xml = archive.read("word/document.xml").decode("utf-8", errors="replace")
+                except KeyError:
+                    result["errors"] = [*result["errors"], "missing:word/document.xml"]
+
+            if document_xml:
+                try:
+                    root = ET.fromstring(document_xml)
+                except ET.ParseError as exc:
+                    result["errors"] = [*result["errors"], f"document_xml_parse_error:{exc}"]
+                else:
+                    result["document_xml_parseable"] = True
+                    result["w_tbl_count"] = len(root.findall(".//w:tbl", _NS))
+                    result["w_tr_count"] = len(root.findall(".//w:tr", _NS))
+                    result["w_tc_count"] = len(root.findall(".//w:tc", _NS))
+                    result["w_drawing_count"] = len(root.findall(".//w:drawing", _NS))
+                    body_text = " ".join(part.strip() for part in root.itertext() if str(part).strip())
+                    result["fallback_text_markers"] = _collect_fallback_text_markers(body_text)
+
+            relationship_targets: list[str] = []
+            if result["document_relationships_present"]:
+                try:
+                    rels_xml = archive.read("word/_rels/document.xml.rels").decode("utf-8", errors="replace")
+                except KeyError:
+                    result["errors"] = [*result["errors"], "missing:word/_rels/document.xml.rels"]
+                else:
+                    try:
+                        rels_root = ET.fromstring(rels_xml)
+                    except ET.ParseError as exc:
+                        result["errors"] = [*result["errors"], f"document_relationships_parse_error:{exc}"]
+                    else:
+                        for rel in rels_root.findall(".//pr:Relationship", _NS):
+                            rel_type = str(rel.attrib.get("Type") or "").strip()
+                            target = str(rel.attrib.get("Target") or "").strip()
+                            if rel_type == _IMAGE_REL_TYPE or "media/" in target:
+                                relationship_targets.append(target)
+            result["media_relationship_targets"] = relationship_targets
+            result["media_relationship_count"] = len(relationship_targets)
+
+            fallback_media_entries = _collect_fallback_media_entries(media_entries, relationship_targets)
+            result["fallback_media_entries"] = fallback_media_entries
+            result["image_fallback_table_count"] = max(
+                len(fallback_media_entries),
+                len(result["fallback_text_markers"]),
+            )
+            result["has_table_xml"] = bool(result["w_tbl_count"])
+            result["docx_valid"] = bool(
+                result["content_types_present"]
+                and result["package_relationships_present"]
+                and result["word_document_xml_present"]
+                and result["document_xml_parseable"]
+            )
+    except zipfile.BadZipFile:
+        result["errors"] = [*result["errors"], "bad_zip"]
+    except OSError as exc:
+        result["errors"] = [*result["errors"], f"io_error:{exc}"]
+
+    return result
+
+
+def evaluate_docx_table_gate(
+    source: str | Path | bytes | bytearray,
+    *,
+    detected_table_count: int = 0,
+    expected_table_count: int = 0,
+) -> dict[str, object]:
+    inspection = inspect_docx_package(source)
+    blockers: list[str] = []
+    warnings = list(inspection.get("warnings") or [])
+
+    if not inspection["docx_valid"]:
+        blockers.append("docx_invalid")
+    if not inspection["word_document_xml_present"]:
+        blockers.append("word_document_xml_missing")
+    if not inspection["package_relationships_present"]:
+        blockers.append("package_relationships_missing")
+    if not inspection["document_relationships_present"]:
+        blockers.append("document_relationships_missing")
+
+    table_signal_count = max(
+        _non_negative_int(detected_table_count),
+        _non_negative_int(expected_table_count),
+        _non_negative_int(inspection["image_fallback_table_count"]),
+    )
+    if table_signal_count > 0 and not inspection["has_table_xml"]:
+        blockers.append("table_detected_but_no_word_table")
+    if inspection["image_fallback_table_count"]:
+        warnings.append("image_fallback_detected")
+
+    pass_gate = not blockers
+    return {
+        **inspection,
+        "detected_table_count": _non_negative_int(detected_table_count),
+        "expected_table_count": _non_negative_int(expected_table_count),
+        "table_signal_count": table_signal_count,
+        "status": "pass" if pass_gate else "fail",
+        "pass": pass_gate,
+        "blockers": blockers,
+        "warnings": sorted(set(warnings)),
+    }
+
+
+def _coerce_docx_source(source: str | Path | bytes | bytearray) -> tuple[Path | None, bytes]:
+    if isinstance(source, (bytes, bytearray)):
+        return None, bytes(source)
+    path = Path(source).expanduser().resolve()
+    return path, path.read_bytes()
+
+
+def _collect_fallback_text_markers(body_text: str) -> list[str]:
+    markers: list[str] = []
+    for pattern in _TABLE_FALLBACK_TEXT_PATTERNS:
+        matches = pattern.findall(body_text)
+        markers.extend(str(match) for match in matches)
+    return markers
+
+
+def _collect_fallback_media_entries(media_entries: list[str], relationship_targets: list[str]) -> list[str]:
+    entries: dict[str, str] = {}
+    for candidate in [*media_entries, *relationship_targets]:
+        base_name = Path(candidate).name
+        if any(pattern.search(base_name) for pattern in _TABLE_FALLBACK_PATH_PATTERNS):
+            entries.setdefault(base_name, candidate)
+    return [entries[key] for key in sorted(entries)]
+
+
+def _non_negative_int(value: object) -> int:
+    try:
+        parsed = int(value)
+    except (TypeError, ValueError):
+        return 0
+    return max(parsed, 0)
diff --git a/backend/tests/test_pdf_to_word_fidelity_gate.py b/backend/tests/test_pdf_to_word_fidelity_gate.py
new file mode 100644
index 0000000..242342c
--- /dev/null
+++ b/backend/tests/test_pdf_to_word_fidelity_gate.py
@@ -0,0 +1,106 @@
+from __future__ import annotations
+
+import importlib.util
+import json
+from pathlib import Path
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "docx_inspect"
+CASES_PATH = FIXTURE_DIR / "cases.json"
+MODULE_PATH = Path(__file__).resolve().parents[1] / "app" / "services" / "pdf_to_word" / "fidelity_gate.py"
+
+_spec = importlib.util.spec_from_file_location("pdf_to_word_fidelity_gate", MODULE_PATH)
+assert _spec is not None and _spec.loader is not None
+_module = importlib.util.module_from_spec(_spec)
+_spec.loader.exec_module(_module)
+evaluate_docx_table_gate = _module.evaluate_docx_table_gate
+inspect_docx_package = _module.inspect_docx_package
+
+
+def _load_cases() -> dict:
+    return json.loads(CASES_PATH.read_text(encoding="utf-8"))
+
+
+def _fixture_path(name: str) -> Path:
+    return FIXTURE_DIR / name
+
+
+def test_inspect_docx_reports_table_xml_and_cell_counts_for_positive_fixture():
+    cases = _load_cases()
+    fixture = _fixture_path(cases["valid_table"]["file"])
+
+    result = inspect_docx_package(fixture)
+
+    assert result["docx_valid"] is True
+    assert result["word_document_xml_present"] is True
+    assert result["document_relationships_present"] is True
+    assert result["w_tbl_count"] == 1
+    assert result["w_tr_count"] == 2
+    assert result["w_tc_count"] == 6
+    assert result["has_table_xml"] is True
+    assert result["image_fallback_table_count"] == 0
+    assert result["word_media_count"] == 0
+
+
+def test_gate_blocks_detected_table_without_word_table_and_exposes_fallback_trace():
+    cases = _load_cases()
+    case = cases["image_fallback_only"]
+    fixture = _fixture_path(case["file"])
+
+    result = evaluate_docx_table_gate(fixture, detected_table_count=case["detected_table_count"])
+
+    assert result["docx_valid"] is True
+    assert result["has_table_xml"] is False
+    assert result["word_media_count"] == 1
+    assert result["image_fallback_table_count"] == 1
+    assert result["status"] == "fail"
+    assert result["pass"] is False
+    assert "table_detected_but_no_word_table" in result["blockers"]
+    assert "image_fallback_detected" in result["warnings"]
+
+
+def test_gate_distinguishes_missing_document_relationships():
+    cases = _load_cases()
+    case = cases["missing_document_relationships"]
+    fixture = _fixture_path(case["file"])
+
+    result = evaluate_docx_table_gate(fixture, detected_table_count=case["detected_table_count"])
+
+    assert result["word_document_xml_present"] is True
+    assert result["document_relationships_present"] is False
+    assert result["docx_valid"] is True
+    assert result["status"] == "fail"
+    assert "document_relationships_missing" in result["blockers"]
+
+
+def test_gate_distinguishes_missing_word_document_xml():
+    cases = _load_cases()
+    fixture = _fixture_path(cases["missing_word_document"]["file"])
+
+    result = evaluate_docx_table_gate(fixture)
+
+    assert result["word_document_xml_present"] is False
+    assert result["docx_valid"] is False
+    assert result["status"] == "fail"
+    assert "word_document_xml_missing" in result["blockers"]
+
+
+def test_gate_distinguishes_invalid_zip_docx():
+    cases = _load_cases()
+    fixture = _fixture_path(cases["invalid_zip"]["file"])
+
+    result = evaluate_docx_table_gate(fixture)
+
+    assert result["docx_valid"] is False
+    assert result["status"] == "fail"
+    assert "docx_invalid" in result["blockers"]
+    assert "bad_zip" in result["errors"]
+
+
+def test_gate_output_is_json_serializable():
+    cases = _load_cases()
+    fixture = _fixture_path(cases["valid_table"]["file"])
+
+    result = evaluate_docx_table_gate(fixture, detected_table_count=1, expected_table_count=1)
+
+    encoded = json.dumps(result, ensure_ascii=False)
+    assert "\"status\": \"pass\"" in encoded
