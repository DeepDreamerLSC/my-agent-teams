+
+
+def render_docx_pages(
+    docx_path: str | Path,
+    *,
+    render_root: Path,
+    render_dpi: int,
+    converted_pdf_path: str | Path | None = None,
+    converter: Callable[[Path, Path], str | Path | None] | None = None,
+    timeout_seconds: int = DOCX_RENDER_TIMEOUT_SECONDS,
+    allow_text_fallback: bool = True,
+    expected_page_count: int | None = None,
+    fallback_page_size: tuple[int, int] | None = None,
+) -> dict:
+    resolved_docx_path = Path(docx_path).expanduser().resolve()
+    resolved_render_root = Path(render_root).expanduser().resolve()
+    resolved_render_root.mkdir(parents=True, exist_ok=True)
+
+    pdf_path = (
+        Path(converted_pdf_path).expanduser().resolve()
