+        raise PageRenderError(
+            "docx_pdf_conversion_timeout",
+            f"docx to pdf conversion timed out for {resolved_docx_path.name}",
+            details={
+                "docx_path": str(resolved_docx_path),
+                "command": command,
+                "timeout_seconds": timeout_seconds,
+                "stdout": _normalize_process_output(timeout_stdout),
+                "stderr": _normalize_process_output(getattr(exc, "stderr", None)),
+            },
+        ) from exc
+    if completed.returncode != 0:
+        raise PageRenderError(
+            "docx_pdf_conversion_failed",
+            f"docx to pdf conversion failed for {resolved_docx_path.name}",
+            details={
+                "docx_path": str(resolved_docx_path),
+                "command": command,
+                "stdout": _normalize_process_output(completed.stdout),
+                "stderr": _normalize_process_output(completed.stderr),
+                "returncode": completed.returncode,
+            },
+        )
