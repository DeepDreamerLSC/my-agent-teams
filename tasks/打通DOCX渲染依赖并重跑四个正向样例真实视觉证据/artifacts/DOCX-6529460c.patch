+        else resolved_render_root / f"{resolved_docx_path.stem}.rendered.pdf"
+    )
+    try:
+        converted_pdf = convert_docx_to_pdf(
+            resolved_docx_path,
+            output_pdf_path=pdf_path,
+            converter=converter,
