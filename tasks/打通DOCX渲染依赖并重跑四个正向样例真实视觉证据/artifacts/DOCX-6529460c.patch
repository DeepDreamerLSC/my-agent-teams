+def score_render_pair_images(render_pair: Mapping[str, Any], *, thumbnail_size: tuple[int, int] = (256, 256)) -> list[dict[str, Any]]:
+    page_scores: list[dict[str, Any]] = []
+    for pair in render_pair.get("render_pairs") or []:
+        if not isinstance(pair, Mapping):
+            continue
+        page_index = int(pair.get("page_index") or 0)
+        pair_status = str(pair.get("pair_status") or "unknown")
+        source_image_path = pair.get("source_image_path")
+        docx_image_path = pair.get("docx_image_path")
+        score: float | None = None
+        review_reasons: list[str] = []
+        if pair_status != "matched":
+            review_reasons.append(f"render_pair_{pair_status}")
+        elif not source_image_path or not docx_image_path:
+            review_reasons.append("render_pair_image_path_missing")
+        else:
+            try:
+                score = compare_page_images(source_image_path, docx_image_path, thumbnail_size=thumbnail_size)
+            except Exception as exc:  # pragma: no cover - image decoder errors vary by platform
+                review_reasons.append(f"image_compare_failed:{exc}")
+        if score is not None:
+            if score < DEFAULT_THRESHOLDS["critical_page_render_similarity_min"]:
+                review_reasons.append("critical_page_similarity_below_threshold")
+        page_scores.append(
+            {
+                "page_index": page_index,
+                "pair_status": pair_status,
+                "page_role": "critical",
