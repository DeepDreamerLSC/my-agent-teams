+    output_pdf_path: str | Path,
+    converter: Callable[[Path, Path], str | Path | None] | None = None,
+    timeout_seconds: int = DOCX_RENDER_TIMEOUT_SECONDS,
+) -> Path:
+    resolved_docx_path = Path(docx_path).expanduser().resolve()
+    resolved_output_pdf_path = Path(output_pdf_path).expanduser().resolve()
+
+    if not resolved_docx_path.exists():
+        raise PageRenderError(
+            "docx_not_found",
+            f"DOCX file not found: {resolved_docx_path}",
+            details={"docx_path": str(resolved_docx_path)},
+        )
+
+    resolved_output_pdf_path.parent.mkdir(parents=True, exist_ok=True)
+
+    if converter is not None:
