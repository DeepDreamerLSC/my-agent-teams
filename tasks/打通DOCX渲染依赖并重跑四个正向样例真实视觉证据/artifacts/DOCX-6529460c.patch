+        human_review_reasons.append("render_pair_not_ready")
+    if not page_scores:
+        blocking_failures.append("page_scores_missing")
+        human_review_reasons.append("page_scores_missing")
+
+    min_page_score = aggregate.get("min_page_similarity")
+    overall_score = aggregate.get("overall_page_similarity_mean")
+    if overall_score is not None and overall_score < threshold_values["document_overall_similarity_min"]:
+        human_review_reasons.append("document_similarity_below_threshold")
+    if min_page_score is not None and min_page_score < threshold_values["critical_page_render_similarity_min"]:
+        human_review_reasons.append("critical_page_similarity_below_threshold")
+
+    artifact_ready_for_scoring = gate_enabled and render_pair_ready and bool(page_scores)
+    gate_passed = bool(
+        artifact_ready_for_scoring
+        and overall_score is not None
+        and overall_score >= threshold_values["document_overall_similarity_min"]
+        and min_page_score is not None
+        and min_page_score >= threshold_values["critical_page_render_similarity_min"]
+    )
+    if not artifact_ready_for_scoring:
+        status = "artifact_not_ready"
+        failure_code = blocking_failures[0] if blocking_failures else "visual_similarity_artifact_not_ready"
+    elif gate_passed:
+        status = "passed"
+        failure_code = None
+    else:
+        status = "scored_no_go"
+        failure_code = "visual_similarity_below_threshold"
+
+    vetoes = []
+    if not artifact_ready_for_scoring:
+        vetoes.append(
+            {
+                "code": "visual_similarity_artifact_not_ready",
+                "scope": "document",
+                "severity": "p0",
+                "blocking": True,
+                "reason": "render pair or page-level similarity evidence is not ready for scoring",
+                "details": list(blocking_failures),
+            }
+        )
+    elif not gate_passed:
+        vetoes.append(
+            {
+                "code": "visual_similarity_below_threshold",
+                "scope": "document",
+                "severity": "p0",
+                "blocking": True,
+                "reason": "real render-pair similarity is below the human visual threshold",
+                "details": {
+                    "overall_page_similarity_mean": overall_score,
+                    "min_page_similarity": min_page_score,
+                    "thresholds": threshold_values,
+                },
+            }
+        )
+
+    return {
+        "report_type": VISUAL_SIMILARITY_REPORT_TYPE,
+        "contract_version": VISUAL_SIMILARITY_GATE_VERSION,
+        "artifact_name": VISUAL_SIMILARITY_ARTIFACT_NAME,
+        "implementation_status": "real_render_pair_scored" if artifact_ready_for_scoring else "render_pair_not_ready",
+        "status": status,
+        "failure_code": failure_code,
+        "sample_name": sample_name,
+        "subject": subject,
+        "document_page_type": document_page_type,
+        "mode_boundary": {
+            "requested_mode": _normalize_mode(requested_mode),
+            "parser_backend": parser_backend,
+            "resolved_gate_mode": gate_mode,
+            "enabled": gate_enabled,
+            "default_sync_safe": True,
+            "default_sync_invokes_render_or_slow_model": False,
+            "reason": "visual similarity counts only in quality/hybrid_async",
+        },
+        "score_contract": {
+            "dimension_key": VISUAL_SIMILARITY_DIMENSION_KEY,
+            "dimension_weight": VISUAL_SIMILARITY_DIMENSION_WEIGHT,
+            "eligible_for_final_score": artifact_ready_for_scoring,
+            "counts_toward_final_score": artifact_ready_for_scoring,
+            "reason": "real render pair + page scores ready" if artifact_ready_for_scoring else "artifact not ready",
+        },
+        "thresholds": threshold_values,
+        "render_pair_status": render_pair_status,
+        "render_pair_failure_code": render_pair.get("failure_code"),
+        "renderer_strategy": render_pair.get("renderer_strategy"),
+        "fallback_used": bool(render_pair.get("fallback_used")),
+        "render_pairs": list(render_pair.get("render_pairs") or []),
+        "page_scores": page_scores,
+        "key_regions": [],
+        "vetoes": vetoes,
+        "blocking_failures": blocking_failures,
+        "human_review_required": bool(human_review_reasons) or not gate_passed,
+        "human_review_reasons": sorted(set(human_review_reasons)),
+        "aggregate": aggregate,
+        "artifact_ready_for_scoring": artifact_ready_for_scoring,
+        "gate_passed": gate_passed,
+        "slow_model_policy": {
+            "candidate_models": ["qwen3_vl_8b"],
+            "disallowed_modes": ["fast", "balanced", DEFAULT_SYNC_MODE],
+            "fallback_action": "manual_review",
+        },
+        "slow_model_review": {
+            "enabled": False,
+            "selected_page_count": 0,
+            "executed_page_count": 0,
+            "fallback_page_count": 0,
+            "pages": [],
+            "status": "not_requested",
+        },
+    }
+
+
+def build_visual_similarity_gate_report(
+    contract: Mapping[str, Any],
+    *,
+    requested_mode: str | None = None,
+    parser_backend: str | None = None,
+) -> dict[str, Any]:
+    _validate_contract(contract)
+    render_pair = _load_render_pair_artifact(contract)
+    return build_visual_similarity_report_from_render_pair(
+        render_pair,
+        sample_name=str(contract.get("sample_name") or ""),
+        subject=str(contract.get("subject") or "") or None,
+        document_page_type=str(contract.get("subject_page_type") or contract.get("document_page_type") or "") or None,
+        requested_mode=requested_mode,
+        parser_backend=parser_backend,
+        thresholds=contract.get("thresholds") if isinstance(contract.get("thresholds"), Mapping) else None,
+    )
+
+
+def _validate_contract(contract: Mapping[str, Any]) -> None:
+    required = {"contract_version", "source_policy", "thresholds", "slow_model_policy", "artifact_contract", "page_scores", "key_regions", "evidence_paths"}
+    missing = sorted(required - set(contract))
+    if missing:
+        raise VisualSimilarityGateError(f"missing visual similarity contract fields: {missing}")
+    if str(contract.get("contract_version") or "") != VISUAL_SIMILARITY_GATE_VERSION:
+        raise VisualSimilarityGateError("unsupported visual similarity contract_version")
+    source_policy = contract.get("source_policy") if isinstance(contract.get("source_policy"), Mapping) else {}
+    if int(source_policy.get("visual_similarity_weight") or 0) != VISUAL_SIMILARITY_DIMENSION_WEIGHT:
+        raise VisualSimilarityGateError("visual_similarity_weight must remain 17 in the 95-point route")
+
+
+def _load_render_pair_artifact(contract: Mapping[str, Any]) -> Mapping[str, Any]:
+    inline_payload = contract.get("render_pair_artifact")
+    if isinstance(inline_payload, Mapping):
+        return inline_payload
+    path_value = str(contract.get("render_pair_artifact_path") or "").strip()
+    if not path_value:
+        return {}
+    path = Path(path_value).expanduser().resolve()
+    if not path.exists():
+        return {"status": "missing", "ok": False, "failure_code": "render_pair_artifact_missing"}
+    try:
+        payload = json.loads(path.read_text(encoding="utf-8"))
+    except Exception as exc:  # pragma: no cover
+        return {"status": "invalid", "ok": False, "failure_code": f"render_pair_artifact_unreadable:{exc}"}
+    return payload if isinstance(payload, Mapping) else {"status": "invalid", "ok": False, "failure_code": "render_pair_artifact_not_object"}
+
+
+def _build_aggregate(page_scores: Sequence[Mapping[str, Any]], render_pairs: Sequence[object]) -> dict[str, Any]:
+    numeric_scores = [
+        float(item["page_render_similarity"])
+        for item in page_scores
+        if item.get("page_render_similarity") not in (None, "")
+    ]
+    return {
+        "render_pair_count": len(render_pairs),
+        "page_score_count": len(page_scores),
+        "render_pair_ready_page_count": sum(
+            1 for pair in render_pairs if isinstance(pair, Mapping) and str(pair.get("pair_status") or "") == "matched"
+        ),
+        "overall_page_similarity_mean": round(sum(numeric_scores) / len(numeric_scores), 4) if numeric_scores else None,
+        "min_page_similarity": round(min(numeric_scores), 4) if numeric_scores else None,
+        "max_page_similarity": round(max(numeric_scores), 4) if numeric_scores else None,
+    }
+
+
+def _normalize_mode(requested_mode: str | None) -> str:
+    return str(requested_mode or "").strip().lower()
diff --git a/backend/app/services/pdf_to_word/workspace.py b/backend/app/services/pdf_to_word/workspace.py
index 5b2b617..0455130 100644
--- a/backend/app/services/pdf_to_word/workspace.py
+++ b/backend/app/services/pdf_to_word/workspace.py
@@ -4,6 +4,15 @@ import json
 import shutil
 import tempfile
 from pathlib import Path
+from typing import Any
+
+
+CANONICAL_VISUAL_EVIDENCE_FILENAMES = (
+    "render_pair.json",
+    "visual_similarity.json",
+    "fidelity_veto.json",
+    "human_review_report.json",
+)
 
 
 class PDFToWordWorkspace:
@@ -25,13 +34,51 @@ class PDFToWordWorkspace:
         shutil.rmtree(self.path, ignore_errors=True)
         self.path = None
 
-    def write_json(self, name: str, payload: dict) -> Path:
+    def ensure_dir(self, *parts: str) -> Path:
         if self.path is None:
             raise RuntimeError("workspace is not active")
-        target = self.path / name
-        target.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+        target = self.path.joinpath(*parts)
+        target.mkdir(parents=True, exist_ok=True)
         return target
 
+    def write_json(self, name: str, payload: dict[str, Any]) -> Path:
+        if self.path is None:
+            raise RuntimeError("workspace is not active")
+        return write_json_payload(self.path / name, payload)
+
+    def write_canonical_visual_evidence(self, artifact_name: str, payload: dict[str, Any]) -> Path:
+        if artifact_name not in CANONICAL_VISUAL_EVIDENCE_FILENAMES:
+            raise ValueError(f"unsupported canonical visual evidence artifact: {artifact_name}")
+        return self.write_json(artifact_name, payload)
+
+
+def write_json_payload(path: str | Path, payload: dict[str, Any]) -> Path:
+    target = Path(path).expanduser().resolve()
+    target.parent.mkdir(parents=True, exist_ok=True)
+    target.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+    return target
+
+
+def collect_canonical_visual_evidence(sample_root: str | Path) -> dict[str, Any]:
+    resolved_root = Path(sample_root).expanduser().resolve()
+    artifacts: dict[str, dict[str, Any]] = {}
+    missing: list[str] = []
+    for file_name in CANONICAL_VISUAL_EVIDENCE_FILENAMES:
+        path = resolved_root / file_name
+        exists = path.exists()
+        artifacts[file_name] = {
+            "path": str(path),
+            "exists": exists,
+        }
+        if not exists:
+            missing.append(file_name)
+    return {
+        "sample_root": str(resolved_root),
+        "artifacts": artifacts,
+        "missing_artifacts": missing,
+        "complete": not missing,
+    }
+
 
 def create_pdf_to_word_workspace(root: Path) -> PDFToWordWorkspace:
     return PDFToWordWorkspace(root)
