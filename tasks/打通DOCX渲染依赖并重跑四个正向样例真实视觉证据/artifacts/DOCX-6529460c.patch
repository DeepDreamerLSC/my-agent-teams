+            resolved_docx_path,
+            render_root=resolved_render_root,
+            render_dpi=render_dpi,
+            expected_page_count=expected_page_count,
+            page_size=fallback_page_size,
+            fallback_reason=exc.to_dict(),
+        )
+
+    pages = render_pdf_pages(
+        converted_pdf,
+        source_name=resolved_docx_path.name,
+        render_root=resolved_render_root,
+        render_dpi=render_dpi,
+        metadata_extra={
+            "source_docx": str(resolved_docx_path),
+            "converted_pdf_path": str(converted_pdf),
+            "renderer_strategy": "libreoffice_pdf_conversion",
+        },
+    )
+    return {
+        "status": "success",
+        "renderer_strategy": "libreoffice_pdf_conversion",
+        "docx_path": str(resolved_docx_path),
+        "converted_pdf_path": str(converted_pdf),
+        "pages": pages,
+        "fallback_used": False,
+    }
