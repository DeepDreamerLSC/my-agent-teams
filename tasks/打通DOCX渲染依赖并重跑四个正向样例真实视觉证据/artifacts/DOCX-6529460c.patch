+                "docx_pdf_conversion_failed",
+                f"custom docx converter failed for {resolved_docx_path.name}",
+                details={"docx_path": str(resolved_docx_path), "error": str(exc)},
+            ) from exc
+        candidate_path = Path(candidate).expanduser().resolve() if candidate else resolved_output_pdf_path
