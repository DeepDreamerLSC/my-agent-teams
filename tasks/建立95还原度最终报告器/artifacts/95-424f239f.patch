+def _coerce_fidelity_score(value: Any) -> float | None:
+    try:
+        numeric = float(value)
+    except (TypeError, ValueError):
+        return None
+    if numeric < 0:
+        numeric = 0.0
+    return round(numeric, 4)
+
+
+def _coerce_fidelity_notes(value: Any) -> list[str]:
+    if isinstance(value, list):
+        return [str(item) for item in value if str(item).strip()]
+    if isinstance(value, str) and value.strip():
+        return [value.strip()]
+    return []
+
+
+def _resolve_fidelity_dimension_threshold(*, weight: float | None, threshold: float) -> float:
+    normalized_threshold = max(0.0, float(threshold))
+    if weight is None or float(weight) <= 0:
+        return round(normalized_threshold, 4)
+    return round(float(weight) * normalized_threshold / 100.0, 4)
+
+
+def _normalize_fidelity_weights_payload(payload: dict[str, Any]) -> dict[str, float]:
+    weights: dict[str, float] = {}
+    for raw_name, raw_value in payload.items():
+        name = str(raw_name).strip()
+        if not name:
+            continue
+        normalized_name = 'tables' if name in FIDELITY_TABLE_DIMENSION_ALIASES else name
+        try:
+            weights[normalized_name] = round(float(raw_value), 4)
+        except (TypeError, ValueError):
+            continue
+    return weights
+
+
+def _normalize_fidelity_dimensions_payload(payload: dict[str, Any]) -> dict[str, dict[str, Any]]:
+    dimensions: dict[str, dict[str, Any]] = {}
+    for raw_name, raw_value in payload.items():
+        name = str(raw_name).strip()
+        if not name or not isinstance(raw_value, dict):
+            continue
+        normalized_name = 'tables' if name in FIDELITY_TABLE_DIMENSION_ALIASES else name
+        merged_payload = dict(dimensions.get(normalized_name) or {})
+        merged_payload.update(raw_value)
+        dimensions[normalized_name] = merged_payload
+    return dimensions
+
+
+def _normalize_fidelity_tables(payload: dict[str, Any], *, threshold: float, weight: float | None) -> tuple[dict[str, Any], list[str]]:
+    score = _coerce_fidelity_score(payload.get('score'))
+    implemented = _coerce_bool(payload.get('implemented', score is not None))
+    notes = _coerce_fidelity_notes(payload.get('notes') or payload.get('warnings'))
+    detected_table_sample_count = int(payload.get('detected_table_sample_count') or 0)
+    sample_with_table_xml_count = int(payload.get('sample_with_table_xml_count') or 0)
+    image_fallback_table_count = int(payload.get('image_fallback_table_count') or payload.get('table_fallback_count') or 0)
+    raw_has_table_xml = payload.get('has_table_xml') if 'has_table_xml' in payload else payload.get('table_xml_present')
+    has_table_xml = _coerce_bool(raw_has_table_xml)
+    if not has_table_xml and sample_with_table_xml_count > 0:
+        has_table_xml = True
+    if score is None and implemented:
+        score = 0.0
+    dimension_threshold = _resolve_fidelity_dimension_threshold(weight=weight, threshold=threshold)
+    hard_gate_passed = (
+        implemented
+        and (
+            detected_table_sample_count <= 0
+            or (
+                has_table_xml
+                and sample_with_table_xml_count >= detected_table_sample_count
+                and image_fallback_table_count == 0
+            )
+        )
+    )
+    if not implemented:
+        status = 'missing'
+    elif not hard_gate_passed:
+        status = 'fail'
+    elif score is not None and score >= dimension_threshold:
+        status = 'pass'
+    else:
+        status = 'review'
+    blockers: list[str] = []
+    if not implemented:
+        blockers.append('dimension_missing:tables')
+    elif detected_table_sample_count > 0 and sample_with_table_xml_count < detected_table_sample_count:
+        blockers.append('table_gate_failed:detected_without_word_table_xml')
+    if image_fallback_table_count > 0:
+        blockers.append('table_gate_failed:image_fallback_present')
+    return (
+        {
+            'implemented': implemented,
+            'status': status,
+            'score': score,
+            'has_table_xml': has_table_xml,
+            'detected_table_sample_count': detected_table_sample_count,
+            'sample_with_table_xml_count': sample_with_table_xml_count,
+            'image_fallback_table_count': image_fallback_table_count,
+            'hard_gate_passed': hard_gate_passed,
+            'notes': notes,
+        },
+        blockers,
+    )
+
+
+def build_fidelity_final_report_summary(*, input_path: str | Path) -> dict[str, Any]:
+    resolved_input = Path(input_path).expanduser().resolve()
+    payload = _read_json(resolved_input)
+    threshold = _coerce_fidelity_score(payload.get('threshold'))
+    if threshold is None:
+        threshold = FIDELITY_FINAL_REPORT_DEFAULT_THRESHOLD
+    weights_payload = payload.get('weights') if isinstance(payload.get('weights'), dict) else {}
+    dimensions_payload = payload.get('dimensions') if isinstance(payload.get('dimensions'), dict) else {}
+    weights = _normalize_fidelity_weights_payload(weights_payload)
+    normalized_dimensions_payload = _normalize_fidelity_dimensions_payload(dimensions_payload)
+
+    dimensions: dict[str, Any] = {}
+    missing_dimensions: list[str] = []
+    blocking_failures = [str(item) for item in (payload.get('blocking_failures') or []) if str(item).strip()]
+    weighted_total = 0.0
+
+    for name, weight in weights.items():
+        raw_dimension = normalized_dimensions_payload.get(name) if isinstance(normalized_dimensions_payload.get(name), dict) else {}
+        if name == 'tables':
+            table_summary, table_blockers = _normalize_fidelity_tables(raw_dimension, threshold=threshold, weight=weight)
+            score = table_summary.get('score')
+            weighted_score = round(float(score or 0.0), 4)
+            table_summary['weight'] = round(float(weight), 4)
+            table_summary['weighted_score'] = weighted_score
+            dimensions[name] = table_summary
+            weighted_total += weighted_score
+            blocking_failures.extend(table_blockers)
+            if table_summary['status'] == 'missing':
+                missing_dimensions.append(name)
+            continue
+
+        implemented = _coerce_bool(raw_dimension.get('implemented', raw_dimension.get('score') is not None))
+        score = _coerce_fidelity_score(raw_dimension.get('score'))
+        notes = _coerce_fidelity_notes(raw_dimension.get('notes') or raw_dimension.get('warnings'))
+        dimension_threshold = _resolve_fidelity_dimension_threshold(weight=weight, threshold=threshold)
+        if not implemented or score is None:
+            status = 'missing'
+            weighted_score = 0.0
+            missing_dimensions.append(name)
+            blocking_failures.append(f'dimension_missing:{name}')
+        else:
+            weighted_score = round(float(score), 4)
+            weighted_total += weighted_score
+            status = 'pass' if score >= dimension_threshold else 'review'
+        dimensions[name] = {
+            'implemented': implemented and score is not None,
+            'status': status,
+            'score': score,
+            'weight': round(float(weight), 4),
+            'weighted_score': weighted_score,
+            'notes': notes,
+        }
+
+    tables = dict(dimensions.get('tables') or {})
+    overall_score = round(weighted_total, 4)
+    if overall_score < threshold:
+        blocking_failures.append(f'overall_score_below_threshold:{overall_score:.4f}')
+    blocking_failures = list(dict.fromkeys(blocking_failures))
+    report_passed = not missing_dimensions and not blocking_failures and overall_score >= threshold
+
+    return {
+        'report_type': FIDELITY_FINAL_REPORT_TYPE,
+        'generated_at': datetime.now().astimezone().isoformat(timespec='seconds'),
+        'input_path': str(resolved_input),
+        'schema_version': int(payload.get('schema_version') or 1),
+        'sample_set': str(payload.get('sample_set') or '').strip() or None,
+        'threshold': threshold,
+        'overall_score': overall_score,
+        'pass': report_passed,
+        'blocking_failures': blocking_failures,
+        'missing_dimensions': missing_dimensions,
+        'weights': {key: round(float(value), 4) for key, value in weights.items()},
+        'dimensions': dimensions,
+        'tables': tables,
+        'coverage': {
+            'dimension_count': len(weights),
+            'implemented_dimension_count': sum(1 for item in dimensions.values() if item.get('implemented')),
+            'missing_dimension_count': len(missing_dimensions),
+        },
+    }
+
+
+def _build_fidelity_final_report_markdown(summary: dict[str, Any]) -> str:
+    lines = [
+        '# PDF→Word 95% Fidelity Final Report',
+        '',
+        f"- Pass: `{str(summary.get('pass')).lower()}`",
+        f"- Overall score: `{summary.get('overall_score')}`",
+        f"- Threshold: `{summary.get('threshold')}`",
+        f"- Sample set: `{summary.get('sample_set')}`",
+        '',
+        '## Table Gate',
+        '',
+        f"- has_table_xml: `{(summary.get('tables') or {}).get('has_table_xml')}`",
+        f"- detected_table_sample_count: `{(summary.get('tables') or {}).get('detected_table_sample_count')}`",
+        f"- sample_with_table_xml_count: `{(summary.get('tables') or {}).get('sample_with_table_xml_count')}`",
+        f"- image_fallback_table_count: `{(summary.get('tables') or {}).get('image_fallback_table_count')}`",
+        f"- hard_gate_passed: `{(summary.get('tables') or {}).get('hard_gate_passed')}`",
+        '',
+        '## Dimensions',
+        '',
+    ]
+    for name, payload in (summary.get('dimensions') or {}).items():
+        lines.append(
+            f"- `{name}`: status=`{payload.get('status')}`, score=`{payload.get('score')}`, "
+            f"weight=`{payload.get('weight')}`, weighted=`{payload.get('weighted_score')}`"
+        )
+    lines.extend(['', '## Blocking Failures', ''])
+    failures = summary.get('blocking_failures') or []
+    if failures:
+        lines.extend(f'- `{failure}`' for failure in failures)
+    else:
+        lines.append('- None')
+    return '\n'.join(lines) + '\n'
+
+
+def write_fidelity_final_report_artifacts(summary: dict[str, Any], output_dir: str | Path) -> Path:
+    target_dir = Path(output_dir).expanduser().resolve()
+    target_dir.mkdir(parents=True, exist_ok=True)
+    (target_dir / 'fidelity_metrics.json').write_text(
+        json.dumps(summary, ensure_ascii=False, indent=2) + '\n',
+        encoding='utf-8',
+    )
+    (target_dir / 'fidelity_report.md').write_text(
+        _build_fidelity_final_report_markdown(summary),
+        encoding='utf-8',
+    )
+    return target_dir
+
