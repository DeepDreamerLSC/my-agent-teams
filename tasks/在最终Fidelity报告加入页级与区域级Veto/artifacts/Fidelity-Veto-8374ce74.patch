@@ -0,0 +1,429 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any, Sequence
+
+
+FIDELITY_VETO_CONTRACT_VERSION = 'pdf_to_word_fidelity_veto/v1'
+FIDELITY_VETO_TAXONOMY: dict[str, dict[str, Any]] = {
+    'critical_page_reading_order_break': {
+        'severity': 'p0',
+        'scope': 'page',
+        'category': 'reading_order',
+        'label': '关键页读序崩坏',
+        'subject_scope': ['science', 'math', 'chinese', 'english', 'general'],
+    },
+    'table_visual_adjacency_severe_misalignment': {
+        'severity': 'p0',
+        'scope': 'region',
+        'category': 'table_visual_adjacency',
+        'label': '表格视觉邻接严重错位',
+        'subject_scope': ['science', 'math', 'general'],
+    },
+    'formula_or_graphic_region_critical_distortion': {
+        'severity': 'p0',
+        'scope': 'region',
+        'category': 'formula_or_graphic',
+        'label': '公式/图形区关键失真',
+        'subject_scope': ['math', 'science', 'general'],
+    },
+    'english_reading_or_option_region_critical_distortion': {
+        'severity': 'p0',
+        'scope': 'region',
+        'category': 'english_reading_or_option',
+        'label': '英语阅读/选项区关键失真',
+        'subject_scope': ['english', 'general'],
+    },
+    'critical_fallback_not_visually_close_to_source': {
+        'severity': 'p0',
+        'scope': 'page',
+        'category': 'fallback_gap',
+        'label': '关键页 fallback 无法接近原 PDF',
+        'subject_scope': ['science', 'math', 'chinese', 'english', 'general'],
+    },
+}
+FIDELITY_VETO_CODE_ALIASES = {
+    'page_reading_order_break': 'critical_page_reading_order_break',
+    'reading_order_break': 'critical_page_reading_order_break',
+    'table_visual_adjacency_misaligned': 'table_visual_adjacency_severe_misalignment',
+    'table_adjacency_misaligned': 'table_visual_adjacency_severe_misalignment',
+    'formula_graphic_critical_distortion': 'formula_or_graphic_region_critical_distortion',
+    'formula_critical_distortion': 'formula_or_graphic_region_critical_distortion',
+    'graphic_critical_distortion': 'formula_or_graphic_region_critical_distortion',
+    'english_reading_option_critical_distortion': 'english_reading_or_option_region_critical_distortion',
+    'english_option_critical_distortion': 'english_reading_or_option_region_critical_distortion',
+    'fallback_page_not_visually_close': 'critical_fallback_not_visually_close_to_source',
+    'key_page_fallback_not_close': 'critical_fallback_not_visually_close_to_source',
+}
+FIDELITY_VETO_ARTIFACT_FIELDS = (
+    'fidelity_veto_path',
+    'visual_similarity_path',
+    'fidelity_report_path',
+)
+
+
+def _coerce_int(value: Any) -> int | None:
+    try:
+        return int(value)
+    except (TypeError, ValueError):
+        return None
+
+
+def _coerce_float(value: Any) -> float | None:
+    try:
+        return float(value)
+    except (TypeError, ValueError):
+        return None
+
+
+def _str_or_none(value: Any) -> str | None:
+    text = str(value or '').strip()
+    return text or None
+
+
+def _dedupe_paths(paths: Sequence[Path]) -> list[Path]:
+    result: list[Path] = []
+    seen: set[Path] = set()
+    for raw_path in paths:
+        path = raw_path.expanduser().resolve()
+        if path in seen:
+            continue
+        seen.add(path)
+        result.append(path)
+    return result
+
+
+def _normalize_evidence_paths(value: Any) -> list[str]:
+    if isinstance(value, list):
+        return [text for item in value if (text := _str_or_none(item))]
+    if isinstance(value, dict):
+        return [text for item in value.values() if (text := _str_or_none(item))]
+    if isinstance(value, str):
+        text = _str_or_none(value)
+        return [text] if text else []
+    return []
+
+
+def _canonicalize_veto_code(raw_code: str | None) -> str:
+    normalized = str(raw_code or '').strip()
+    return FIDELITY_VETO_CODE_ALIASES.get(normalized, normalized or 'unknown_veto')
+
+
+def _infer_scope(entry: dict[str, Any], *, default_scope: str | None = None) -> str:
+    explicit = _str_or_none(entry.get('scope'))
+    if explicit in {'page', 'region'}:
+        return explicit
+    if default_scope in {'page', 'region'}:
+        return str(default_scope)
+    if any(entry.get(key) is not None for key in ('region_id', 'region_kind', 'region_label', 'key_region_kind')):
+        return 'region'
+    return 'page'
+
+
+def _normalize_veto_entry(entry: dict[str, Any], *, default_scope: str | None = None) -> dict[str, Any]:
+    raw_code = _str_or_none(entry.get('code') or entry.get('reason_code') or entry.get('kind'))
+    canonical_code = _canonicalize_veto_code(raw_code)
+    taxonomy = FIDELITY_VETO_TAXONOMY.get(canonical_code) or {}
+    scope = _infer_scope(entry, default_scope=default_scope or _str_or_none(taxonomy.get('scope')))
+    summary = (
+        _str_or_none(entry.get('summary'))
+        or _str_or_none(entry.get('reason'))
+        or _str_or_none(entry.get('message'))
+        or _str_or_none(taxonomy.get('label'))
+        or canonical_code
+    )
+    severity = str(entry.get('severity') or taxonomy.get('severity') or 'p1').strip().lower()
+    return {
+        'code': raw_code or canonical_code,
+        'canonical_code': canonical_code,
+        'severity': severity,
+        'scope': scope,
+        'page_index': _coerce_int(entry.get('page_index') or entry.get('page')),
+        'region_kind': (
+            _str_or_none(entry.get('region_kind'))
+            or _str_or_none(entry.get('key_region_kind'))
+            or _str_or_none(entry.get('region_type'))
+        ),
+        'region_id': (
+            _str_or_none(entry.get('region_id'))
+            or _str_or_none(entry.get('region_label'))
+            or _str_or_none(entry.get('key_region_id'))
+        ),
+        'summary': summary,
+        'category': _str_or_none(taxonomy.get('category')),
+        'label': _str_or_none(taxonomy.get('label')),
+        'subject_scope': list(taxonomy.get('subject_scope') or []),
+        'triggered': bool(entry.get('triggered', True)),
+        'evidence_paths': _normalize_evidence_paths(
+            entry.get('evidence_paths') or entry.get('evidence') or entry.get('artifacts')
+        ),
+    }
+
+
+def _normalize_page_scores(payload: Any) -> list[float]:
+    if not isinstance(payload, list):
+        return []
+    scores: list[float] = []
+    for item in payload:
+        if not isinstance(item, dict):
+            continue
+        value = _coerce_float(item.get('score') if item.get('score') is not None else item.get('similarity_score'))
+        if value is not None:
+            scores.append(value)
+    return scores
+
+
+def _collect_raw_vetoes(payload: dict[str, Any]) -> list[dict[str, Any]]:
+    vetoes: list[dict[str, Any]] = []
+    for field_name, default_scope in (
+        ('vetoes', None),
+        ('page_vetoes', 'page'),
+        ('region_vetoes', 'region'),
+    ):
+        items = payload.get(field_name)
+        if not isinstance(items, list):
+            continue
+        for item in items:
+            if isinstance(item, dict):
+                vetoes.append(_normalize_veto_entry(item, default_scope=default_scope))
+    deduped: list[dict[str, Any]] = []
+    seen: set[tuple[Any, ...]] = set()
+    for item in vetoes:
+        if not item.get('triggered'):
+            continue
+        key = (
+            item.get('canonical_code'),
+            item.get('scope'),
+            item.get('page_index'),
+            item.get('region_kind'),
+            item.get('region_id'),
+            item.get('summary'),
+        )
+        if key in seen:
+            continue
+        seen.add(key)
+        deduped.append(item)
+    return deduped
+
+
+def _empty_summary(
+    *,
+    sample_name: str,
+    status: str,
+    artifact_candidates: list[Path],
+    artifact_path: Path | None = None,
+    error: str | None = None,
+) -> dict[str, Any]:
+    return {
+        'contract_version': FIDELITY_VETO_CONTRACT_VERSION,
+        'status': status,
+        'artifact_path': str(artifact_path) if artifact_path else None,
+        'artifact_candidates': [str(path) for path in artifact_candidates],
+        'sample_name': sample_name,
+        'subject': None,
+        'document_page_type': None,
+        'overall_score': None,
+        'human_review_required': False,
+        'page_score_count': 0,
+        'min_page_score': None,
+        'render_pair_count': 0,
+        'veto_count': 0,
+        'p0_veto_count': 0,
+        'page_veto_count': 0,
+        'region_veto_count': 0,
+        'taxonomy_counts': {},
+        'failed_taxonomy': [],
+        'vetoes': [],
+        'p0_vetoes': [],
+        'no_go': False,
+        'error': error,
+    }
+
+
+def summarize_fidelity_veto_payload(
+    payload: dict[str, Any],
+    *,
+    sample_name: str,
+    artifact_candidates: Sequence[Path] | None = None,
+    artifact_path: str | Path | None = None,
+) -> dict[str, Any]:
+    page_scores = _normalize_page_scores(payload.get('page_scores'))
+    render_pairs = payload.get('render_pairs') if isinstance(payload.get('render_pairs'), list) else []
+    vetoes = _collect_raw_vetoes(payload)
+    vetoes.sort(
+        key=lambda item: (
+            0 if str(item.get('severity')) == 'p0' else 1,
+            int(item.get('page_index') or 0),
+            str(item.get('scope') or ''),
+            str(item.get('canonical_code') or ''),
+        )
+    )
+    p0_vetoes = [item for item in vetoes if str(item.get('severity') or '').lower() == 'p0']
+    taxonomy_counts: dict[str, int] = {}
+    for item in p0_vetoes:
+        key = str(item.get('canonical_code') or 'unknown_veto')
+        taxonomy_counts[key] = int(taxonomy_counts.get(key, 0)) + 1
+
+    return {
+        'contract_version': (
+            _str_or_none(payload.get('contract_version'))
+            or _str_or_none(payload.get('report_type'))
+            or FIDELITY_VETO_CONTRACT_VERSION
+        ),
+        'status': 'present',
+        'artifact_path': str(Path(artifact_path).expanduser().resolve()) if artifact_path else None,
+        'artifact_candidates': [str(path) for path in (artifact_candidates or [])],
+        'sample_name': _str_or_none(payload.get('sample_name')) or sample_name,
+        'subject': _str_or_none(payload.get('subject')),
+        'document_page_type': _str_or_none(payload.get('document_page_type') or payload.get('page_type')),
+        'overall_score': _coerce_float(payload.get('overall_score') if payload.get('overall_score') is not None else payload.get('score')),
+        'human_review_required': bool(payload.get('human_review_required')),
+        'page_score_count': len(page_scores),
+        'min_page_score': min(page_scores) if page_scores else None,
+        'render_pair_count': len(render_pairs),
+        'veto_count': len(vetoes),
+        'p0_veto_count': len(p0_vetoes),
+        'page_veto_count': sum(1 for item in vetoes if item.get('scope') == 'page'),
+        'region_veto_count': sum(1 for item in vetoes if item.get('scope') == 'region'),
+        'taxonomy_counts': taxonomy_counts,
+        'failed_taxonomy': sorted(taxonomy_counts),
+        'vetoes': vetoes,
+        'p0_vetoes': p0_vetoes,
+        'no_go': bool(p0_vetoes),
+        'error': None,
+    }
+
+
+def _candidate_artifact_paths(
+    *,
+    sample_name: str,
+    sample_dir: str | Path,
+    archive_root: str | Path,
+    source_manifest: dict[str, Any] | None = None,
+) -> list[Path]:
+    sample_root = Path(sample_dir).expanduser().resolve()
+    archive_path = Path(archive_root).expanduser().resolve()
+    source_artifacts = (
+        source_manifest.get('source_artifacts')
+        if isinstance(source_manifest, dict) and isinstance(source_manifest.get('source_artifacts'), dict)
+        else {}
+    )
+    candidates: list[Path] = []
+    for field_name in FIDELITY_VETO_ARTIFACT_FIELDS:
+        path_value = source_artifacts.get(field_name) if isinstance(source_artifacts, dict) else None
+        if path_value:
+            candidates.append(Path(str(path_value)))
+    candidates.extend([
+        sample_root / 'fidelity_veto.json',
+        sample_root / 'visual_similarity.json',
+        archive_path / 'reports' / 'fidelity-veto' / f'{sample_name}.json',
+        archive_path / 'reports' / 'visual_similarity' / f'{sample_name}.json',
+    ])
+    return _dedupe_paths(candidates)
+
+
+def load_fidelity_veto_summary(
+    *,
+    sample_name: str,
+    sample_dir: str | Path,
+    archive_root: str | Path,
+    source_manifest: dict[str, Any] | None = None,
+) -> dict[str, Any]:
+    candidates = _candidate_artifact_paths(
+        sample_name=sample_name,
+        sample_dir=sample_dir,
+        archive_root=archive_root,
+        source_manifest=source_manifest,
+    )
+    artifact_path = next((path for path in candidates if path.exists() and path.is_file()), None)
+    if artifact_path is None:
+        return _empty_summary(sample_name=sample_name, status='missing', artifact_candidates=candidates)
+    try:
+        payload = json.loads(artifact_path.read_text(encoding='utf-8'))
+    except Exception as exc:
+        return _empty_summary(
+            sample_name=sample_name,
+            status='invalid',
+            artifact_candidates=candidates,
+            artifact_path=artifact_path,
+            error=str(exc),
+        )
+    if not isinstance(payload, dict):
+        return _empty_summary(
+            sample_name=sample_name,
+            status='invalid',
+            artifact_candidates=candidates,
+            artifact_path=artifact_path,
+            error='fidelity_veto_payload_not_object',
+        )
+    return summarize_fidelity_veto_payload(
+        payload,
+        sample_name=sample_name,
+        artifact_candidates=candidates,
+        artifact_path=artifact_path,
+    )
+
+
+def build_fidelity_veto_gate_summary(sample_summaries: Sequence[dict[str, Any]]) -> dict[str, Any]:
+    samples: list[dict[str, Any]] = [dict(item) for item in sample_summaries if isinstance(item, dict)]
+    available_sample_count = sum(1 for sample in samples if sample.get('status') == 'present')
+    missing_sample_count = sum(1 for sample in samples if sample.get('status') == 'missing')
+    invalid_sample_count = sum(1 for sample in samples if sample.get('status') == 'invalid')
+    page_veto_count = sum(int(sample.get('page_veto_count') or 0) for sample in samples)
+    region_veto_count = sum(int(sample.get('region_veto_count') or 0) for sample in samples)
+    p0_veto_count = sum(int(sample.get('p0_veto_count') or 0) for sample in samples)
+    sample_with_any_veto_count = sum(1 for sample in samples if int(sample.get('veto_count') or 0) > 0)
+    sample_with_p0_veto_count = sum(1 for sample in samples if int(sample.get('p0_veto_count') or 0) > 0)
+    samples_requiring_human_review = sorted({
+        str(sample.get('sample_name') or '')
+        for sample in samples
+        if sample.get('human_review_required')
+    })
+    taxonomy_counts: dict[str, int] = {}
+    for sample in samples:
+        for key, value in (sample.get('taxonomy_counts') or {}).items():
+            taxonomy_counts[str(key)] = int(taxonomy_counts.get(str(key), 0)) + int(value or 0)
+
+    if invalid_sample_count:
+        status = 'invalid_artifact_present'
+    elif available_sample_count == 0:
+        status = 'waiting_for_upstream_artifact'
+    elif missing_sample_count:
+        status = 'partial_coverage'
+    else:
+        status = 'active'
+
+    return {
+        'status': status,
+        'contract_version': FIDELITY_VETO_CONTRACT_VERSION,
+        'supported_p0_veto_codes': sorted(FIDELITY_VETO_TAXONOMY),
+        'available_sample_count': available_sample_count,
+        'missing_sample_count': missing_sample_count,
+        'invalid_sample_count': invalid_sample_count,
+        'sample_with_any_veto_count': sample_with_any_veto_count,
+        'sample_with_p0_veto_count': sample_with_p0_veto_count,
+        'page_veto_count': page_veto_count,
+        'region_veto_count': region_veto_count,
+        'p0_veto_count': p0_veto_count,
+        'p0_triggered': p0_veto_count > 0,
+        'taxonomy_counts': dict(sorted(taxonomy_counts.items())),
+        'triggered_sample_names': sorted(
+            str(sample.get('sample_name') or '')
+            for sample in samples
+            if int(sample.get('p0_veto_count') or 0) > 0
+        ),
+        'samples_requiring_human_review': samples_requiring_human_review,
+        'samples': [
+            {
+                'sample_name': str(sample.get('sample_name') or ''),
+                'status': sample.get('status'),
+                'overall_score': sample.get('overall_score'),
+                'veto_count': int(sample.get('veto_count') or 0),
+                'p0_veto_count': int(sample.get('p0_veto_count') or 0),
+                'failed_taxonomy': list(sample.get('failed_taxonomy') or []),
+                'no_go': bool(sample.get('no_go')),
+            }
+            for sample in samples
+        ],
+    }
