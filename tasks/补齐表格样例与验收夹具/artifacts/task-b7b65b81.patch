diff --git a/backend/tests/test_pdf_to_word_table_fixtures.py b/backend/tests/test_pdf_to_word_table_fixtures.py
new file mode 100644
index 0000000..21b8288
--- /dev/null
+++ b/backend/tests/test_pdf_to_word_table_fixtures.py
@@ -0,0 +1,135 @@
+from __future__ import annotations
+
+from io import BytesIO
+import json
+from pathlib import Path
+import zipfile
+from xml.etree import ElementTree as ET
+
+import pytest
+
+from app.services.pdf_to_word.exercise_docx_assembler import assemble_exercise_docx_bytes
+from app.services.pdf_to_word.exercise_ir import ContentBlock, ExerciseDocument, ExerciseItem, ExerciseSection, encode_docx_visual_payload
+from app.services.pdf_to_word.table_ir import load_normalized_table_ir, validate_normalized_table_ir
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "table_goldens"
+TABLE_IR_FIXTURE_DIR = Path(__file__).parent / "fixtures" / "pdf_to_word" / "table_ir"
+WORD_NS = {"w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main"}
+
+
+def _load_cases() -> list[dict]:
+    payload = json.loads((FIXTURE_DIR / "cases.json").read_text(encoding="utf-8"))
+    return list(payload["cases"])
+
+
+CASES = _load_cases()
+
+
+def _read_document_xml(docx_bytes: bytes) -> str:
+    with zipfile.ZipFile(BytesIO(docx_bytes)) as archive:
+        return archive.read("word/document.xml").decode("utf-8")
+
+
+def _read_document_root(docx_bytes: bytes) -> ET.Element:
+    return ET.fromstring(_read_document_xml(docx_bytes))
+
+
+def _build_table_payload(case: dict) -> dict:
+    payload_source = str(case["payload_source"])
+    payload: dict = {
+        "kind": "table",
+        "fallback_text": str(case["fallback_text"]),
+    }
+    if payload_source == "table_rows":
+        payload["version"] = 1
+        payload["table_rows"] = list(case["table_rows"])
+        return payload
+
+    if payload_source == "table_html":
+        payload["version"] = 1
+        payload["table_html"] = str(case["table_html"])
+        return payload
+
+    if payload_source != "table_ir":
+        raise AssertionError(f"unsupported payload_source: {payload_source}")
+
+    table_ir_path = TABLE_IR_FIXTURE_DIR / str(case["table_ir_fixture"])
+    table_ir = load_normalized_table_ir(table_ir_path)
+    report = validate_normalized_table_ir(table_ir)
+    payload.update(
+        {
+            "version": 2,
+            "table_id": table_ir.table_id,
+            "source_candidate_id": table_ir.source_candidate_id,
+            "table_ir": table_ir.to_dict(),
+            "table_validation_status": report.status,
+            "table_validation_warnings": list(report.warnings),
+            "assigned_question_id": case.get("question_id") or table_ir.assigned_question_id,
+            "assigned_region_id": table_ir.assigned_region_id,
+        }
+    )
+    if table_ir.raw.image_path is not None:
+        payload["image_path"] = table_ir.raw.image_path
+    return payload
+
+
+def _render_case(case: dict) -> tuple[str, ET.Element]:
+    payload = _build_table_payload(case)
+    document = ExerciseDocument(
+        source_name=f"{case['case_id']}.pdf",
+        mode="balanced",
+        parser_backend="fixture",
+        page_count=1,
+        sections=[
+            ExerciseSection(
+                title=str(case["sample_name"]),
+                items=[
+                    ExerciseItem(
+                        question_id=str(case["question_id"]),
+                        number=str(case["question_number"]),
+                        stem_blocks=[
+                            ContentBlock(kind="text", text=str(case["stem_text"])),
+                            ContentBlock(kind="table", text=encode_docx_visual_payload(payload)),
+                        ],
+                    )
+                ],
+            )
+        ],
+    )
+    docx_bytes = assemble_exercise_docx_bytes(document)
+    return _read_document_xml(docx_bytes), _read_document_root(docx_bytes)
+
+
+def test_table_golden_cases_cover_required_samples_and_expected_fields():
+    by_name = {case["sample_name"]: case for case in CASES}
+
+    assert {"英语八年级", "五下科学"} <= set(by_name)
+    assert any(case["expected"]["has_table_xml"] for case in CASES)
+    assert any(not case["expected"]["has_table_xml"] for case in CASES)
+
+    for case in CASES:
+        expected = case["expected"]
+        assert set(expected) == {"has_table_xml", "image_fallback_table_count", "required_cell_texts"}
+        assert isinstance(expected["has_table_xml"], bool)
+        assert isinstance(expected["image_fallback_table_count"], int)
+        assert isinstance(expected["required_cell_texts"], list)
+
+
+@pytest.mark.parametrize("case", CASES, ids=lambda case: str(case["case_id"]))
+def test_table_golden_cases_render_expected_table_gate_signals(case: dict):
+    document_xml, document_root = _render_case(case)
+    expected = case["expected"]
+
+    has_table_xml = bool(document_root.findall(".//w:tbl", WORD_NS))
+    fallback_count = document_xml.count(str(case["fallback_text"]))
+
+    assert has_table_xml is bool(expected["has_table_xml"])
+    assert fallback_count == int(expected["image_fallback_table_count"])
+
+    for text in expected["required_cell_texts"]:
+        assert str(text) in document_xml
+
+    if expected["has_table_xml"]:
+        assert fallback_count == 0
+    else:
+        assert document_root.findall(".//w:tbl", WORD_NS) == []
